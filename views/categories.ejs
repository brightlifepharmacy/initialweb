<% layout("/layouts/boilerplate") -%>

<section class="py-16 bg-gradient-to-b from-green-50 via-white to-gray-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-green-600 dark:text-green-400">Browse by Category</p>
      <h1 class="mt-3 text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">Product Categories</h1>
      <p class="mt-4 text-base leading-8 text-gray-600 dark:text-gray-300">
        Explore the main product groups available at BrightLife Pharmacy and jump straight into filtered listings.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 mt-12 md:grid-cols-3">
      <% categoryCards.forEach(category => { %>
        <article class="flex flex-col h-full overflow-hidden transition-all duration-300 bg-white border border-gray-200 shadow-sm rounded-2xl hover:-translate-y-1 hover:shadow-2xl dark:border-gray-700 dark:bg-gray-800">
          <div class="bg-gradient-to-br <%= category.accent %> p-6 text-white">
            <div class="flex items-center justify-between gap-4">
              <div class="flex items-center justify-center h-14 w-14 rounded-2xl bg-white/15 backdrop-blur-sm">
                <i class="fa-solid <%= category.icon %> text-2xl"></i>
              </div>
              <span class="px-3 py-1 text-sm font-semibold rounded-full bg-white/20 backdrop-blur-sm">
                <%= category.count %> items
              </span>
            </div>
            <h2 class="mt-6 text-2xl font-bold"><%= category.title %></h2>
          </div>

          <div class="flex flex-col flex-1 p-6">
            <p class="text-sm leading-7 text-gray-600 dark:text-gray-300">
              <%= category.description %>
            </p>

            <a
              href="<%= category.href %>"
              class="inline-flex items-center justify-center px-5 py-3 mt-6 text-sm font-semibold text-white transition-colors bg-green-600 rounded-lg hover:bg-green-700"
            >
              Explore Category
              <i class="ml-2 fa-solid fa-arrow-right"></i>
            </a>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="p-6 mt-12 bg-white border border-green-100 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Need the full catalog?</h2>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Open the full product list and use backend category filters from the products page.
          </p>
        </div>
        <a href="/products" class="inline-flex items-center justify-center px-5 py-3 font-semibold text-green-600 transition-colors border border-green-500 rounded-lg hover:bg-green-50 dark:text-green-400 dark:hover:bg-green-900/20">
          <i class="mr-2 fa-solid fa-boxes-stacked"></i>
          View All Products
        </a>
      </div>
    </div>
  </div>
</section>
