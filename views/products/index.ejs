    { id: 11, name: "Cough Syrup DC", category: "syrups", price: 65, mrp: 80, rating: 4.2, reviews: 54, rx: false, brand: "sun-pharma", image: "🧪" },
    { id: 12, name: "Zincovit Syrup", category: "syrups", price: 110, mrp: 130, rating: 4.5, reviews: 112, rx: false, brand: "cipla", image: "🧪" },
    { id: 13, name: "Maalox Plus", category: "syrups", price: 75, mrp: 95, rating: 4.3, reviews: 78, rx: false, brand: "dr-reddy", image: "🧪" },
    { id: 14, name: "Cough Syrup", category: "syrups", price: 45, mrp: 55, rating: 4.0, reviews: 43, rx: false, brand: "gsk", image: "🧪" },
    
    // Injectables
    { id: 15, name: "Insulin Injection", category: "injectables", price: 450, mrp: 550, rating: 4.8, reviews: 89, rx: true, brand: "pfizer", image: "💉" },
    { id: 16, name: "Vitamin B12 Injection", category: "injectables", price: 85, mrp: 100, rating: 4.4, reviews: 56, rx: true, brand: "cipla", image: "💉" },
    { id: 17, name: "Dexona Injection", category: "injectables", price: 65, mrp: 80, rating: 4.2, reviews: 34, rx: true, brand: "sun-pharma", image: "💉" },
    
    // Topical
    { id: 18, name: "Volini Gel", category: "topical", price: 145, mrp: 165, rating: 4.5, reviews: 88, rx: false, brand: "cipla", image: "🧴" },
    { id: 19, name: "Betadine Ointment", category: "topical", price: 68, mrp: 80, rating: 4.3, reviews: 61, rx: false, brand: "gsk", image: "🧴" },
    { id: 20, name: "Moisturex Cream", category: "topical", price: 120, mrp: 145, rating: 4.6, reviews: 73, rx: false, brand: "dr-reddy", image: "🧴" },
    { id: 21, name: "Acne Gel", category: "topical", price: 95, mrp: 115, rating: 4.1, reviews: 42, rx: false, brand: "sun-pharma", image: "🧴" },
    
    // Diabetic Care
    { id: 22, name: "Glucophage 500", category: "diabetic", price: 78, mrp: 95, rating: 4.5, reviews: 167, rx: true, brand: "pfizer", image: "💊" },
    { id: 23, name: "Glycomet 250", category: "diabetic", price: 55, mrp: 70, rating: 4.3, reviews: 89, rx: true, brand: "sun-pharma", image: "💊" },
    
    // Supplements
    { id: 24, name: "Ostocalcium", category: "supplements", price: 160, mrp: 185, rating: 4.7, reviews: 145, rx: false, brand: "gsk", image: "💊" },
    { id: 25, name: "Vitamin D3", category: "supplements", price: 125, mrp: 150, rating: 4.6, reviews: 98, rx: false, brand: "cipla", image: "💊" },
    { id: 26, name: "Omega 3", category: "supplements", price: 180, mrp: 210, rating: 4.8, reviews: 112, rx: false, brand: "pfizer", image: "💊" },
  ];

  // ===================== STATE =====================
  let currentPage = 1;
  const itemsPerPage = 12;
  let filteredProducts = [...allProducts];
  let currentProducts = [];

  // ===================== RENDER PRODUCTS =====================
  function renderProducts() {
    const grid = document.getElementById('product-grid');
    const start = (currentPage - 1) * itemsPerPage;
    const end = Math.min(start + itemsPerPage, filteredProducts.length);
    currentProducts = filteredProducts.slice(start, end);
    
    if (currentProducts.length === 0) {
      grid.innerHTML = `
        <div class="col-span-full text-center py-12">
          <div class="text-6xl mb-4">🔍</div>
          <h3 class="font-display text-xl text-[#12261A] dark:text-[#F2F8F0]">No products found</h3>
          <p class="text-sm text-[#4B5C50] dark:text-[#8FA393] mt-2">Try adjusting your filters</p>
        </div>
      `;
      return;
    }
    
    grid.innerHTML = currentProducts.map(med => `
      <div class="group relative rounded-2xl border border-[#E3E8E1] dark:border-[#22302A] bg-white dark:bg-[#16211A] overflow-hidden hover:border-[#2E7D32] dark:hover:border-[#4CAF50] hover:shadow-md transition-all product-card">
        
        ${med.rx ? `
          <span class="absolute top-3 left-3 z-10 bg-white dark:bg-[#16211A] border border-[#D4A63A]/50 text-[#8a6a1f] dark:text-[#E3C069] text-[10px] font-mono px-2.5 py-1 rounded-full rx-label shadow-sm">
            Rx required
          </span>
        ` : ''}
        
        <a href="/product/${med.id}" class="block">
          <div class="h-32 flex items-center justify-center bg-gradient-to-br from-[#E8F5E9] to-[#D2E9D5] dark:from-[#1D2E21] dark:to-[#16241A] text-5xl">
            ${med.image}
          </div>
        </a>
        
        <div class="p-4">
          <p class="text-[11px] text-[#4B5C50] dark:text-[#8FA393] font-mono capitalize">${med.category.replace('-', ' ')}</p>
          <a href="/product/${med.id}" class="block">
            <h3 class="font-semibold text-sm mt-1 text-[#12261A] dark:text-[#F2F8F0] hover:text-[#2E7D32] dark:hover:text-[#66BB6A] transition-colors">
              ${med.name}
            </h3>
          </a>
          
          <div class="flex items-center gap-1 mt-2">
            <svg class="w-3.5 h-3.5 text-[#C99A2E]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.05 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.958a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.363 1.118l1.287 3.957c.3.922-.755 1.688-1.538 1.118l-3.37-2.447a1 1 0 00-1.175 0l-3.37 2.447c-.783.57-1.838-.196-1.539-1.118l1.287-3.957a1 1 0 00-.363-1.118L2.062 9.386c-.784-.57-.38-1.81.588-1.81h4.163a1 1 0 00.95-.69l1.286-3.958z"/></svg>
            <span class="text-xs font-medium text-[#12261A] dark:text-[#E9F2E7]">${med.rating}</span>
            <span class="text-[11px] text-[#4B5C50] dark:text-[#8FA393]">(${med.reviews})</span>
          </div>
          
          <div class="flex items-baseline gap-2 mt-3">
            <span class="font-display font-semibold text-[#12261A] dark:text-[#F2F8F0]">₹${med.price}</span>
            <span class="text-xs text-[#8A978C] dark:text-[#6E8175] line-through">₹${med.mrp}</span>
            <span class="ml-auto text-xs text-[#2E7D32] dark:text-[#66BB6A] font-medium">${Math.round((1 - med.price/med.mrp) * 100)}% off</span>
          </div>
          
          <button class="mt-3 w-full text-xs font-semibold py-2.5 rounded-lg bg-[#2E7D32] hover:bg-[#276b2b] dark:bg-[#3F9142] dark:hover:bg-[#4CAF50] text-white transition-colors request-btn" data-id="${med.id}">
            Request purchase
          </button>
        </div>
      </div>
    `).join('');
    
    // Update pagination info
    document.getElementById('page-start').textContent = start + 1;
    document.getElementById('page-end').textContent = end;
    document.getElementById('total-items').textContent = filteredProducts.length;
    document.getElementById('product-count').textContent = filteredProducts.length;
    
    updatePagination();
    updateRequestButtons();
  }

  // ===================== UPDATE PAGINATION =====================
  function updatePagination() {
    const totalPages = Math.ceil(filteredProducts.length / itemsPerPage);
    const prevBtn = document.getElementById('prev-page');
    const nextBtn = document.getElementById('next-page');
    const pageBtns = document.querySelectorAll('.pagination-btn[data-page]');
    
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages || totalPages === 0;
    
    pageBtns.forEach(btn => {
      const page = parseInt(btn.dataset.page);
      btn.classList.toggle('active', page === currentPage);
    });
  }

  // ===================== FILTER FUNCTIONS =====================
  function applyFilters() {
    const selectedCategories = [];
    document.querySelectorAll('.filter-section:first-of-type input[type="checkbox"]:checked').forEach(cb => {
      selectedCategories.push(cb.value);
    });
    
    const rxChecked = document.querySelector('.filter-section:nth-of-type(3) input[value="rx"]')?.checked || false;
    const otcChecked = document.querySelector('.filter-section:nth-of-type(3) input[value="otc"]')?.checked || false;
    
    const priceMax = parseInt(document.getElementById('price-slider')?.value || 5000);
    
    filteredProducts = allProducts.filter(product => {
      // Category filter
      if (selectedCategories.length > 0 && !selectedCategories.includes(product.category)) {
        return false;
      }
      
      // Prescription filter
      if (rxChecked && !product.rx) return false;
      if (otcChecked && product.rx) return false;
      
      // Price filter
      if (product.price > priceMax) return false;
      
      return true;
    });
    
    currentPage = 1;
    renderProducts();
  }

  // ===================== REQUEST BUTTON =====================
  function updateRequestButtons() {
    document.querySelectorAll('.request-btn').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const id = this.dataset.id;
        const product = allProducts.find(p => p.id == id);
        if (product) {
          alert(`Request placed for ${product.name}\nPrice: ₹${product.price}\nA pharmacist will contact you shortly.`);
        }
      });
    });
  }

  // ===================== INIT =====================
  document.addEventListener('DOMContentLoaded', () => {
    renderProducts();
    
    // Price slider
    const slider = document.getElementById('price-slider');
    const priceMin = document.getElementById('price-min');
    const priceMax = document.getElementById('price-max');
    const priceInputMin = document.getElementById('price-input-min');
    const priceInputMax = document.getElementById('price-input-max');
    
    if (slider) {
      slider.addEventListener('input', function() {
        const val = this.value;
        priceMax.textContent = val;
        priceInputMax.value = val;
      });
    }
    
    // Apply filters
    document.getElementById('apply-filters')?.addEventListener('click', applyFilters);
    
    // Clear filters
    document.getElementById('clear-filters')?.addEventListener('click', function() {
      document.querySelectorAll('.filter-section input[type="checkbox"]').forEach(cb => cb.checked = false);
      document.querySelectorAll('.filter-section input[type="radio"]').forEach(rb => rb.checked = false);
      document.getElementById('price-slider').value = 5000;
      document.getElementById('price-max').textContent = '5000';
      document.getElementById('price-input-max').value = 5000;
      applyFilters();
    });
    
    // Pagination
    document.querySelectorAll('.pagination-btn[data-page]').forEach(btn => {
      btn.addEventListener('click', function() {
        const page = parseInt(this.dataset.page);
        const totalPages = Math.ceil(filteredProducts.length / itemsPerPage);
        if (page >= 1 && page <= totalPages) {
          currentPage = page;
          renderProducts();
        }
      });
    });
    
    document.getElementById('prev-page')?.addEventListener('click', function() {
      if (currentPage > 1) {
        currentPage--;
        renderProducts();
      }
    });
    
    document.getElementById('next-page')?.addEventListener('click', function() {
      const totalPages = Math.ceil(filteredProducts.length / itemsPerPage);
      if (currentPage < totalPages) {
        currentPage++;
        renderProducts();
      }
    });
    
    // Mobile filter drawer
    const filterToggle = document.getElementById('filter-toggle-mobile');
    const filterDrawer = document.getElementById('filter-drawer');
    const filterOverlay = document.getElementById('filter-overlay');
    const filterClose = document.getElementById('filter-close');
    
    if (filterToggle && filterDrawer) {
      filterToggle.addEventListener('click', function() {
        filterDrawer.classList.add('open');
        filterDrawer.style.pointerEvents = 'auto';
        filterOverlay.style.opacity = '1';
      });
      
      const closeFilter = () => {
        filterDrawer.classList.remove('open');
        setTimeout(() => {
          filterDrawer.style.pointerEvents = 'none';
        }, 300);
        filterOverlay.style.opacity = '0';
      };
      
      filterClose?.addEventListener('click', closeFilter);
      filterOverlay?.addEventListener('click', closeFilter);
    }
  });
</script>