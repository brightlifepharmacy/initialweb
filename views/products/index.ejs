<!-- products.ejs -->
<% layout("/layouts/boilerplate") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">

<style>
  .font-display { font-family: 'Fraunces', serif; }
  .font-body { font-family: 'Inter', sans-serif; }
  .font-mono { font-family: 'IBM Plex Mono', monospace; }

  .rx-label {
    transform: rotate(-2deg);
    font-family: 'IBM Plex Mono', monospace;
  }
  .rx-label::before {
    content: "";
    position: absolute;
    top: -5px;
    left: 14px;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: inherit;
  }

  /* Filter Sidebar Styles */
  .filter-section {
    transition: all 0.3s ease;
  }
  
  .filter-section summary {
    cursor: pointer;
    user-select: none;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid #E3E8E1;
  }
  
  .dark .filter-section summary {
    border-bottom-color: #22302A;
  }
  
  .filter-section summary::-webkit-details-marker {
    display: none;
  }
  
  .filter-section summary::after {
    content: "▼";
    font-size: 12px;
    transition: transform 0.3s ease;
  }
  
  .filter-section[open] summary::after {
    transform: rotate(180deg);
  }
  
  .filter-section .filter-content {
    padding: 12px 0;
  }
  
  /* Custom Checkbox */
  .custom-checkbox {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    padding: 6px 0;
    transition: color 0.2s;
  }
  
  .custom-checkbox:hover {
    color: #2E7D32;
  }
  
  .dark .custom-checkbox:hover {
    color: #66BB6A;
  }
  
  .custom-checkbox input[type="checkbox"] {
    display: none;
  }
  
  .custom-checkbox .checkmark {
    width: 18px;
    height: 18px;
    border: 2px solid #C5D0C0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
  }
  
  .dark .custom-checkbox .checkmark {
    border-color: #2A3A31;
  }
  
  .custom-checkbox input:checked + .checkmark {
    background: #2E7D32;
    border-color: #2E7D32;
  }
  
  .dark .custom-checkbox input:checked + .checkmark {
    background: #3F9142;
    border-color: #3F9142;
  }
  
  .custom-checkbox input:checked + .checkmark::after {
    content: "✓";
    color: white;
    font-size: 12px;
    font-weight: bold;
  }
  
  /* Price Range Slider */
  .price-slider {
    width: 100%;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: #C5D0C0;
    border-radius: 2px;
    outline: none;
  }
  
  .dark .price-slider {
    background: #2A3A31;
  }
  
  .price-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #2E7D32;
    cursor: pointer;
  }
  
  .dark .price-slider::-webkit-slider-thumb {
    background: #3F9142;
  }
  
  /* Pagination */
  .pagination-btn {
    min-width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: 1px solid #E3E8E1;
    background: white;
    color: #4B5C50;
    transition: all 0.2s;
    cursor: pointer;
  }
  
  .dark .pagination-btn {
    border-color: #22302A;
    background: #16211A;
    color: #A9BDAE;
  }
  
  .pagination-btn:hover {
    border-color: #2E7D32;
    color: #2E7D32;
  }
  
  .dark .pagination-btn:hover {
    border-color: #66BB6A;
    color: #66BB6A;
  }
  
  .pagination-btn.active {
    background: #2E7D32;
    border-color: #2E7D32;
    color: white;
  }
  
  .dark .pagination-btn.active {
    background: #3F9142;
    border-color: #3F9142;
    color: white;
  }
  
  .pagination-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  
  /* Product Card Hover Effects */
  .product-card {
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  
  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
  }
  
  .dark .product-card:hover {
    box-shadow: 0 12px 30px rgba(0,0,0,0.3);
  }
  
  /* Mobile Filter Drawer */
  .filter-drawer {
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  
  .filter-drawer.open {
    transform: translateX(0);
  }
</style>

