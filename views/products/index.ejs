<% layout("/layouts/boilerplate") %>

<!-- Products Page -->
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  
  <!-- Page Header -->
  <div class="bg-gradient-to-r from-green-600 to-teal-500">
    <div class="container px-4 py-8 mx-auto sm:px-6 lg:px-8">
      <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center">
        <div>
          <h1 class="mb-2 text-3xl font-bold text-white md:text-4xl">Available Products</h1>
          <p class="max-w-3xl text-green-100">
            Browse our comprehensive collection of genuine allopathic medicines and surgical supplies. 
            All products are sourced from certified manufacturers and stored under proper conditions.
          </p>
        </div>
        <div class="p-4 border rounded-lg bg-white/10 backdrop-blur-sm border-white/20">
          <p class="mb-1 text-sm text-white">Need assistance?</p>
          <a href="tel:+911234567890" class="font-bold text-white hover:text-green-100">
            <i class="mr-2 fa-solid fa-phone"></i>Call Pharmacist
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container px-4 py-8 mx-auto sm:px-6 lg:px-8">
    
    <% const activeCategory = typeof selectedCategory !== 'undefined' ? selectedCategory : 'all'; %>
    <% const activeSearch = typeof searchQuery !== 'undefined' ? searchQuery : ''; %>
    <% const currentPageNumber = typeof currentPage !== 'undefined' ? currentPage : 1; %>
    <% const totalPageCount = typeof totalPages !== 'undefined' ? totalPages : 1; %>
    <% const totalProductCount = typeof totalProducts !== 'undefined' ? totalProducts : 0; %>
    <% const searchSuffix = activeSearch ? '&search=' + encodeURIComponent(activeSearch) : ''; %>
    <% const categoryLinks = {
      all: '/products?category=all' + searchSuffix,
      allopathic: '/products?category=allopathic' + searchSuffix,
      surgical: '/products?category=surgical' + searchSuffix,
      devices: '/products?category=devices' + searchSuffix,
    }; %>

    <!-- Search and Filter Bar -->
    <div class="p-4 mb-6 bg-white border border-gray-200 shadow-sm dark:bg-gray-800 rounded-xl dark:border-gray-700">
      <div class="flex flex-col items-center justify-between gap-4 lg:flex-row">
        <form id="product-search-form" method="GET" action="/products" class="w-full lg:max-w-xl">
          <input type="hidden" name="category" value="<%= activeCategory %>">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
              <i class="text-gray-400 fa-solid fa-search"></i>
            </div>
            <input
              name="search"
              type="text"
              id="product-search"
              value="<%= activeSearch %>"
              placeholder="Search medicines, surgical items, brands..."
              class="w-full py-3 pl-10 pr-12 border border-gray-300 rounded-lg dark:border-gray-700 bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            >
            <button type="submit" class="absolute text-green-600 transform -translate-y-1/2 right-2 top-1/2 dark:text-green-400 hover:text-green-800">
              <i class="fa-solid fa-arrow-right"></i>
            </button>
          </div>
        </form>

        <div class="flex flex-wrap justify-start gap-2 lg:justify-end">
          <a href="<%= categoryLinks.all %>" data-category-link data-category="all" class="px-4 py-2 text-sm font-medium rounded-lg <%= activeCategory === 'all' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' %>">All Products</a>
          <a href="<%= categoryLinks.allopathic %>" data-category-link data-category="allopathic" class="px-4 py-2 text-sm font-medium rounded-lg <%= activeCategory === 'allopathic' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' %>">Allopathic Medicines</a>
          <a href="<%= categoryLinks.surgical %>" data-category-link data-category="surgical" class="px-4 py-2 text-sm font-medium rounded-lg <%= activeCategory === 'surgical' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' %>">Surgical Items</a>
          <a href="<%= categoryLinks.devices %>" data-category-link data-category="devices" class="px-4 py-2 text-sm font-medium rounded-lg <%= activeCategory === 'devices' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' %>">Medical Devices</a>
        </div>
      </div>

      <div class="flex flex-col gap-2 mt-4 text-sm text-gray-600 md:flex-row md:items-center md:justify-between dark:text-gray-400">
        <p id="products-summary"><%= totalProductCount %> products found</p>
        <p id="products-page-indicator">Page <%= currentPageNumber %> of <%= totalPageCount %></p>
      </div>
    </div>

    <!-- Products Grid -->
    <div id="products-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      
      <% const displayProducts = typeof products !== "undefined" ? products : [
        // Allopathic Medicines
        {
          id: 1,
          name: 'Paracetamol 500mg',
          type: 'medicine',
          category: 'Pain & Fever',
          manufacturer: 'Cipla Ltd',
          dosage: 'Tablet',
          pack: 'Strip of 10',
          description: 'For relief from fever, headaches, and mild to moderate pain.',
          price: '₹25',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-green-400 to-green-600'
        },
        {
          id: 2,
          name: 'Amoxicillin 500mg',
          type: 'medicine',
          category: 'Antibiotic',
          manufacturer: 'GSK Pharmaceuticals',
          dosage: 'Capsule',
          pack: 'Strip of 10',
          description: 'Broad-spectrum antibiotic for bacterial infections.',
          price: '₹120',
          availability: 'In Stock',
          requires_prescription: true,
          imageColor: 'from-purple-400 to-purple-600'
        },
        {
          id: 3,
          name: 'Cetirizine 10mg',
          type: 'medicine',
          category: 'Antihistamine',
          manufacturer: 'Sun Pharma',
          dosage: 'Tablet',
          pack: 'Strip of 10',
          description: 'For allergy relief, hay fever, and skin allergies.',
          price: '₹35',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-green-400 to-green-600'
        },
        {
          id: 4,
          name: 'Omeprazole 20mg',
          type: 'medicine',
          category: 'Acidity',
          manufacturer: 'Dr. Reddy\'s',
          dosage: 'Capsule',
          pack: 'Strip of 10',
          description: 'Proton pump inhibitor for acid reflux and ulcers.',
          price: '₹85',
          availability: 'Limited Stock',
          requires_prescription: false,
          imageColor: 'from-orange-400 to-orange-600'
        },
        
        // Surgical Items
        {
          id: 5,
          name: 'Surgical Gloves',
          type: 'surgical',
          category: 'Disposables',
          manufacturer: 'HLL Lifecare',
          size: 'Medium',
          pack: 'Box of 100',
          description: 'Sterile latex examination gloves, powder-free.',
          price: '₹450',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-teal-400 to-teal-600'
        },
        {
          id: 6,
          name: 'Surgical Mask',
          type: 'surgical',
          category: 'PPE',
          manufacturer: '3M',
          size: 'Standard',
          pack: 'Box of 50',
          description: '3-ply surgical mask with nose clip and ear loops.',
          price: '₹250',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-gray-400 to-gray-600'
        },
        {
          id: 7,
          name: 'Insulin Syringes',
          type: 'surgical',
          category: 'Injectables',
          manufacturer: 'BD Medical',
          size: '1ml',
          pack: 'Box of 100',
          description: 'Disposable insulin syringes with ultra-fine needles.',
          price: '₹180',
          availability: 'In Stock',
          requires_prescription: true,
          imageColor: 'from-pink-400 to-pink-600'
        },
        {
          id: 8,
          name: 'Surgical Gauze',
          type: 'surgical',
          category: 'Dressings',
          manufacturer: 'Johnson & Johnson',
          size: '10cm x 10cm',
          pack: 'Pack of 10',
          description: 'Sterile surgical gauze for wound dressing.',
          price: '₹120',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-yellow-400 to-yellow-600'
        },
        
        // Medical Devices
        {
          id: 9,
          name: 'Digital Thermometer',
          type: 'device',
          category: 'Monitoring',
          manufacturer: 'Dr. Morepen',
          features: 'Fever alert, memory function',
          pack: '1 Piece',
          description: 'Accurate digital thermometer with quick reading.',
          price: '₹299',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-red-400 to-red-600'
        },
        {
          id: 10,
          name: 'BP Monitor',
          type: 'device',
          category: 'Monitoring',
          manufacturer: 'Omron',
          features: 'Automatic, memory for 2 users',
          pack: '1 Piece',
          description: 'Automatic blood pressure monitor with cuff.',
          price: '₹1,299',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-indigo-400 to-indigo-600'
        },
        {
          id: 11,
          name: 'Nebulizer Machine',
          type: 'device',
          category: 'Respiratory',
          manufacturer: 'Rossmax',
          features: 'Portable, mask included',
          pack: '1 Piece',
          description: 'Compressor nebulizer for asthma and respiratory conditions.',
          price: '₹2,499',
          availability: 'Available on Order',
          requires_prescription: true,
          imageColor: 'from-cyan-400 to-cyan-600'
        },
        {
          id: 12,
          name: 'Oximeter',
          type: 'device',
          category: 'Monitoring',
          manufacturer: 'BeatLife',
          features: 'SpO2 & Pulse rate',
          pack: '1 Piece',
          description: 'Fingertip pulse oximeter with LED display.',
          price: '₹899',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-violet-400 to-violet-600'
        }
      ]; %>
      
      <% displayProducts.forEach(product => { %>
        <div class="overflow-hidden transition-all duration-300 bg-white border border-gray-200 shadow-sm product-card dark:bg-gray-800 rounded-xl hover:shadow-xl dark:border-gray-700 group" data-type="<%= product.type %>">
          
          <!-- Product Header -->
          <div class="relative">
            <!-- Image/Icon -->
            <div class="h-48 bg-gradient-to-r <%= product.imageColor %> flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 bg-black/10"></div>
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="<%= product.name %>" class="z-10 object-contain w-full h-full">
              <% } else { %>
                <img src="/images/logo.png" alt="placeholder" class="z-10 object-contain w-full h-full opacity-90">
              <% } %>
              
              <!-- Prescription Badge -->
              <% if(product.requires_prescription) { %>
                <div class="absolute z-20 top-3 left-3">
                  <span class="px-3 py-1 text-xs font-bold text-white bg-red-500 rounded-full">
                    <i class="mr-1 fa-solid fa-prescription"></i> Rx Required
                  </span>
                </div>
              <% } %>
              
              <!-- Availability Badge -->
              <div class="absolute z-20 top-3 right-3">
                <span class="<%= product.availability === 'In Stock' ? 'bg-green-500' : product.availability === 'Limited Stock' ? 'bg-yellow-500' : 'bg-green-500' %> text-white px-3 py-1 rounded-full text-xs font-bold">
                  <%= product.availability %>
                </span>
              </div>
            </div>
          </div>

          <!-- Product Details -->
          <div class="p-5">
            <!-- Category & Manufacturer -->
            <div class="flex items-start justify-between mb-2">
              <div>
                <span class="text-xs font-medium tracking-wider text-green-600 uppercase dark:text-green-400">
                  <%= product.displayCategory || product.category %>
                </span>
                <h3 class="mt-1 text-lg font-bold text-gray-900 dark:text-white">
                  <%= product.name %>
                </h3>
              </div>
              <span class="text-2xl font-bold text-gray-900 dark:text-white">
                <%= typeof product.price === "number" ? "₹" + product.price.toLocaleString("en-IN") : product.price %>
              </span>
            </div>

            <!-- Manufacturer -->
            <p class="mb-2 text-sm text-gray-600 dark:text-gray-400">
              <i class="mr-1 fa-solid fa-industry"></i>
              <%= product.manufacturer %>
            </p>

            <!-- Specifications -->
            <div class="mb-3">
              <% if(product.type === 'medicine') { %>
                <div class="flex items-center mb-1 text-sm text-gray-600 dark:text-gray-400">
                  <i class="w-4 mr-2 fa-solid fa-capsules"></i>
                  <span><%= product.dosage %> • <%= product.pack %></span>
                </div>
              <% } else if(product.type === 'surgical') { %>
                <div class="flex items-center mb-1 text-sm text-gray-600 dark:text-gray-400">
                  <i class="w-4 mr-2 fa-solid fa-ruler-combined"></i>
                  <span><%= product.size %> • <%= product.pack %></span>
                </div>
              <% } else { %>
                <div class="flex items-center mb-1 text-sm text-gray-600 dark:text-gray-400">
                  <i class="w-4 mr-2 fa-solid fa-list-check"></i>
                  <span><%= product.features %></span>
                </div>
              <% } %>
            </div>

            <!-- Description -->
            <p class="mb-4 text-sm text-gray-700 dark:text-gray-300 line-clamp-2">
              <%= product.description %>
            </p>

            <!-- Action Buttons -->
            <div class="flex gap-2">
              <a href="/products/<%= encodeURIComponent(product.slug || product._id || product.id) %>" 
                 class="flex items-center justify-center flex-1 px-4 py-2 text-sm font-medium text-center text-white transition-all duration-300 bg-green-600 rounded-lg hover:bg-green-700 group-hover:scale-105">
                <i class="mr-2 fa-solid fa-eye"></i>
                View Details
              </a>
              <button type="button" aria-label="Leave a comment for <%= product.name %>" class="flex items-center justify-center w-12 px-4 py-2 text-lg font-bold text-green-600 transition-all duration-300 border border-green-500 rounded-lg inquiry-btn shrink-0 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20" data-product="<%= product.name %>">
                ?
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <% if (totalPageCount > 1) { %>
    <div id="products-pagination" class="flex flex-wrap items-center justify-center gap-2 mt-10">
      <% const startPage = Math.max(1, currentPageNumber - 2); %>
      <% const endPage = Math.min(totalPageCount, currentPageNumber + 2); %>
      <% if (currentPageNumber > 1) { %>
        <a href="/products?page=<%= currentPageNumber - 1 %>&category=<%= activeCategory %><%= activeSearch ? '&search=' + encodeURIComponent(activeSearch) : '' %>" data-page-link data-page="<%= currentPageNumber - 1 %>" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">Previous</a>
      <% } %>
      <% for (let pageNumber = startPage; pageNumber <= endPage; pageNumber++) { %>
        <a href="/products?page=<%= pageNumber %>&category=<%= activeCategory %><%= activeSearch ? '&search=' + encodeURIComponent(activeSearch) : '' %>" data-page-link data-page="<%= pageNumber %>" class="px-4 py-2 text-sm font-medium rounded-lg <%= pageNumber === currentPageNumber ? 'bg-green-600 text-white' : 'bg-white border border-gray-300 dark:bg-gray-800 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700' %>"><%= pageNumber %></a>
      <% } %>
      <% if (currentPageNumber < totalPageCount) { %>
        <a href="/products?page=<%= currentPageNumber + 1 %>&category=<%= activeCategory %><%= activeSearch ? '&search=' + encodeURIComponent(activeSearch) : '' %>" data-page-link data-page="<%= currentPageNumber + 1 %>" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">Next</a>
      <% } %>
    </div>
    <% } %>

    <% if (displayProducts.length === 0) { %>
    <div id="no-products" class="py-12 text-center">
      <div class="flex items-center justify-center w-24 h-24 mx-auto mb-6 bg-gray-200 rounded-full dark:bg-gray-700">
        <i class="text-3xl text-gray-400 fa-solid fa-search"></i>
      </div>
      <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">No products found</h3>
      <p class="text-gray-600 dark:text-gray-400">Try adjusting your search or filter criteria</p>
      <a href="/products" class="inline-flex px-6 py-2 mt-4 text-white transition-all duration-300 bg-green-600 rounded-lg hover:bg-green-700">
        Reset Filters
      </a>
    </div>
    <% } %>

    <!-- Information Banner -->
    <div class="p-6 mt-12 border border-green-100 bg-gradient-to-r from-green-50 to-teal-50 dark:from-gray-800 dark:to-gray-700 rounded-xl dark:border-gray-600">
      <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
        <div class="flex items-center space-x-4">
          <div class="flex items-center justify-center w-12 h-12 bg-green-100 rounded-full dark:bg-green-900/30">
            <i class="text-green-600 fa-solid fa-triangle-exclamation dark:text-green-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 dark:text-white">Important Information</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Prescription drugs (marked with Rx) require valid doctor's prescription. 
              Consult our pharmacists for proper usage guidelines.
            </p>
          </div>
        </div>
        <a href="/contact" class="px-6 py-2 font-medium text-green-600 transition-all duration-300 bg-white border border-green-200 rounded-lg dark:bg-gray-700 dark:text-green-400 dark:border-gray-600 hover:bg-green-50 dark:hover:bg-gray-600 whitespace-nowrap">
          <i class="mr-2 fa-solid fa-user-doctor"></i>
          Consult Pharmacist
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Products Page JavaScript -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const apiEndpoint = '/products';
    const searchForm = document.getElementById('product-search-form');
    const searchInput = document.getElementById('product-search');
    const productsGrid = document.getElementById('products-grid');
    const summaryEl = document.getElementById('products-summary');
    const pageIndicatorEl = document.getElementById('products-page-indicator');
    const initialGridClass = productsGrid ? productsGrid.className : '';
    const categoryLinks = document.querySelectorAll('[data-category-link]');
    const filterLinks = document.querySelectorAll('[data-category-link]');

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function escapeAttr(value) {
      return escapeHtml(value).replace(/`/g, '&#96;');
    }

    function formatPrice(product) {
      if (typeof product.price === 'number') {
        return `₹${new Intl.NumberFormat('en-IN').format(product.price)}`;
      }

      if (product.priceText) {
        return escapeHtml(product.priceText);
      }

      return escapeHtml(product.price || 'Contact for price');
    }

    function renderNoProducts() {
      return `
        <div class="py-12 text-center">
          <div class="flex items-center justify-center w-24 h-24 mx-auto mb-6 bg-gray-200 rounded-full dark:bg-gray-700">
            <i class="text-3xl text-gray-400 fa-solid fa-search"></i>
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">No products found</h3>
          <p class="text-gray-600 dark:text-gray-400">Try adjusting your search or filter criteria</p>
          <a href="/products" class="inline-flex px-6 py-2 mt-4 text-white transition-all duration-300 bg-green-600 rounded-lg hover:bg-green-700">Reset Filters</a>
        </div>
      `;
    }

    function renderProductCard(product) {
      const type = product.type || 'medicine';
      const iconClass = type === 'surgical' ? 'fa-syringe' : type === 'device' ? 'fa-stethoscope' : 'fa-pills';
      const categoryLabel = escapeHtml(product.displayCategory || product.category || 'Product');
      const name = escapeHtml(product.name || 'Unnamed Product');
      const manufacturer = escapeHtml(product.manufacturer || '');
      const description = escapeHtml(product.description || '');
      const availability = escapeHtml(product.availability || 'In Stock');
      const availabilityClass = availability === 'In Stock' ? 'bg-green-500' : availability === 'Limited Stock' ? 'bg-yellow-500' : 'bg-green-500';
      const requiresPrescription = Boolean(product.requires_prescription);
      const detailTarget = encodeURIComponent(product.slug || product.id || name.toLowerCase().replace(/\s+/g, '-'));
      const detailUrl = `/products/${detailTarget}`;
      const specText = type === 'medicine'
        ? escapeHtml(`${product.dosage || ''}${product.dosage && product.pack ? ' • ' : ''}${product.pack || ''}`)
        : type === 'surgical'
          ? escapeHtml(`${product.size || ''}${product.size && product.pack ? ' • ' : ''}${product.pack || ''}`)
          : escapeHtml(product.features || product.pack || '');

      return `
        <div class="overflow-hidden transition-all duration-300 bg-white border border-gray-200 shadow-sm product-card dark:bg-gray-800 rounded-xl hover:shadow-xl dark:border-gray-700 group" data-type="${escapeAttr(type)}">
          <div class="relative">
            <div class="flex items-center justify-center h-48 overflow-hidden relative bg-gradient-to-r ${escapeAttr(product.imageColor || 'from-green-500 to-teal-500')}">
              <div class="absolute inset-0 bg-black/10"></div>
              ${product.image ? `
                <img src="${escapeAttr(product.image)}" alt="${escapeAttr(product.name || '')}" class="z-10 object-contain w-full h-full" />
              ` : `
                <img src="/images/logo.png" alt="placeholder" class="z-10 object-contain w-full h-full opacity-90" />
              `}
              ${requiresPrescription ? `
                <div class="absolute z-20 top-3 left-3">
                  <span class="px-3 py-1 text-xs font-bold text-white bg-red-500 rounded-full"><i class="mr-1 fa-solid fa-prescription"></i> Rx Required</span>
                </div>
              ` : ''}
              <div class="absolute z-20 top-3 right-3">
                <span class="${availabilityClass} text-white px-3 py-1 rounded-full text-xs font-bold">${availability}</span>
              </div>
            </div>
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between mb-2">
              <div>
                <span class="text-xs font-medium tracking-wider text-green-600 uppercase dark:text-green-400">${categoryLabel}</span>
                <h3 class="mt-1 text-lg font-bold text-gray-900 dark:text-white">${name}</h3>
              </div>
              <span class="text-2xl font-bold text-gray-900 dark:text-white">${formatPrice(product)}</span>
            </div>
            <p class="mb-2 text-sm text-gray-600 dark:text-gray-400"><i class="mr-1 fa-solid fa-industry"></i>${manufacturer}</p>
            <div class="mb-3">
              <div class="flex items-center mb-1 text-sm text-gray-600 dark:text-gray-400">
                <i class="w-4 mr-2 fa-solid ${type === 'medicine' ? 'fa-capsules' : type === 'surgical' ? 'fa-ruler-combined' : 'fa-list-check'}"></i>
                <span>${specText}</span>
              </div>
            </div>
            <p class="mb-4 text-sm text-gray-700 dark:text-gray-300 line-clamp-2">${description}</p>
            <div class="flex gap-2">
              <a href="${detailUrl}" class="flex items-center justify-center flex-1 px-4 py-2 text-sm font-medium text-center text-white transition-all duration-300 bg-green-600 rounded-lg hover:bg-green-700 group-hover:scale-105"><i class="mr-2 fa-solid fa-eye"></i>View Details</a>
              <button type="button" aria-label="Leave a comment for ${name}" class="flex items-center justify-center w-12 px-4 py-2 text-lg font-bold text-green-600 transition-all duration-300 border border-green-500 rounded-lg inquiry-btn shrink-0 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20" data-product="${escapeAttr(product.name || '')}">?</button>
            </div>
          </div>
        </div>
      `;
    }

    function renderPagination(currentPage, totalPages, category, search) {
      if (!totalPages || totalPages <= 1) {
        return '';
      }

      const safeCategory = category || 'all';
      const searchPart = search ? `&search=${encodeURIComponent(search)}` : '';
      const startPage = Math.max(1, currentPage - 2);
      const endPage = Math.min(totalPages, currentPage + 2);
      const pages = [];

      if (currentPage > 1) {
        pages.push(`<a href="/products?page=${currentPage - 1}&category=${encodeURIComponent(safeCategory)}${searchPart}" data-page-link data-page="${currentPage - 1}" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">Previous</a>`);
      }

      for (let pageNumber = startPage; pageNumber <= endPage; pageNumber += 1) {
        pages.push(`<a href="/products?page=${pageNumber}&category=${encodeURIComponent(safeCategory)}${searchPart}" data-page-link data-page="${pageNumber}" class="px-4 py-2 text-sm font-medium rounded-lg ${pageNumber === currentPage ? 'bg-green-600 text-white' : 'bg-white border border-gray-300 dark:bg-gray-800 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700'}">${pageNumber}</a>`);
      }

      if (currentPage < totalPages) {
        pages.push(`<a href="/products?page=${currentPage + 1}&category=${encodeURIComponent(safeCategory)}${searchPart}" data-page-link data-page="${currentPage + 1}" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">Next</a>`);
      }

      return `<div class="flex flex-wrap items-center justify-center gap-2 mt-10">${pages.join('')}</div>`;
    }

    function ensurePaginationContainer() {
      let pagination = document.getElementById('products-pagination');
      if (!pagination) {
        pagination = document.createElement('div');
        pagination.id = 'products-pagination';
        productsGrid.insertAdjacentElement('afterend', pagination);
      }

      return pagination;
    }

    function updateCategoryLinks(activeCategory) {
      filterLinks.forEach(link => {
        const linkCategory = link.dataset.category || 'all';
        const isActive = linkCategory === activeCategory;
        link.classList.toggle('bg-green-600', isActive);
        link.classList.toggle('text-white', isActive);
        link.classList.toggle('bg-gray-100', !isActive);
        link.classList.toggle('dark:bg-gray-700', !isActive);
        link.classList.toggle('text-gray-700', !isActive);
        link.classList.toggle('dark:text-gray-300', !isActive);
      });
    }

    function updateLocation(targetUrl) {
      window.history.pushState({}, '', targetUrl.pathname + targetUrl.search);
    }

    function updateViewFromResponse(data) {
      const products = Array.isArray(data.products) ? data.products : [];
      const pagination = ensurePaginationContainer();

      if (products.length > 0) {
        productsGrid.className = initialGridClass;
        productsGrid.innerHTML = products.map(renderProductCard).join('');
      } else {
        productsGrid.className = 'py-12 text-center';
        productsGrid.innerHTML = renderNoProducts();
      }

      pagination.innerHTML = renderPagination(data.currentPage || 1, data.totalPages || 1, data.category || 'all', data.search || '');
      pagination.classList.toggle('hidden', !data.totalPages || data.totalPages <= 1);

      if (summaryEl) {
        summaryEl.textContent = `${data.totalProducts || 0} products found`;
      }

      if (pageIndicatorEl) {
        pageIndicatorEl.textContent = `Page ${data.currentPage || 1} of ${data.totalPages || 1}`;
      }

      updateCategoryLinks(data.category || 'all');
    }

    async function loadProducts(targetUrl, shouldPushState = true) {
      const apiUrl = new URL(apiEndpoint, window.location.origin);
      const params = targetUrl.searchParams;
      apiUrl.searchParams.set('format', 'json');
      ['category', 'search', 'page', 'limit'].forEach(key => {
        const value = params.get(key);
        if (value) {
          apiUrl.searchParams.set(key, value);
        }
      });

      const response = await fetch(apiUrl.toString(), {
        headers: {
          Accept: 'application/json',
        },
      });

      if (!response.ok) {
        const payload = await response.json().catch(() => ({}));
        throw new Error(payload.message || 'Unable to load products.');
      }

      const data = await response.json();
      updateViewFromResponse(data);

      if (shouldPushState) {
        updateLocation(targetUrl);
      }
    }

    function buildTargetUrl(sourceUrl, overrides = {}) {
      const targetUrl = new URL(sourceUrl, window.location.origin);
      Object.entries(overrides).forEach(([key, value]) => {
        if (value === null || value === undefined || value === '') {
          targetUrl.searchParams.delete(key);
        } else {
          targetUrl.searchParams.set(key, value);
        }
      });

      return targetUrl;
    }

    document.addEventListener('click', async function(event) {
      const inquiryButton = event.target.closest('.inquiry-btn');
      if (inquiryButton) {
        showCommentModal(inquiryButton.dataset.product || 'this product');
        return;
      }

      const categoryLink = event.target.closest('[data-category-link]');
      if (categoryLink) {
        event.preventDefault();
        const targetUrl = new URL(categoryLink.href, window.location.origin);
        targetUrl.searchParams.delete('page');

        try {
          await loadProducts(targetUrl);
        } catch (error) {
          showNotification(error.message, 'error');
        }
        return;
      }

      const pageLink = event.target.closest('[data-page-link]');
      if (pageLink) {
        event.preventDefault();
        const targetUrl = new URL(pageLink.href, window.location.origin);

        try {
          await loadProducts(targetUrl);
        } catch (error) {
          showNotification(error.message, 'error');
        }
      }
    });

    if (searchForm) {
      searchForm.addEventListener('submit', async function(event) {
        event.preventDefault();

        const formData = new FormData(searchForm);
        const targetUrl = buildTargetUrl(searchForm.action, {
          category: formData.get('category') || 'all',
          search: formData.get('search') || '',
          page: '1',
        });

        try {
          await loadProducts(targetUrl);
        } catch (error) {
          showNotification(error.message, 'error');
        }
      });
    }

    window.addEventListener('popstate', async function() {
      try {
        await loadProducts(window.location.href, false);
      } catch (error) {
        showNotification(error.message, 'error');
      }
    });

    function showCommentModal(productName) {
      const existingModal = document.getElementById('comment-modal');
      if (existingModal) {
        existingModal.remove();
      }

      const modal = document.createElement('div');
      modal.id = 'comment-modal';
      modal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4';
      modal.innerHTML = `
        <div class="w-full max-w-md p-6 bg-white dark:bg-gray-800 rounded-xl animate-slide-up">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">Comment on ${escapeHtml(productName)}</h3>
            <button type="button" class="text-gray-400 close-modal hover:text-gray-600 dark:hover:text-gray-300">
              <i class="text-xl fa-solid fa-xmark"></i>
            </button>
          </div>

          <form id="comment-form" class="space-y-4">
            <div>
              <label class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">Your Comment</label>
              <textarea rows="3" required class="w-full px-4 py-3 border border-gray-300 rounded-lg dark:border-gray-700 bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="Write your comment about ${escapeAttr(productName)}..."></textarea>
            </div>

            <div class="flex gap-3 pt-4">
              <button type="submit" class="flex-1 px-4 py-2 font-medium text-white transition-all duration-300 bg-green-600 rounded-lg hover:bg-green-700">
                Submit Comment
              </button>
            </div>
          </form>
        </div>
      `;

      document.body.appendChild(modal);

      modal.querySelectorAll('.close-modal').forEach(btn => {
        btn.addEventListener('click', () => modal.remove());
      });

      const form = modal.querySelector('#comment-form');
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        showNotification('Comment submitted successfully!', 'success');
        modal.remove();
        this.reset();
      });

      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.remove();
        }
      });
    }

    function showNotification(message, type = 'info') {
      const notification = document.createElement('div');
      notification.className = `fixed top-4 right-4 px-6 py-3 rounded-lg shadow-lg z-50 transform transition-all duration-300 animate-fade-in ${type === 'success' ? 'bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-300' : 'bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300'}`;
      notification.innerHTML = `
        <div class="flex items-center space-x-2">
          <i class="fa-solid ${type === 'success' ? 'fa-circle-check' : 'fa-circle-exclamation'}"></i>
          <span class="font-medium">${escapeHtml(message)}</span>
        </div>
      `;

      document.body.appendChild(notification);

      setTimeout(() => {
        notification.style.opacity = '0';
        notification.style.transform = 'translateY(-20px)';
        setTimeout(() => {
          if (notification.parentNode) {
            document.body.removeChild(notification);
          }
        }, 300);
      }, 3000);
    }

    updateCategoryLinks('<%= activeCategory %>');
  });
</script>

<style>
  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }

  .animate-slide-up {
    animation: slideUp 0.3s ease-out forwards;
  }

  /* Product card hover effects */
  .product-card {
    animation: fadeIn 0.5s ease-out;
    animation-fill-mode: both;
  }

  .product-card:hover {
    transform: translateY(-5px);
  }

  /* Line clamp for description */
  .line-clamp-2 {
    display: -webkit-box;
    line-clamp: 2;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Custom scrollbar for modal */
  .modal-content {
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-content::-webkit-scrollbar {
    width: 6px;
  }

  .modal-content::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 3px;
  }

  .modal-content::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 3px;
  }

  .modal-content::-webkit-scrollbar-thumb:hover {
    background: #555;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .product-card {
      animation-delay: 0s !important;
    }
    
    .filter-btn {
      font-size: 0.75rem;
      padding: 0.5rem 0.75rem;
    }
  }

  /* Loading skeleton (optional) */
  .skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite;
  }

  .dark .skeleton {
    background: linear-gradient(90deg, #374151 25%, #4b5563 50%, #374151 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite;
  }

  @keyframes loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
</style>
