<% layout("/layouts/boilerplate") %>

<!-- Products Page -->
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  
  <!-- Page Header -->
  <div class="bg-gradient-to-r from-green-600 to-teal-500">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">Available Products</h1>
          <p class="text-green-100 max-w-3xl">
            Browse our comprehensive collection of genuine allopathic medicines and surgical supplies. 
            All products are sourced from certified manufacturers and stored under proper conditions.
          </p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-lg p-4 border border-white/20">
          <p class="text-white text-sm mb-1">Need assistance?</p>
          <a href="tel:+911234567890" class="text-white font-bold hover:text-green-100">
            <i class="fa-solid fa-phone mr-2"></i>Call Pharmacist
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Search and Filter Bar -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 mb-6 border border-gray-200 dark:border-gray-700">
      <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
        
        <!-- Search Bar -->
        <div class="w-full md:w-auto flex-1">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fa-solid fa-search text-gray-400"></i>
            </div>
            <input 
              type="text" 
              id="product-search"
              placeholder="Search medicines, surgical items, brands..."
              class="w-full pl-10 pr-4 py-3 border border-gray-300 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            >
            <button id="search-btn" class="absolute right-2 top-1/2 transform -translate-y-1/2 text-green-600 dark:text-green-400 hover:text-green-800">
              <i class="fa-solid fa-arrow-right"></i>
            </button>
          </div>
        </div>

        <!-- Filter Buttons -->
        <div class="flex flex-wrap gap-2">
          <button class="filter-btn active px-4 py-2 bg-green-600 text-white rounded-lg text-sm font-medium" data-filter="all">
            All Products
          </button>
          <button class="filter-btn px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-600" data-filter="medicine">
            Allopathic Medicines
          </button>
          <button class="filter-btn px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-600" data-filter="surgical">
            Surgical Items
          </button>
          <button class="filter-btn px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-600" data-filter="device">
            Medical Devices
          </button>
        </div>
      </div>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      
      <% const products = [
        // Allopathic Medicines
        {
          id: 1,
          name: 'Paracetamol 500mg',
          type: 'medicine',
          category: 'Pain & Fever',
          manufacturer: 'Cipla Ltd',
          dosage: 'Tablet',
          pack: 'Strip of 10',
          description: 'For relief from fever, headaches, and mild to moderate pain.',
          price: '₹25',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-green-400 to-green-600'
        },
        {
          id: 2,
          name: 'Amoxicillin 500mg',
          type: 'medicine',
          category: 'Antibiotic',
          manufacturer: 'GSK Pharmaceuticals',
          dosage: 'Capsule',
          pack: 'Strip of 10',
          description: 'Broad-spectrum antibiotic for bacterial infections.',
          price: '₹120',
          availability: 'In Stock',
          requires_prescription: true,
          imageColor: 'from-purple-400 to-purple-600'
        },
        {
          id: 3,
          name: 'Cetirizine 10mg',
          type: 'medicine',
          category: 'Antihistamine',
          manufacturer: 'Sun Pharma',
          dosage: 'Tablet',
          pack: 'Strip of 10',
          description: 'For allergy relief, hay fever, and skin allergies.',
          price: '₹35',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-green-400 to-green-600'
        },
        {
          id: 4,
          name: 'Omeprazole 20mg',
          type: 'medicine',
          category: 'Acidity',
          manufacturer: 'Dr. Reddy\'s',
          dosage: 'Capsule',
          pack: 'Strip of 10',
          description: 'Proton pump inhibitor for acid reflux and ulcers.',
          price: '₹85',
          availability: 'Limited Stock',
          requires_prescription: false,
          imageColor: 'from-orange-400 to-orange-600'
        },
        
        // Surgical Items
        {
          id: 5,
          name: 'Surgical Gloves',
          type: 'surgical',
          category: 'Disposables',
          manufacturer: 'HLL Lifecare',
          size: 'Medium',
          pack: 'Box of 100',
          description: 'Sterile latex examination gloves, powder-free.',
          price: '₹450',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-teal-400 to-teal-600'
        },
        {
          id: 6,
          name: 'Surgical Mask',
          type: 'surgical',
          category: 'PPE',
          manufacturer: '3M',
          size: 'Standard',
          pack: 'Box of 50',
          description: '3-ply surgical mask with nose clip and ear loops.',
          price: '₹250',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-gray-400 to-gray-600'
        },
        {
          id: 7,
          name: 'Insulin Syringes',
          type: 'surgical',
          category: 'Injectables',
          manufacturer: 'BD Medical',
          size: '1ml',
          pack: 'Box of 100',
          description: 'Disposable insulin syringes with ultra-fine needles.',
          price: '₹180',
          availability: 'In Stock',
          requires_prescription: true,
          imageColor: 'from-pink-400 to-pink-600'
        },
        {
          id: 8,
          name: 'Surgical Gauze',
          type: 'surgical',
          category: 'Dressings',
          manufacturer: 'Johnson & Johnson',
          size: '10cm x 10cm',
          pack: 'Pack of 10',
          description: 'Sterile surgical gauze for wound dressing.',
          price: '₹120',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-yellow-400 to-yellow-600'
        },
        
        // Medical Devices
        {
          id: 9,
          name: 'Digital Thermometer',
          type: 'device',
          category: 'Monitoring',
          manufacturer: 'Dr. Morepen',
          features: 'Fever alert, memory function',
          pack: '1 Piece',
          description: 'Accurate digital thermometer with quick reading.',
          price: '₹299',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-red-400 to-red-600'
        },
        {
          id: 10,
          name: 'BP Monitor',
          type: 'device',
          category: 'Monitoring',
          manufacturer: 'Omron',
          features: 'Automatic, memory for 2 users',
          pack: '1 Piece',
          description: 'Automatic blood pressure monitor with cuff.',
          price: '₹1,299',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-indigo-400 to-indigo-600'
        },
        {
          id: 11,
          name: 'Nebulizer Machine',
          type: 'device',
          category: 'Respiratory',
          manufacturer: 'Rossmax',
          features: 'Portable, mask included',
          pack: '1 Piece',
          description: 'Compressor nebulizer for asthma and respiratory conditions.',
          price: '₹2,499',
          availability: 'Available on Order',
          requires_prescription: true,
          imageColor: 'from-cyan-400 to-cyan-600'
        },
        {
          id: 12,
          name: 'Oximeter',
          type: 'device',
          category: 'Monitoring',
          manufacturer: 'BeatLife',
          features: 'SpO2 & Pulse rate',
          pack: '1 Piece',
          description: 'Fingertip pulse oximeter with LED display.',
          price: '₹899',
          availability: 'In Stock',
          requires_prescription: false,
          imageColor: 'from-violet-400 to-violet-600'
        }
      ] %>
      
      <% products.forEach(product => { %>
        <div class="product-card bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700 group" data-type="<%= product.type %>">
          
          <!-- Product Header -->
          <div class="relative">
            <!-- Image/Icon -->
            <div class="h-48 bg-gradient-to-r <%= product.imageColor %> flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 bg-black/10"></div>
              <% if(product.type === 'medicine') { %>
                <i class="fa-solid fa-pills text-white text-6xl z-10"></i>
              <% } else if(product.type === 'surgical') { %>
                <i class="fa-solid fa-syringe text-white text-6xl z-10"></i>
              <% } else { %>
                <i class="fa-solid fa-stethoscope text-white text-6xl z-10"></i>
              <% } %>
              
              <!-- Prescription Badge -->
              <% if(product.requires_prescription) { %>
                <div class="absolute top-3 left-3 z-20">
                  <span class="bg-red-500 text-white px-3 py-1 rounded-full text-xs font-bold">
                    <i class="fa-solid fa-prescription mr-1"></i> Rx Required
                  </span>
                </div>
              <% } %>
              
              <!-- Availability Badge -->
              <div class="absolute top-3 right-3 z-20">
                <span class="<%= product.availability === 'In Stock' ? 'bg-green-500' : product.availability === 'Limited Stock' ? 'bg-yellow-500' : 'bg-green-500' %> text-white px-3 py-1 rounded-full text-xs font-bold">
                  <%= product.availability %>
                </span>
              </div>
            </div>
          </div>

          <!-- Product Details -->
          <div class="p-5">
            <!-- Category & Manufacturer -->
            <div class="flex justify-between items-start mb-2">
              <div>
                <span class="text-xs font-medium text-green-600 dark:text-green-400 uppercase tracking-wider">
                  <%= product.category %>
                </span>
                <h3 class="font-bold text-gray-900 dark:text-white text-lg mt-1">
                  <%= product.name %>
                </h3>
              </div>
              <span class="text-2xl font-bold text-gray-900 dark:text-white">
                <%= product.price %>
              </span>
            </div>

            <!-- Manufacturer -->
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
              <i class="fa-solid fa-industry mr-1"></i>
              <%= product.manufacturer %>
            </p>

            <!-- Specifications -->
            <div class="mb-3">
              <% if(product.type === 'medicine') { %>
                <div class="flex items-center text-sm text-gray-600 dark:text-gray-400 mb-1">
                  <i class="fa-solid fa-capsules mr-2 w-4"></i>
                  <span><%= product.dosage %> • <%= product.pack %></span>
                </div>
              <% } else if(product.type === 'surgical') { %>
                <div class="flex items-center text-sm text-gray-600 dark:text-gray-400 mb-1">
                  <i class="fa-solid fa-ruler-combined mr-2 w-4"></i>
                  <span><%= product.size %> • <%= product.pack %></span>
                </div>
              <% } else { %>
                <div class="flex items-center text-sm text-gray-600 dark:text-gray-400 mb-1">
                  <i class="fa-solid fa-list-check mr-2 w-4"></i>
                  <span><%= product.features %></span>
                </div>
              <% } %>
            </div>

            <!-- Description -->
            <p class="text-gray-700 dark:text-gray-300 text-sm mb-4 line-clamp-2">
              <%= product.description %>
            </p>

            <!-- Action Buttons -->
            <div class="flex gap-2">
              <a href="/products/<%= product.id %>" 
                 class="flex-1 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-all duration-300 font-medium text-center text-sm flex items-center justify-center group-hover:scale-105">
                <i class="fa-solid fa-eye mr-2"></i>
                View Details
              </a>
              <button class="inquiry-btn px-4 py-2 border border-green-500 text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg transition-all duration-300" data-product="<%= product.name %>">
                <i class="fa-solid fa-question"></i>
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- No Products Message (Hidden by default) -->
    <div id="no-products" class="hidden text-center py-12">
      <div class="w-24 h-24 bg-gray-200 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-6">
        <i class="fa-solid fa-search text-gray-400 text-3xl"></i>
      </div>
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">No products found</h3>
      <p class="text-gray-600 dark:text-gray-400">Try adjusting your search or filter criteria</p>
      <button id="reset-filters" class="mt-4 px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-all duration-300">
        Reset Filters
      </button>
    </div>

    <!-- Information Banner -->
    <div class="mt-12 bg-gradient-to-r from-green-50 to-teal-50 dark:from-gray-800 dark:to-gray-700 rounded-xl p-6 border border-green-100 dark:border-gray-600">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
            <i class="fa-solid fa-triangle-exclamation text-green-600 dark:text-green-400"></i>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 dark:text-white">Important Information</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              Prescription drugs (marked with Rx) require valid doctor's prescription. 
              Consult our pharmacists for proper usage guidelines.
            </p>
          </div>
        </div>
        <a href="/contact" class="px-6 py-2 bg-white dark:bg-gray-700 text-green-600 dark:text-green-400 rounded-lg border border-green-200 dark:border-gray-600 hover:bg-green-50 dark:hover:bg-gray-600 transition-all duration-300 font-medium whitespace-nowrap">
          <i class="fa-solid fa-user-doctor mr-2"></i>
          Consult Pharmacist
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Products Page JavaScript -->
<script>
  // Filter functionality
  const filterButtons = document.querySelectorAll('.filter-btn');
  const productCards = document.querySelectorAll('.product-card');
  const searchInput = document.getElementById('product-search');
  const searchBtn = document.getElementById('search-btn');
  const noProductsMsg = document.getElementById('no-products');
  const resetFiltersBtn = document.getElementById('reset-filters');

  // Active filter state
  let activeFilter = 'all';
  let searchQuery = '';

  // Filter button click handler
  filterButtons.forEach(button => {
    button.addEventListener('click', function() {
      // Update active button
      filterButtons.forEach(btn => {
        btn.classList.remove('active', 'bg-green-600', 'text-white');
        btn.classList.add('bg-gray-100', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
      });
      
      this.classList.remove('bg-gray-100', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
      this.classList.add('active', 'bg-green-600', 'text-white');
      
      // Update active filter
      activeFilter = this.dataset.filter;
      
      // Apply filters
      applyFilters();
    });
  });

  // Search functionality
  searchInput.addEventListener('input', function() {
    searchQuery = this.value.toLowerCase().trim();
    applyFilters();
  });

  searchBtn.addEventListener('click', function() {
    searchQuery = searchInput.value.toLowerCase().trim();
    applyFilters();
  });

  searchInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      searchQuery = this.value.toLowerCase().trim();
      applyFilters();
    }
  });

  // Reset filters
  resetFiltersBtn?.addEventListener('click', function() {
    // Reset UI
    filterButtons.forEach(btn => {
      btn.classList.remove('active', 'bg-green-600', 'text-white');
      btn.classList.add('bg-gray-100', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
    });
    
    // Set "All Products" as active
    document.querySelector('.filter-btn[data-filter="all"]').classList.add('active', 'bg-green-600', 'text-white');
    
    // Reset values
    activeFilter = 'all';
    searchInput.value = '';
    searchQuery = '';
    
    // Apply filters
    applyFilters();
  });

  // Inquiry button functionality
  document.querySelectorAll('.inquiry-btn').forEach(button => {
    button.addEventListener('click', function() {
      const productName = this.dataset.product;
      showInquiryModal(productName);
    });
  });

  // Apply filters function
  function applyFilters() {
    let visibleCount = 0;
    
    productCards.forEach(card => {
      const productType = card.dataset.type;
      const productName = card.querySelector('h3').textContent.toLowerCase();
      const productDesc = card.querySelector('p.text-gray-700').textContent.toLowerCase();
      const productCategory = card.querySelector('span.uppercase').textContent.toLowerCase();
      const productManufacturer = card.querySelector('p.text-sm').textContent.toLowerCase();
      
      // Check type filter
      const typeMatch = activeFilter === 'all' || productType === activeFilter;
      
      // Check search query
      const searchMatch = !searchQuery || 
        productName.includes(searchQuery) ||
        productDesc.includes(searchQuery) ||
        productCategory.includes(searchQuery) ||
        productManufacturer.includes(searchQuery);
      
      // Show/hide card
      if (typeMatch && searchMatch) {
        card.style.display = 'block';
        visibleCount++;
        
        // Add animation
        card.style.animation = 'none';
        setTimeout(() => {
          card.style.animation = 'fadeIn 0.5s ease-out';
        }, 10);
      } else {
        card.style.display = 'none';
      }
    });
    
    // Show/hide no products message
    if (visibleCount === 0) {
      noProductsMsg.classList.remove('hidden');
      noProductsMsg.style.animation = 'none';
      setTimeout(() => {
        noProductsMsg.style.animation = 'fadeIn 0.5s ease-out';
      }, 10);
    } else {
      noProductsMsg.classList.add('hidden');
    }
  }

  // Show inquiry modal
  function showInquiryModal(productName) {
    // Create modal
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4';
    modal.innerHTML = `
      <div class="bg-white dark:bg-gray-800 rounded-xl max-w-md w-full p-6 animate-slide-up">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">Inquiry: ${productName}</h3>
          <button class="close-modal text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
            <i class="fa-solid fa-xmark text-xl"></i>
          </button>
        </div>
        
        <form id="inquiry-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Name</label>
            <input type="text" required 
                   class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent">
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Phone Number</label>
            <input type="tel" required 
                   class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                   placeholder="+91">
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Message</label>
            <textarea rows="3" 
                      class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
                      placeholder="Your question about ${productName}..."></textarea>
          </div>
          
          <div class="flex gap-3 pt-4">
            <button type="submit" 
                    class="flex-1 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-all duration-300 font-medium">
              Submit Inquiry
            </button>
            <button type="button" 
                    class="close-modal px-4 py-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-300">
              Cancel
            </button>
          </div>
        </form>
        
        <div class="mt-4 text-center">
          <p class="text-sm text-gray-500 dark:text-gray-400">
            <i class="fa-solid fa-phone mr-1"></i>
            Or call us directly: <a href="tel:+911234567890" class="text-green-600 dark:text-green-400 hover:underline">+91 12345 67890</a>
          </p>
        </div>
      </div>
    `;
    
    document.body.appendChild(modal);
    
    // Close modal handlers
    const closeButtons = modal.querySelectorAll('.close-modal');
    closeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        modal.remove();
      });
    });
    
    // Form submission
    const form = modal.querySelector('#inquiry-form');
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Show success message
      showNotification('Inquiry submitted successfully! Our pharmacist will contact you shortly.', 'success');
      
      // Close modal
      modal.remove();
      
      // Reset form (optional)
      this.reset();
    });
    
    // Close on backdrop click
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.remove();
      }
    });
  }

  // Notification function
  function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `fixed top-4 right-4 px-6 py-3 rounded-lg shadow-lg z-50 transform transition-all duration-300 animate-fade-in ${
      type === 'success' 
        ? 'bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-300' 
        : 'bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-300'
    }`;
    notification.innerHTML = `
      <div class="flex items-center space-x-2">
        <i class="fa-solid ${type === 'success' ? 'fa-circle-check' : 'fa-circle-info'}"></i>
        <span class="font-medium">${message}</span>
      </div>
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
      notification.style.opacity = '0';
      notification.style.transform = 'translateY(-20px)';
      setTimeout(() => {
        if (notification.parentNode) {
          document.body.removeChild(notification);
        }
      }, 300);
    }, 3000);
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function() {
    applyFilters();
    
    // Add animation to product cards
    productCards.forEach((card, index) => {
      card.style.animationDelay = `${index * 0.05}s`;
    });
  });
</script>

<style>
  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }

  .animate-slide-up {
    animation: slideUp 0.3s ease-out forwards;
