<% layout("/layouts/boilerplate") %>

<%
  const priceText = typeof product.price === "number"
    ? "Rs." + product.price.toLocaleString("en-IN")
    : product.price;
  const categoryText = product.displayCategory || product.category;
  const prescriptionText = product.requires_prescription ? "Required" : "Not required";
  const typeLabel = product.type === "medicine"
    ? "Medicine"
    : product.type === "surgical"
      ? "Surgical Item"
      : "Medical Device";
%>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <div class="bg-gradient-to-r from-green-600 to-teal-500">
    <div class="container mx-auto px-4 py-8 sm:px-6 lg:px-8">
      <a href="/products" class="mb-5 inline-flex items-center text-sm font-semibold text-white/90 transition-colors hover:text-white">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        Back to products
      </a>

      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-green-100"><%= typeLabel %></p>
          <h1 class="text-3xl font-bold text-white md:text-4xl"><%= product.name %></h1>
          <p class="mt-3 max-w-3xl text-green-50"><%= product.description %></p>
        </div>

        <div class="rounded-lg border border-white/20 bg-white/10 p-4 text-white backdrop-blur-sm">
          <p class="text-sm text-green-50">Price</p>
          <p class="text-3xl font-bold"><%= priceText %></p>
        </div>
      </div>
    </div>
  </div>

  <main class="container mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <section class="grid grid-cols-1 gap-8 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="h-72 bg-gradient-to-r <%= product.imageColor || "from-green-400 to-teal-500" %> p-8">
            <img
              src="<%= product.image %>"
              alt="<%= product.name %>"
              class="h-full w-full rounded-lg bg-white/80 object-contain p-6 dark:bg-gray-900/80"
            >
          </div>
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="mb-6 flex flex-wrap gap-3">
            <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-700 dark:bg-green-900/30 dark:text-green-300">
              <%= product.availability %>
            </span>
            <% if (product.requires_prescription) { %>
              <span class="rounded-full bg-red-100 px-3 py-1 text-sm font-semibold text-red-700 dark:bg-red-900/30 dark:text-red-300">
                <i class="fa-solid fa-prescription mr-1"></i>
                Rx Required
              </span>
            <% } %>
          </div>

          <h2 class="mb-4 text-2xl font-bold text-gray-900 dark:text-white">Product Details</h2>

          <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Product ID</dt>
              <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= product.id %></dd>
            </div>

            <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Category</dt>
              <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= categoryText %></dd>
            </div>

            <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Manufacturer</dt>
              <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= product.manufacturer %></dd>
            </div>

            <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Pack</dt>
              <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= product.pack %></dd>
            </div>

            <% if (product.dosage) { %>
              <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Dosage Form</dt>
                <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= product.dosage %></dd>
              </div>
            <% } %>

            <% if (product.size) { %>
              <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Size</dt>
                <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= product.size %></dd>
              </div>
            <% } %>

            <% if (product.features) { %>
              <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Features</dt>
                <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= product.features %></dd>
              </div>
            <% } %>

            <div class="rounded-lg bg-gray-50 p-4 dark:bg-gray-900">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Prescription</dt>
              <dd class="mt-1 font-semibold text-gray-900 dark:text-white"><%= prescriptionText %></dd>
            </div>
          </dl>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="tel:+919876543210"
              class="inline-flex flex-1 items-center justify-center rounded-lg bg-green-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-green-700"
            >
              <i class="fa-solid fa-phone mr-2"></i>
              Call to Order
            </a>

            <a
              href="/contact"
              class="inline-flex flex-1 items-center justify-center rounded-lg border border-green-500 px-6 py-3 font-semibold text-green-600 transition-colors hover:bg-green-50 dark:text-green-400 dark:hover:bg-green-900/20"
            >
              <i class="fa-solid fa-user-doctor mr-2"></i>
              Ask Pharmacist
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>
