<style>
  /* Animation Keyframes */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out;
  }
  
  .animate-slide-down {
    animation: slideDown 0.4s ease-out;
  }
  
  /* Newsletter Response Styles */
  #subscription-response.success #subscription-message {
    background-color: #E8F5E9;
    color: #2E7D32;
    border: 1px solid #A5D6A7;
  }
  
  #subscription-response.error #subscription-message {
    background-color: #FFEBEE;
    color: #C62828;
    border: 1px solid #EF9A9A;
  }
  
  .dark #subscription-response.success #subscription-message {
    background-color: #1D2E21;
    color: #66BB6A;
    border: 1px solid #2E7D32;
  }
  
  .dark #subscription-response.error #subscription-message {
    background-color: #2B1815;
    color: #E28880;
    border: 1px solid #B3453D;
  }
  
  #subscription-response.success #subscription-message i,
  #subscription-response.error #subscription-message i {
    font-size: 1rem;
  }
  
  /* Back to Top Button Animation */
  #back-to-top.show {
    opacity: 1 !important;
    pointer-events: auto !important;
    transform: translateY(0) !important;
  }
  
  /* Smooth Transitions for All Interactive Elements */
  .footer-link {
    position: relative;
  }
  
  /* Hover Glow Effect for Social Icons */
  .social-icon:hover {
    filter: drop-shadow(0 0 8px rgba(46, 125, 50, 0.3));
  }
</style>

<script>
  // Set current year
  document.getElementById('current-year').textContent = new Date().getFullYear();

  // Newsletter form submission with inline response
  const newsletterForm = document.getElementById('newsletter-form');
  const subscriptionResponse = document.getElementById('subscription-response');
  const subscriptionMessage = document.getElementById('subscription-message');
  
  if (newsletterForm) {
    newsletterForm.addEventListener('submit', function(e) {
      e.preventDefault();
      const email = document.getElementById('newsletter-email').value;
      const submitBtn = this.querySelector('button[type="submit"]');
      
      // Disable button and show loading state
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>...';
      
      // Simulate API call (replace with actual API call)
      setTimeout(() => {
        // Simulate success
        const success = true; // Change to false to test error state
        
        // Show response
        subscriptionResponse.classList.remove('hidden', 'success', 'error', 'animate-slide-down');
        
        if (success) {
          subscriptionResponse.classList.add('success', 'animate-slide-down');
          subscriptionMessage.innerHTML = `
            <i class="fa-regular fa-circle-check"></i>
            <span>Thank you! You've been subscribed successfully.</span>
          `;
          this.reset();
        } else {
          subscriptionResponse.classList.add('error', 'animate-slide-down');
          subscriptionMessage.innerHTML = `
            <i class="fa-regular fa-circle-xmark"></i>
            <span>Something went wrong. Please try again.</span>
          `;
        }
        
        // Reset button
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fa-regular fa-paper-plane mr-2"></i>';
        
        // Auto-hide response after 5 seconds
        setTimeout(() => {
          subscriptionResponse.classList.remove('animate-slide-down');
          setTimeout(() => {
            subscriptionResponse.classList.add('hidden');
          }, 300);
        }, 5000);
        
      }, 1500);
    });
  }

  // Back to Top Button with proper scroll detection
  const backToTopBtn = document.getElementById('back-to-top');
  let isFooterVisible = false;
  
  function checkScrollPosition() {
    const scrollY = window.pageYOffset || document.documentElement.scrollTop;
    const windowHeight = window.innerHeight;
    const documentHeight = document.documentElement.scrollHeight;
    const footer = document.querySelector('footer');
    
    // Show button when scrolled down more than 300px
    if (scrollY > 300) {
      backToTopBtn.classList.add('show');
    } else {
      backToTopBtn.classList.remove('show');
    }
    
    // Check if footer is visible in viewport
    if (footer) {
      const footerRect = footer.getBoundingClientRect();
      const footerTop = footerRect.top;
      const footerBottom = footerRect.bottom;
      
      // If footer is at the bottom of the viewport or visible
      if (footerTop < windowHeight && footerBottom > 0) {
        isFooterVisible = true;
        // Position button slightly above footer if overlapping
        if (footerTop < windowHeight - 100) {
          const offset = Math.min(20, windowHeight - footerTop + 20);
          backToTopBtn.style.bottom = `${offset + 20}px`;
        } else {
          backToTopBtn.style.bottom = '2rem';
        }
      } else {
        isFooterVisible = false;
        backToTopBtn.style.bottom = '2rem';
      }
    }
  }

  // Throttled scroll listener for better performance
  let ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        checkScrollPosition();
        ticking = false;
      });
      ticking = true;
    }
  });

  // Check on load and resize
  window.addEventListener('load', checkScrollPosition);
  window.addEventListener('resize', checkScrollPosition);

  // Smooth scroll to top
  backToTopBtn?.addEventListener('click', function() {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });

  // Keyboard accessibility for back to top button
  backToTopBtn?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    }
  });
</script>