<% layout("/layouts/boilerplate") -%>

<section class="py-12 bg-white dark:bg-gray-900">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <article class="max-w-4xl mx-auto">
      <a
        href="/blogs"
        class="inline-flex items-center mb-6 text-sm font-semibold text-green-600 transition-colors hover:text-green-700 dark:text-green-400 dark:hover:text-green-300"
      >
        <i class="mr-2 fa-solid fa-arrow-left"></i>
        Back to Articles
      </a>

      <div class="overflow-hidden border border-gray-200 shadow-sm rounded-xl bg-gray-50 dark:border-gray-700 dark:bg-gray-800">
        <div class="p-6 bg-white dark:bg-gray-900 sm:p-8">
          <img
            src="<%= article.image || '/images/article-allopathic.svg' %>"
            alt="<%= article.title %>"
            class="object-contain w-full rounded-lg h-72"
          >
        </div>

        <div class="p-6 sm:p-8">
          <p class="mb-3 text-sm font-semibold tracking-wider text-green-600 uppercase dark:text-green-400">
            Health & Wellness
          </p>

          <h1 class="text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">
            <%= article.title %>
          </h1>

          <div class="flex flex-wrap items-center gap-3 mt-4 text-sm text-gray-500 dark:text-gray-400">
            <span class="px-3 py-1 font-semibold text-green-700 rounded-full bg-green-50 dark:bg-green-900/30 dark:text-green-300"><%= article.category || 'Health Guide' %></span>
            <span><%= article.readTime || '4 min read' %></span>
          </div>

          <p class="mt-4 text-lg leading-8 text-gray-600 dark:text-gray-300">
            <%= article.description %>
          </p>

          <div class="pt-8 mt-8 space-y-5 border-t border-gray-200 dark:border-gray-700">
            <% (article.content || []).forEach(paragraph => { %>
              <p class="text-base leading-8 text-gray-700 dark:text-gray-300">
                <%= paragraph %>
              </p>
            <% }) %>
          </div>
        </div>
      </div>
    </article>
  </div>
</section>
