<% layout("/layouts/boilerplate") -%>

<section class="bg-white py-12 dark:bg-gray-900">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <article class="mx-auto max-w-4xl">
      <a
        href="/blogs"
        class="mb-6 inline-flex items-center text-sm font-semibold text-green-600 transition-colors hover:text-green-700 dark:text-green-400 dark:hover:text-green-300"
      >
        <i class="fa-solid fa-arrow-left mr-2"></i>
        Back to Articles
      </a>

      <div class="overflow-hidden rounded-xl border border-gray-200 bg-gray-50 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="bg-white p-6 dark:bg-gray-900 sm:p-8">
          <img
            src="<%= article.image %>"
            alt="<%= article.title %>"
            class="h-72 w-full rounded-lg object-contain"
          >
        </div>

        <div class="p-6 sm:p-8">
          <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-green-600 dark:text-green-400">
            Health & Wellness
          </p>

          <h1 class="text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">
            <%= article.title %>
          </h1>

          <p class="mt-4 text-lg leading-8 text-gray-600 dark:text-gray-300">
            <%= article.description %>
          </p>

          <div class="mt-8 space-y-5 border-t border-gray-200 pt-8 dark:border-gray-700">
            <% article.content.forEach(paragraph => { %>
              <p class="text-base leading-8 text-gray-700 dark:text-gray-300">
                <%= paragraph %>
              </p>
            <% }) %>
          </div>
        </div>
      </div>
    </article>
  </div>
</section>
