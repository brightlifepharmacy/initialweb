<!-- blogs.ejs -->
<% layout("/layouts/boilerplate") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">

<style>
  .font-display { font-family: 'Fraunces', serif; }
  .font-body { font-family: 'Inter', sans-serif; }
  .font-mono { font-family: 'IBM Plex Mono', monospace; }

  /* Blog Card Styles */
  .blog-card {
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  
  .blog-card:hover {
    transform: translateY(-4px);
  }
  
  /* Tag Styles */
  .blog-tag {
    transition: all 0.2s;
  }
  
  .blog-tag:hover {
    transform: scale(1.05);
  }
  
  /* Comment Section */
  .comment-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 14px;
    flex-shrink: 0;
  }
  
  /* Like Button Animation */
  .like-btn.liked {
    color: #E53E3E;
  }
  
  .like-btn.liked i {
    animation: heartBeat 0.3s ease;
  }
  
  @keyframes heartBeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }
  
  /* Save Button */
  .save-btn.saved {
    color: #2E7D32;
  }
  
  .save-btn.saved i {
    animation: savePop 0.3s ease;
  }
  
  @keyframes savePop {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }
  
  /* Comment Input Focus */
  .comment-input:focus {
    box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.1);
  }
  
  /* Featured Badge */
  .featured-badge {
    background: linear-gradient(135deg, #2E7D32, #C99A2E);
  }
  
  .dark .featured-badge {
    background: linear-gradient(135deg, #3F9142, #E3C069);
  }
  
  /* Category Pills */
  .category-pill {
    transition: all 0.2s;
    cursor: pointer;
  }
  
  .category-pill.active {
    background: #2E7D32;
    color: white;
    border-color: #2E7D32;
  }
  
  .dark .category-pill.active {
    background: #3F9142;
    border-color: #3F9142;
  }
  
  .category-pill:hover:not(.active) {
    border-color: #2E7D32;
    color: #2E7D32;
  }
  
  .dark .category-pill:hover:not(.active) {
    border-color: #66BB6A;
    color: #66BB6A;
  }
</style>

<main class="font-body bg-[#F7F8F5] dark:bg-[#0E1712] text-[#12261A] dark:text-[#E9F2E7] transition-colors duration-300 min-h-screen">
  
  <!-- Page Header -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[#E8F5E9] via-white to-[#F7F8F5] dark:from-[#0E1712] dark:via-[#111B15] dark:to-[#0A120E] pt-12 pb-16 lg:pt-16 lg:pb-20 transition-colors duration-300 border-b border-[#E3E8E1] dark:border-[#22302A]">
    <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-[#2E7D32] via-[#C99A2E] to-[#2E7D32] dark:from-[#4CAF50] dark:via-[#E3C069] dark:to-[#4CAF50] opacity-60"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-10 dark:opacity-5">
      <div class="absolute top-20 right-20 w-64 h-64 rounded-full bg-[#2E7D32] blur-3xl"></div>
      <div class="absolute bottom-20 right-40 w-96 h-96 rounded-full bg-[#C99A2E] blur-3xl"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#E8F5E9] dark:bg-[#1D2E21] border border-[#A5D6A7] dark:border-[#2E7D32] mb-6 animate-fade-in">
          <i class="fa-solid fa-blog text-[#2E7D32] dark:text-[#66BB6A] text-sm"></i>
          <span class="text-xs font-medium text-[#2E7D32] dark:text-[#66BB6A] uppercase tracking-wider">Health Blog</span>
        </div>
        
        <h1 class="font-display font-bold text-4xl md:text-5xl text-[#12261A] dark:text-[#F2F8F0] mb-4 animate-slide-up">
          Health <span class="text-[#2E7D32] dark:text-[#66BB6A]">Insights</span> & <span class="text-[#C99A2E] dark:text-[#E3C069]">Wellness</span>
        </h1>
        
        <p class="text-lg text-[#4B5C50] dark:text-[#8FA393] max-w-2xl mx-auto leading-relaxed animate-slide-up animation-delay-200">
          Expert articles on allopathic medicines, health tips, and wellness advice from our pharmacists
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    
    <!-- Categories & Search -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
      <div class="flex flex-wrap gap-2">
        <button class="category-pill px-4 py-2 rounded-full border border-[#E3E8E1] dark:border-[#22302A] text-sm font-medium text-[#4B5C50] dark:text-[#8FA393] bg-white dark:bg-[#16211A] active" data-category="all">
          All
        </button>
        <button class="category-pill px-4 py-2 rounded-full border border-[#E3E8E1] dark:border-[#22302A] text-sm font-medium text-[#4B5C50] dark:text-[#8FA393] bg-white dark:bg-[#16211A]" data-category="medicines">
          Medicines
        </button>
        <button class="category-pill px-4 py-2 rounded-full border border-[#E3E8E1] dark:border-[#22302A] text-sm font-medium text-[#4B5C50] dark:text-[#8FA393] bg-white dark:bg-[#16211A]" data-category="diabetes">
          Diabetes
        </button>
        <button class="category-pill px-4 py-2 rounded-full border border-[#E3E8E1] dark:border-[#22302A] text-sm font-medium text-[#4B5C50] dark:text-[#8FA393] bg-white dark:bg-[#16211A]" data-category="heart">
          Heart Health
        </button>
        <button class="category-pill px-4 py-2 rounded-full border border-[#E3E8E1] dark:border-[#22302A] text-sm font-medium text-[#4B5C50] dark:text-[#8FA393] bg-white dark:bg-[#16211A]" data-category="elder-care">
          Elder Care
        </button>
        <button class="category-pill px-4 py-2 rounded-full border border-[#E3E8E1] dark:border-[#22302A] text-sm font-medium text-[#4B5C50] dark:text-[#8FA393] bg-white dark:bg-[#16211A]" data-category="allergies">
          Allergies
        </button>
      </div>
      
      <div class="relative">
        <i class="fa-solid fa-search absolute left-3 top-1/2 -translate-y-1/2 text-[#8A978C] dark:text-[#6E8175] text-sm"></i>
        <input type="text" id="blog-search" placeholder="Search articles..." 
          class="pl-9 pr-4 py-2 w-full md:w-64 rounded-full border border-[#E3E8E1] dark:border-[#2A3A31] bg-white dark:bg-[#16211A] text-sm text-[#12261A] dark:text-[#E9F2E7] placeholder-[#8A978C] dark:placeholder-[#6E8175] focus:outline-none focus:ring-2 focus:ring-[#2E7D32]/40 dark:focus:ring-[#4CAF50]/40 transition-all">
      </div>
    </div>
    
    <!-- Blog Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
      <!-- Blogs will be rendered here -->
    </div>
    
    <!-- Load More -->
    <div class="text-center mt-10">
      <button id="load-more" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-[#E3E8E1] dark:border-[#22302A] bg-white dark:bg-[#16211A] text-sm font-medium text-[#4B5C50] dark:text-[#8FA393] hover:border-[#2E7D32] dark:hover:border-[#66BB6A] hover:text-[#2E7D32] dark:hover:text-[#66BB6A] transition-all">
        <i class="fa-solid fa-rotate"></i>
        Load More Articles
      </button>
    </div>
  </div>

  <!-- Featured Article Section -->
  <section class="bg-white dark:bg-[#111B15] border-y border-[#E3E8E1] dark:border-[#22302A] py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-8">
        <span class="featured-badge text-white text-xs font-mono px-3 py-1 rounded-full">Featured</span>
        <span class="text-sm text-[#4B5C50] dark:text-[#8FA393]">Editor's Pick</span>
      </div>
      
      <div id="featured-blog" class="grid lg:grid-cols-2 gap-8 items-center">
        <!-- Featured blog will be rendered here -->
      </div>
    </div>
  </section>

</main>



<script>
  // ===================== BLOG DATA =====================
  const blogData = [
    {
