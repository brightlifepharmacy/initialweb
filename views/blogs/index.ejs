<% layout("/layouts/boilerplate") -%>

<section class="bg-white py-16 dark:bg-gray-900">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">
        Health & Wellness Articles
      </h1>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        Helpful guides about medicines, first aid, surgical care, and home health.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% articles.forEach(article => { %>
        <article class="flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-gray-50 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800">
          <div class="h-44 bg-white p-4 dark:bg-gray-900">
            <img
              src="<%= article.image %>"
              alt="<%= article.title %>"
              class="h-full w-full rounded-lg object-contain"
            >
          </div>

          <div class="flex flex-1 flex-col p-5">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">
              <%= article.title %>
            </h2>

            <p class="mt-2 flex-1 text-sm leading-6 text-gray-600 dark:text-gray-300">
              <%= article.description %>
            </p>

            <a
              href="/blogs/<%= article.slug %>"
              class="mt-5 rounded-lg bg-green-600 px-4 py-2 text-center text-sm font-semibold text-white transition-colors duration-300 hover:bg-green-700"
            >
              Read Full Article
            </a>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
