<% layout("/layouts/boilerplate") -%>

<section class="py-16 bg-white dark:bg-gray-900">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto mb-12 text-center">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">
        Health & Wellness Articles
      </h1>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        Helpful guides about medicines, first aid, surgical care, and home health.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">
      <% if (articles && articles.length) { %>
      <% articles.forEach(article => { %>
        <article class="flex flex-col h-full overflow-hidden transition-all duration-300 bg-white border border-gray-200 shadow-sm rounded-2xl hover:-translate-y-1 hover:shadow-2xl dark:border-gray-700 dark:bg-gray-800">
          <div class="relative aspect-[16/10] overflow-hidden bg-gradient-to-br from-green-50 via-white to-teal-50 p-5 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
            <img
              src="<%= article.image || '/images/article-allopathic.svg' %>"
              alt="<%= article.title %>"
              class="object-contain w-full h-full rounded-xl"
            >
            <div class="absolute px-3 py-1 text-xs font-semibold text-green-700 rounded-full shadow-sm left-4 top-4 bg-white/90 backdrop-blur dark:bg-gray-900/80 dark:text-green-300">
              Health Guide
            </div>
          </div>

          <div class="flex flex-col flex-1 p-6">
            <h2 class="text-lg font-bold leading-tight text-gray-900 dark:text-white">
              <%= article.title %>
            </h2>

            <p class="flex-1 mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
              <%= article.description %>
            </p>

            <a
              href="/blog/<%= article.slug || article._id || article.id %>"
              class="inline-flex items-center justify-center px-4 py-3 mt-6 text-sm font-semibold text-white transition-colors duration-300 bg-green-600 rounded-xl hover:bg-green-700"
            >
              Read Full Article
              <i class="ml-2 fa-solid fa-arrow-right"></i>
            </a>
          </div>
        </article>
      <% }) %>
      <% } else { %>
        <div class="p-10 text-center border border-gray-300 border-dashed col-span-full rounded-2xl dark:border-gray-700">
          <p class="text-lg font-semibold text-gray-900 dark:text-white">No articles available right now</p>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Please check back after articles are added to the database.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>
