<% layout("/layouts/boilerplate") %>

<!-- About Page -->
<div class="min-h-screen bg-gradient-to-b from-white to-green-50 dark:from-gray-900 dark:to-gray-800">
  
  <!-- Hero Section -->
  <section class="relative py-16 overflow-hidden md:py-24">
    <!-- Background Pattern -->
    <div class="absolute inset-0 bg-green-500 opacity-5"></div>
    
    <!-- Floating Elements -->
    <div class="absolute top-20 left-10 animate-float-slow">
      <div class="flex items-center justify-center w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-2xl">
        <i class="text-2xl text-green-500 fa-solid fa-heart-pulse dark:text-green-400"></i>
      </div>
    </div>
    
    <div class="absolute bottom-20 right-10 animate-float">
      <div class="flex items-center justify-center bg-teal-100 w-14 h-14 dark:bg-teal-900/30 rounded-2xl">
        <i class="text-xl text-teal-500 fa-solid fa-stethoscope dark:text-teal-400"></i>
      </div>
    </div>
    
    <div class="container relative z-10 px-4 mx-auto sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Page Header -->
        <div class="inline-flex items-center px-4 py-2 mb-8 space-x-2 bg-white rounded-full shadow-sm dark:bg-gray-800">
          <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">About BrightLife Pharmacy</span>
        </div>
        
        <h1 class="mb-6 text-4xl font-bold md:text-5xl lg:text-6xl">
          <span class="block text-gray-800 dark:text-white">Our Commitment to</span>
          <span class="block text-transparent bg-gradient-to-r from-green-600 to-teal-500 bg-clip-text animate-gradient-x">Your Health</span>
        </h1>
        
        <p class="max-w-3xl mx-auto mb-8 text-xl leading-relaxed text-gray-600 dark:text-gray-300">
          For over a decade, BrightLife Pharmacy has been the trusted healthcare partner for thousands of families, 
          providing genuine allopathic medicines and surgical supplies with expert care and compassion.
        </p>
        
        <!-- Stats -->
        <div class="grid grid-cols-2 gap-6 mt-12 md:grid-cols-4">
          <div class="text-center">
            <div class="mb-2 text-3xl font-bold text-green-600 md:text-4xl dark:text-green-400">
              <span class="counter" data-target="15">0</span>+
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Years Experience</div>
          </div>
          <div class="text-center">
            <div class="mb-2 text-3xl font-bold text-green-600 md:text-4xl dark:text-green-400">
              <span class="counter" data-target="5000">0</span>+
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Products Available</div>
          </div>
          <div class="text-center">
            <div class="mb-2 text-3xl font-bold text-green-600 md:text-4xl dark:text-green-400">
              <span class="counter" data-target="50000">0</span>+
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Happy Customers</div>
          </div>
          <div class="text-center">
            <div class="mb-2 text-3xl font-bold text-green-600 md:text-4xl dark:text-green-400">
              24/7
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Service Hours</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="py-16 bg-white md:py-24 dark:bg-gray-800">
    <div class="container px-4 mx-auto sm:px-6 lg:px-8">
      <div class="grid items-center grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-20">
        <!-- Image/Visual -->
        <div class="relative">
          <div class="overflow-hidden shadow-2xl rounded-3xl">
            <div class="relative aspect-w-4 aspect-h-3 bg-gradient-to-br from-green-400 to-teal-400">
              <!-- Pharmacy Interior -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent">
              </div>
              <div class="relative z-10 flex flex-col justify-end h-full p-8">
                <img src="/images/brightlife.png" alt="">
                <div class="text-white">
                  <h3 class="mb-2 text-2xl font-bold">Our Pharmacy</h3>
                  <p class="text-white/90">State-of-the-art facility with modern equipment</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Floating Badge -->
          <div class="absolute p-4 bg-white border border-gray-100 shadow-xl -bottom-6 -right-6 dark:bg-gray-800 rounded-2xl dark:border-gray-700">
            <div class="flex items-center space-x-3">
              <div class="flex items-center justify-center w-12 h-12 bg-green-100 rounded-full dark:bg-green-900/30">
                <i class="text-green-600 fa-solid fa-award dark:text-green-400"></i>
              </div>
              <div>
                <div class="font-bold text-gray-800 dark:text-white">ISO 9001:2015</div>
                <div class="text-xs text-gray-600 dark:text-gray-400">Certified</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div class="space-y-6">
          <div class="inline-block">
            <span class="text-sm font-semibold tracking-wider text-green-600 uppercase dark:text-green-400">Our Story</span>
            <div class="w-16 h-1 mt-2 bg-gradient-to-r from-green-500 to-teal-400"></div>
          </div>
          
          <h2 class="text-3xl font-bold text-gray-800 md:text-4xl dark:text-white">
            A Legacy of Trust & Care Since 2010
          </h2>
          
          <div class="space-y-4 text-gray-600 dark:text-gray-300">
            <p>
              Founded in 2010 by Dr. Rajesh Verma, BrightLife Pharmacy began as a small neighborhood pharmacy 
              with a big vision: to provide accessible, reliable healthcare to every family in our community.
            </p>
            
            <p>
              What started as a single store has grown into a trusted healthcare institution, serving thousands 
              of customers with genuine allopathic medicines, surgical supplies, and expert medical guidance.
            </p>
            
            <p>
              Our journey is built on three core principles: <strong class="text-green-600 dark:text-green-400">Quality, Trust, and Compassion</strong>. 
              Every medicine we dispense undergoes rigorous quality checks, and every customer receives 
              personalized care from our certified pharmacists.
            </p>
          </div>
          
          <!-- Founder Quote -->
          <div class="p-6 mt-8 border-l-4 border-green-500 bg-gradient-to-r from-green-50 to-teal-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl">
            <i class="mb-4 text-2xl text-green-400 fa-solid fa-quote-left"></i>
            <p class="italic text-gray-700 dark:text-gray-300">
              "Healthcare is not just about medicines; it's about understanding each patient's unique needs 
              and providing solutions with empathy and expertise."
            </p>
            <div class="flex items-center mt-4">
              <div class="flex items-center justify-center w-10 h-10 mr-3 bg-green-100 rounded-full dark:bg-gray-700">
                <span class="font-bold text-green-600 dark:text-green-400">RV</span>
              </div>
              <div>
                <div class="font-bold text-gray-800 dark:text-white">Dr. Rajesh Verma</div>
                <div class="text-sm text-gray-600 dark:text-gray-400">Founder & Chief Pharmacist</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission & Values -->
  <section class="py-16 md:py-24 bg-gradient-to-r from-green-50 to-teal-50 dark:from-gray-800 dark:to-gray-700">
    <div class="container px-4 mx-auto sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <h2 class="mb-6 text-3xl font-bold text-gray-800 md:text-4xl dark:text-white">
          Our Mission & Values
        </h2>
        <p class="text-gray-600 dark:text-gray-300">
          We're committed to setting new standards in pharmaceutical care through innovation, integrity, and 
          unwavering dedication to our customers' well-being.
        </p>
      </div>
      
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        <!-- Mission Card -->
        <div class="p-8 transition-shadow duration-300 bg-white border border-gray-100 shadow-lg dark:bg-gray-800 rounded-2xl hover:shadow-xl dark:border-gray-700">
          <div class="flex items-center justify-center w-16 h-16 mb-6 bg-gradient-to-r from-green-500 to-green-400 rounded-2xl">
            <i class="text-2xl text-white fa-solid fa-bullseye"></i>
          </div>
          <h3 class="mb-4 text-xl font-bold text-gray-800 dark:text-white">Our Mission</h3>
          <p class="text-gray-600 dark:text-gray-400">
            To provide accessible, affordable, and quality healthcare solutions through genuine medicines, 
            expert consultation, and compassionate service, ensuring every customer receives personalized care 
            for their unique health needs.
          </p>
        </div>
        
        <!-- Vision Card -->
        <div class="p-8 transition-shadow duration-300 bg-white border border-gray-100 shadow-lg dark:bg-gray-800 rounded-2xl hover:shadow-xl dark:border-gray-700">
          <div class="flex items-center justify-center w-16 h-16 mb-6 bg-gradient-to-r from-teal-500 to-teal-400 rounded-2xl">
            <i class="text-2xl text-white fa-solid fa-eye"></i>
          </div>
          <h3 class="mb-4 text-xl font-bold text-gray-800 dark:text-white">Our Vision</h3>
          <p class="text-gray-600 dark:text-gray-400">
            To become the most trusted healthcare partner in the region by 2030, recognized for excellence 
            in pharmaceutical services, community health initiatives, and innovative healthcare solutions 
            that improve quality of life.
          </p>
        </div>
        
        <!-- Values Card -->
        <div class="p-8 transition-shadow duration-300 bg-white border border-gray-100 shadow-lg dark:bg-gray-800 rounded-2xl hover:shadow-xl dark:border-gray-700">
          <div class="flex items-center justify-center w-16 h-16 mb-6 bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-2xl">
            <i class="text-2xl text-white fa-solid fa-hand-holding-heart"></i>
          </div>
          <h3 class="mb-4 text-xl font-bold text-gray-800 dark:text-white">Our Values</h3>
          <div class="space-y-3">
            <div class="flex items-center">
              <i class="mr-3 text-green-500 fa-solid fa-check"></i>
              <span class="text-gray-700 dark:text-gray-300">Integrity & Transparency</span>
            </div>
            <div class="flex items-center">
              <i class="mr-3 text-green-500 fa-solid fa-check"></i>
              <span class="text-gray-700 dark:text-gray-300">Patient-Centric Care</span>
            </div>
            <div class="flex items-center">
              <i class="mr-3 text-green-500 fa-solid fa-check"></i>
              <span class="text-gray-700 dark:text-gray-300">Quality & Safety First</span>
            </div>
            <div class="flex items-center">
              <i class="mr-3 text-green-500 fa-solid fa-check"></i>
              <span class="text-gray-700 dark:text-gray-300">Community Responsibility</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Team -->
  <section class="py-16 bg-white md:py-24 dark:bg-gray-900">
    <div class="container px-4 mx-auto sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <h2 class="mb-6 text-3xl font-bold text-gray-800 md:text-4xl dark:text-white">
          Meet Our Expert Team
        </h2>
        <p class="text-gray-600 dark:text-gray-300">
          Our team of certified pharmacists and healthcare professionals brings decades of combined experience 
          to provide you with the best medical guidance and care.
        </p>
      </div>
      
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
        <% const team = [
          {
            name: 'Dr. Rajesh Verma',
            role: 'Founder & Chief Pharmacist',
            experience: '25+ Years',
            specialization: 'Clinical Pharmacy',
            bio: 'M.Pharm, PhD in Pharmaceutical Sciences with extensive experience in clinical practice.',
            color: 'from-green-500 to-green-400'
          },
          {
            name: 'Dr. Priya Sharma',
            role: 'Head Pharmacist',
            experience: '15+ Years',
            specialization: 'Pediatric Medicine',
            bio: 'Specialized in pediatric medications and child healthcare. B.Pharm, M.Pharm.',
            color: 'from-teal-500 to-teal-400'
          },
          {
            name: 'Dr. Amit Patel',
            role: 'Surgical Specialist',
            experience: '12+ Years',
            specialization: 'Surgical Supplies',
            bio: 'Expert in surgical instruments and medical equipment. Diploma in Medical Technology.',
            color: 'from-emerald-500 to-emerald-400'
          },
          {
            name: 'Ms. Neha Kapoor',
            role: 'Customer Care Head',
            experience: '8+ Years',
            specialization: 'Patient Relations',
            bio: 'Ensuring exceptional customer experience and efficient service delivery.',
            color: 'from-cyan-500 to-cyan-400'
          }
        ] %>
        
        <% team.forEach(member => { %>
          <div class="overflow-hidden transition-all duration-300 bg-white border border-gray-100 shadow-lg group dark:bg-gray-800 rounded-2xl hover:shadow-2xl hover:-translate-y-2 dark:border-gray-700">
            <!-- Team Member Image -->
            <div class="h-64 bg-gradient-to-r <%= member.color %> flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 bg-black/20"></div>
              <div class="flex items-center justify-center w-32 h-32 rounded-full bg-white/20 backdrop-blur-sm">
                <i class="text-5xl text-white fa-solid fa-user-doctor"></i>
              </div>
              
              <!-- Experience Badge -->
              <div class="absolute top-4 right-4">
                <span class="px-3 py-1 text-sm font-bold text-green-600 rounded-full bg-white/90">
                  <%= member.experience %>
                </span>
              </div>
            </div>
            
            <!-- Team Member Details -->
            <div class="p-6">
              <h3 class="mb-1 text-xl font-bold text-gray-800 dark:text-white">
                <%= member.name %>
              </h3>
              <p class="mb-3 font-medium text-green-600 dark:text-green-400">
                <%= member.role %>
              </p>
              
              <div class="mb-4">
                <span class="inline-block px-3 py-1 text-sm font-medium text-gray-700 bg-gray-100 rounded-full dark:bg-gray-700 dark:text-gray-300">
                  <i class="mr-1 fa-solid fa-star"></i>
                  <%= member.specialization %>
                </span>
              </div>
              
              <p class="mb-6 text-sm text-gray-600 dark:text-gray-400">
                <%= member.bio %>
              </p>
              
              <!-- Contact Button -->
              <button class="w-full px-4 py-2 text-sm font-medium text-green-600 transition-all duration-300 transform translate-y-2 border border-green-500 rounded-lg opacity-0 consult-btn dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20 group-hover:opacity-100 group-hover:translate-y-0">
                <i class="mr-2 fa-solid fa-comment-medical"></i>
                Schedule Consultation
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 md:py-24 bg-gradient-to-r from-green-600 to-teal-500">
    <div class="container px-4 mx-auto sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <h2 class="mb-6 text-3xl font-bold text-white md:text-4xl">
          Our Comprehensive Services
        </h2>
        <p class="text-green-100">
          From prescription medicines to surgical supplies and expert consultations, we provide 
          complete healthcare solutions under one roof.
        </p>
      </div>
      
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% const services = [
          {
            icon: 'fa-prescription',
            title: 'Allopathic Medicines',
            description: 'Wide range of genuine prescription and OTC medicines from trusted manufacturers.',
            features: ['Prescription Drugs', 'OTC Medicines', 'Chronic Care', 'Pediatric']
          },
          {
            icon: 'fa-syringe',
            title: 'Surgical Supplies',
            description: 'Complete range of sterile surgical instruments, disposables, and medical equipment.',
            features: ['Surgical Instruments', 'Disposables', 'Medical Devices', 'Sterilization']
          },
          {
            icon: 'fa-user-doctor',
            title: 'Medical Consultation',
            description: 'Free expert guidance from certified pharmacists for medicine usage and health queries.',
            features: ['Medicine Guidance', 'Dosage Advice', 'Side Effects', 'Interactions']
          },
          {
            icon: 'fa-truck-medical',
            title: 'Home Delivery',
            description: 'Fast and reliable medicine delivery to your doorstep within 2 hours.',
            features: ['Emergency Delivery', 'Regular Refills', 'Prescription Pickup', 'Free Delivery']
          },
          {
            icon: 'fa-kit-medical',
            title: 'First Aid Solutions',
            description: 'Complete first aid kits and emergency medical supplies for home and travel.',
            features: ['First Aid Kits', 'Emergency Supplies', 'Wound Care', 'Burn Treatment']
          },
          {
            icon: 'fa-heart-pulse',
            title: 'Health Checkups',
            description: 'Basic health screening and monitoring services at our pharmacy.',
            features: ['BP Monitoring', 'Sugar Testing', 'Weight Management', 'Health Records']
          }
        ] %>
        
        <% services.forEach(service => { %>
          <div class="p-6 transition-all duration-300 border bg-white/10 backdrop-blur-sm rounded-2xl border-white/20 hover:bg-white/20 hover:-translate-y-2">
            <div class="flex items-center justify-center mb-6 w-14 h-14 bg-white/20 rounded-2xl">
              <i class="fa-solid <%= service.icon %> text-white text-2xl"></i>
            </div>
            
            <h3 class="mb-3 text-xl font-bold text-white">
              <%= service.title %>
            </h3>
            
            <p class="mb-4 text-green-100">
              <%= service.description %>
            </p>
            
            <div class="space-y-2">
              <% service.features.forEach(feature => { %>
                <div class="flex items-center text-sm text-white/90">
                  <i class="mr-2 text-green-300 fa-solid fa-check-circle"></i>
                  <span><%= feature %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- Certifications & Accreditations -->
  <section class="py-16 bg-white md:py-24 dark:bg-gray-800">
    <div class="container px-4 mx-auto sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto mb-16 text-center">
        <h2 class="mb-6 text-3xl font-bold text-gray-800 md:text-4xl dark:text-white">
          Certifications & Accreditations
        </h2>
        <p class="text-gray-600 dark:text-gray-300">
          Our commitment to quality and safety is validated by certifications from leading healthcare authorities.
        </p>
      </div>
      
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 md:gap-6">
        <% const certifications = [
          { name: 'ISO 9001:2015', org: 'Quality Management', icon: 'fa-certificate' },
          { name: 'FDA Approved', org: 'Drugs Control', icon: 'fa-pills' },
          { name: 'GST Registered', org: 'Govt. of India', icon: 'fa-file-contract' },
          { name: 'PCI Licensed', org: 'Pharmacy Council', icon: 'fa-award' }
        ] %>
        
        <% certifications.forEach(cert => { %>
          <div class="flex items-center gap-4 p-4 text-left transition-transform duration-300 border border-gray-100 shadow-sm rounded-2xl bg-gray-50 hover:-translate-y-1 hover:shadow-lg dark:border-gray-700 dark:bg-gray-900/60">
            <div class="flex items-center justify-center w-16 h-16 shrink-0 rounded-2xl bg-gradient-to-r from-green-100 to-teal-100 dark:from-gray-700 dark:to-gray-600 sm:h-20 sm:w-20">
              <i class="fa-solid <%= cert.icon %> text-2xl text-green-600 dark:text-green-400 sm:text-3xl"></i>
            </div>
            <div class="min-w-0">
              <div class="text-base font-bold leading-tight text-gray-800 sm:text-lg dark:text-white">
                <%= cert.name %>
              </div>
              <div class="mt-1 text-sm leading-snug text-gray-600 dark:text-gray-400">
                <%= cert.org %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-green-50 to-teal-50 dark:from-gray-800 dark:to-gray-700">
    <div class="container px-4 mx-auto sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="mb-6 text-3xl font-bold text-gray-800 md:text-4xl dark:text-white">
          Ready to Experience Quality Healthcare?
        </h2>
        
        <p class="max-w-2xl mx-auto mb-8 text-lg text-gray-600 dark:text-gray-300">
          Visit BrightLife Pharmacy today or contact us for expert medical guidance. 
          Your health journey begins with us.
        </p>
        
        <div class="flex flex-col justify-center gap-4 sm:flex-row">
          <a href="/contact" 
             class="flex items-center justify-center px-8 py-4 font-bold text-center text-white transition-all duration-300 bg-gradient-to-r from-green-600 to-teal-500 rounded-xl hover:shadow-2xl hover:scale-105">
            <i class="mr-3 fa-solid fa-location-dot"></i>
            Visit Our Pharmacy
          </a>
          
          <a href="tel:+911234567890" 
             class="flex items-center justify-center px-8 py-4 font-bold text-center text-green-600 transition-all duration-300 bg-white border-2 border-green-500 dark:bg-gray-800 dark:text-green-400 rounded-xl hover:bg-green-50 dark:hover:bg-green-900/20">
            <i class="mr-3 fa-solid fa-phone"></i>
            Call: +91 12345 67890
          </a>
        </div>
        
        <!-- Pharmacy Info -->
        <div class="pt-8 mt-12 border-t border-gray-300 dark:border-gray-600">
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            <div class="text-center">
              <div class="mb-2 text-2xl font-bold text-green-600 dark:text-green-400">
                <i class="fa-solid fa-clock"></i>
              </div>
              <div class="font-medium text-gray-800 dark:text-white">8:00 AM - 10:00 PM</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">Monday - Saturday</div>
            </div>
            
            <div class="text-center">
              <div class="mb-2 text-2xl font-bold text-green-600 dark:text-green-400">
                <i class="fa-solid fa-location-dot"></i>
              </div>
              <div class="font-medium text-gray-800 dark:text-white">123 Medical Street</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">Mumbai, Maharashtra 400001</div>
            </div>
            
            <div class="text-center">
              <div class="mb-2 text-2xl font-bold text-green-600 dark:text-green-400">
                <i class="fa-solid fa-envelope"></i>
              </div>
              <div class="font-medium text-gray-800 dark:text-white">info@brightlifepharmacy.com</div>
              <div class="text-sm text-gray-600 dark:text-gray-400">Email Us Anytime</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

