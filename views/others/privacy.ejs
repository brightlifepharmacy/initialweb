<% layout("/layouts/boilerplate") -%>

<div class="py-8 min-h-screen flex items-center justify-center 
            bg-gradient-to-r from-green-300 via-green-50 to-green-200 
            dark:bg-gradient-to-r dark:from-gray-900 dark:via-gray-800 dark:to-gray-900
            px-4 transition-all">

  <div class="w-full max-w-3xl">

    <!-- Card -->
    <div class="bg-white/30 dark:bg-gray-600/40 backdrop-blur-lg 
                rounded-2xl shadow-lg p-10 border 
                border-white/30 dark:border-gray-700/40 
                animate-fadeIn transition-all duration-300">

      <!-- Heading -->
      <h1 class="text-4xl font-bold text-center mb-6 text-gray-800 dark:text-white">
        Privacy Policy
      </h1>

      <!-- Content -->
      <div class="space-y-5 text-gray-700 dark:text-gray-300 text-lg leading-relaxed">

        <p>
          At BrightLife Pharmacy, your privacy is our top priority. We are committed to protecting 
          any information you provide while using our website, including order, account, and contact details.
        </p>

        <h2 class="text-2xl font-semibold mt-6 mb-3 text-gray-800 dark:text-white">
          🔒 Information We Collect
        </h2>

        <ul class="list-disc pl-5 space-y-2">
          <li>Account and registration information such as name, email, and phone number.</li>
          <li>Shipping and billing address information required for order fulfillment.</li>
          <li>Order history and product preferences to improve your shopping experience.</li>
          <li>Device and browser information to help maintain site security and performance.
          </li>
        </ul>

        <h2 class="text-2xl font-semibold mt-6 mb-3 text-gray-800 dark:text-white">
          🛡️ How We Use Your Information
        </h2>

        <ul class="list-disc pl-5 space-y-2">
          <li>To process and deliver orders placed through brightlifepharmacy.com.</li>
          <li>To communicate order updates, offers, and health advice.</li>
          <li>To improve website performance and make our services more relevant to you.</li>
          <li>To comply with legal requirements and protect against fraud.</li>
        </ul>

        <h2 class="text-2xl font-semibold mt-6 mb-3 text-gray-800 dark:text-white">
          🔐 Data Security
        </h2>

        <p>
          We protect your personal information with industry-standard security measures and limit access to authorized personnel only.
        </p>

        <h2 class="text-2xl font-semibold mt-6 mb-3 text-gray-800 dark:text-white">
          🌐 Third-Party Services
        </h2>

        <p>
          BrightLife Pharmacy works with trusted third parties for payment processing, delivery, and analytics. We do not sell your personal data.
        </p>

        <h2 class="text-2xl font-semibold mt-6 mb-3 text-gray-800 dark:text-white">
          📄 Your Rights
        </h2>

        <p>
          You may request updates to your personal data or opt out of marketing emails at any time.
        </p>

        <h2 class="text-2xl font-semibold mt-6 mb-3 text-gray-800 dark:text-white">
          📩 Contact Us
        </h2>

        <p>
          If you have any questions or concerns about privacy, please reach out to us at <a href="mailto:info@brightlifepharmacy.com" class="text-green-600 dark:text-green-400 hover:underline">info@brightlifepharmacy.com</a>.
        </p>

      </div>

      <!-- Back to Home -->
      <div class="text-center mt-10">
        <a href="/"
           class="px-6 py-3 rounded-2xl bg-green-500 hover:bg-green-600 
                  dark:bg-green-600 dark:hover:bg-green-500 text-white text-lg font-medium transition-all">
          Go Back Home
        </a>
      </div>

    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(.92); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-fadeIn { animation: fadeIn 0.25s ease-out; }
</style>
