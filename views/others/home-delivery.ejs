<% layout("/layouts/boilerplate") -%>

<section class="py-16 bg-gradient-to-b from-blue-50 via-white to-gray-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-600 dark:text-blue-400">Convenient Healthcare</p>
      <h1 class="mt-3 text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">Home Delivery Service</h1>
      <p class="mt-4 text-base leading-8 text-gray-600 dark:text-gray-300">
        We bring quality medicines and healthcare products directly to your doorstep. Fast, reliable, and discreet delivery across the city.
      </p>
    </div>

    <div class="grid max-w-5xl grid-cols-1 gap-6 mx-auto mt-12 md:grid-cols-3">
      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 text-blue-600 bg-blue-100 rounded-xl dark:bg-blue-900/30 dark:text-blue-300">
          <i class="text-xl fa-solid fa-truck-fast"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Same Day Delivery</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Orders placed before 2 PM are delivered the same day. Emergency orders prioritized for immediate dispatch.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 text-teal-600 bg-teal-100 rounded-xl dark:bg-teal-900/30 dark:text-teal-300">
          <i class="text-xl fa-solid fa-lock"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Secure & Discreet</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Medicines delivered in plain packaging. Your privacy and confidentiality are our top priority.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-cyan-100 text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-300">
          <i class="text-xl fa-solid fa-headset"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">24/7 Support</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Track your order, get updates, and reach our support team anytime for delivery assistance.
        </p>
      </article>
    </div>

    <div class="max-w-5xl p-6 mx-auto mt-10 bg-white border border-blue-100 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Delivery Coverage</h2>
      <ul class="mt-4 space-y-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
        <li class="flex items-start">
          <i class="mt-1 mr-2 text-blue-600 fa-solid fa-check dark:text-blue-400"></i>
          Entire city and surrounding areas within 10 km radius.
        </li>
        <li class="flex items-start">
          <i class="mt-1 mr-2 text-blue-600 fa-solid fa-check dark:text-blue-400"></i>
          Free delivery on orders above ₹500, otherwise minimal delivery charges.
        </li>
        <li class="flex items-start">
          <i class="mt-1 mr-2 text-blue-600 fa-solid fa-check dark:text-blue-400"></i>
          COD available — pay when you receive your order.
        </li>
      </ul>

      <div class="flex flex-col gap-3 mt-6 sm:flex-row">
        <a href="/products" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold text-white transition-colors bg-blue-600 rounded-lg hover:bg-blue-700">
          Order Now
          <i class="ml-2 fa-solid fa-arrow-right"></i>
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold text-blue-600 transition-colors border border-blue-500 rounded-lg hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/20">
          Track Order
        </a>
      </div>
    </div>
  </div>
</section>
