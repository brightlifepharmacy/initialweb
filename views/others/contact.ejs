        </div>

        <!-- Pharmacy Contact -->
        <div class="bg-gradient-to-r from-green-50 to-teal-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-6 border border-green-200 dark:border-gray-600">
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-phone text-green-600 dark:text-green-400 text-xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-2">Pharmacy Contact</h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">
