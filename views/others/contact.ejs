    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Emergency Contact -->
        <div class="bg-gradient-to-r from-red-50 to-red-100 dark:from-red-900/20 dark:to-red-800/20 rounded-2xl p-6 border border-red-200 dark:border-red-800">
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-red-100 dark:bg-red-900/30 rounded-xl flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-phone-emergency text-red-600 dark:text-red-400 text-xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-2">Emergency Contact</h3>
