          <span class="block bg-gradient-to-r from-green-600 to-teal-500 bg-clip-text text-transparent">With Our Pharmacy</span>
        </h1>
        
        <p class="text-gray-600 dark:text-gray-300 text-lg max-w-2xl mx-auto">
          Have questions about medicines, need expert consultation, or want to visit our pharmacy? 
          We're here to help you 24/7.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Information -->
