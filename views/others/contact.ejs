<% layout("/layouts/boilerplate") %>

<%
  const contact = typeof contactInfo !== 'undefined' && contactInfo ? contactInfo : {
    phone: '+91 12345 67890',
    emergencyPhone: '+91 98765 43210',
    email: 'info@brightlifepharmacy.com',
    address: '123 Medical Street, Health District\nMumbai, Maharashtra 400001',
    whatsappPhone: '+911234567890',
    openingHoursWeekdays: 'Monday - Saturday: 8:00 AM - 10:00 PM',
    openingHoursSunday: 'Sunday: 9:00 AM - 9:00 PM',
    emergencyNote: '24/7 Emergency Services Available',
  };
  const addressMarkup = typeof addressHtml !== 'undefined' && addressHtml ? addressHtml : String(contact.address || '').replace(/\n/g, '<br>');
  const mapEmbedUrl = typeof mapSrc !== 'undefined' && mapSrc ? mapSrc : `https://www.google.com/maps?q=${encodeURIComponent(contact.address || '')}&output=embed`;
%>

<!-- Contact Page -->
