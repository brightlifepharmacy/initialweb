<% layout("/layouts/boilerplate") -%>

<section class="py-16 bg-gradient-to-b from-teal-50 via-white to-gray-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-600 dark:text-teal-400">Medical Essentials</p>
      <h1 class="mt-3 text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">Surgical Supply</h1>
      <p class="mt-4 text-base leading-8 text-gray-600 dark:text-gray-300">
        We provide reliable surgical supplies for clinics, hospitals, and home care, with a focus on quality, sterility, and safe handling.
      </p>
    </div>

    <div class="grid max-w-5xl grid-cols-1 gap-6 mx-auto mt-12 md:grid-cols-3">
      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 text-teal-600 bg-teal-100 rounded-xl dark:bg-teal-900/30 dark:text-teal-300">
          <i class="text-xl fa-solid fa-shield-virus"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Sterile Products</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Gloves, gauze, syringes, and dressings are handled with hygiene and storage standards.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 text-green-600 bg-green-100 rounded-xl dark:bg-green-900/30 dark:text-green-300">
          <i class="text-xl fa-solid fa-truck-medical"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Bulk Availability</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          We support regular and bulk requirements for hospitals and nursing facilities.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 text-orange-600 bg-orange-100 rounded-xl dark:bg-orange-900/30 dark:text-orange-300">
          <i class="text-xl fa-solid fa-circle-check"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Quality Guidance</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Get help choosing correct sizes, types, and usage methods from our pharmacy team.
        </p>
      </article>
    </div>

    <div class="max-w-5xl p-6 mx-auto mt-10 bg-white border border-teal-100 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Common Surgical Supplies</h2>
      <ul class="mt-4 space-y-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
        <li class="flex items-start">
          <i class="mt-1 mr-2 text-teal-600 fa-solid fa-check dark:text-teal-400"></i>
          Surgical gloves, masks, and caps.
        </li>
        <li class="flex items-start">
          <i class="mt-1 mr-2 text-teal-600 fa-solid fa-check dark:text-teal-400"></i>
          Sterile gauze, bandages, and dressing packs.
        </li>
        <li class="flex items-start">
          <i class="mt-1 mr-2 text-teal-600 fa-solid fa-check dark:text-teal-400"></i>
          Disposable syringes and infusion accessories.
        </li>
      </ul>

      <div class="flex flex-col gap-3 mt-6 sm:flex-row">
        <a href="/products?category=surgical" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold text-white transition-colors bg-teal-600 rounded-lg hover:bg-teal-700">
          View Surgical Products
          <i class="ml-2 fa-solid fa-arrow-right"></i>
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold text-teal-600 transition-colors border border-teal-500 rounded-lg hover:bg-teal-50 dark:text-teal-400 dark:hover:bg-teal-900/20">
          Contact Pharmacy
        </a>
      </div>
    </div>
  </div>
</section>
