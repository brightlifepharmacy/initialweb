<% layout("/layouts/boilerplate") -%>

<section class="py-16 bg-gradient-to-b from-emerald-50 via-white to-gray-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Emergency Care Essentials</p>
      <h1 class="mt-3 text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">First Aid Kits</h1>
      <p class="mt-4 text-base leading-8 text-gray-600 dark:text-gray-300">
        Ready-to-use first aid kits for home, travel, offices, and clinics, designed for quick response during common injuries.
      </p>
    </div>

    <div class="grid max-w-5xl grid-cols-1 gap-6 mx-auto mt-12 md:grid-cols-3">
      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-300">
          <i class="text-xl fa-solid fa-briefcase-medical"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Complete Essentials</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Includes bandages, antiseptic wipes, gauze, cotton, adhesive tape, and basic tools.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 text-teal-600 bg-teal-100 rounded-xl dark:bg-teal-900/30 dark:text-teal-300">
          <i class="text-xl fa-solid fa-house-medical"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Home & Office Use</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Compact and practical options suitable for households, schools, and workplace setups.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-cyan-100 text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-300">
          <i class="text-xl fa-solid fa-user-doctor"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Usage Guidance</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Get support on what to keep, how to restock, and how to use items safely.
        </p>
      </article>
    </div>

    <div class="max-w-5xl p-6 mx-auto mt-10 bg-white border shadow-sm rounded-2xl border-emerald-100 dark:border-gray-700 dark:bg-gray-800">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">What to Check Regularly</h2>
      <ul class="mt-4 space-y-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
        <li class="flex items-start">
          <i class="mt-1 mr-2 fa-solid fa-check text-emerald-600 dark:text-emerald-400"></i>
          Expiry dates of antiseptics, pain-relief tablets, and ointments.
        </li>
        <li class="flex items-start">
          <i class="mt-1 mr-2 fa-solid fa-check text-emerald-600 dark:text-emerald-400"></i>
          Quantity of bandages, gauze, and sterile pads after each use.
        </li>
        <li class="flex items-start">
          <i class="mt-1 mr-2 fa-solid fa-check text-emerald-600 dark:text-emerald-400"></i>
          Clean and dry storage to maintain safety and usability.
        </li>
      </ul>

      <div class="flex flex-col gap-3 mt-6 sm:flex-row">
        <a href="/products?category=first-aid" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold text-white transition-colors rounded-lg bg-emerald-600 hover:bg-emerald-700">
          Browse First Aid Products
          <i class="ml-2 fa-solid fa-arrow-right"></i>
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold transition-colors border rounded-lg border-emerald-500 text-emerald-600 hover:bg-emerald-50 dark:text-emerald-400 dark:hover:bg-emerald-900/20">
          Contact Pharmacy
        </a>
      </div>
    </div>
  </div>
</section>
