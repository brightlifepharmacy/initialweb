<% layout("/layouts/boilerplate") -%>

<div class="min-h-screen py-10 bg-gradient-to-b from-green-100 to-white dark:from-gray-950 dark:to-gray-900">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto bg-white dark:bg-gray-900 shadow-xl rounded-3xl p-8 border border-green-100 dark:border-gray-800">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">Frequently Asked Questions</h1>
      <p class="text-gray-600 dark:text-gray-300 mb-8">Answers to common questions about BrightLife Pharmacy services, orders, and support.</p>

      <section class="space-y-6">
        <div class="rounded-3xl border border-gray-200 dark:border-gray-700 p-6 bg-gray-50 dark:bg-gray-800">
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">How do I place an order?</h2>
          <p class="mt-3 text-gray-600 dark:text-gray-300">Browse our products from the Products page, select the items you need, and complete the checkout form. You can also contact us directly for prescription support.</p>
        </div>

        <div class="rounded-3xl border border-gray-200 dark:border-gray-700 p-6 bg-gray-50 dark:bg-gray-800">
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">Can I request home delivery?</h2>
          <p class="mt-3 text-gray-600 dark:text-gray-300">Yes. We offer home delivery across our service area. Visit the Home Delivery page for details and delivery times.</p>
        </div>

        <div class="rounded-3xl border border-gray-200 dark:border-gray-700 p-6 bg-gray-50 dark:bg-gray-800">
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">What is your customer support email?</h2>
          <p class="mt-3 text-gray-600 dark:text-gray-300">Reach us anytime at <a href="mailto:info@brightlifepharmacy.com" class="text-green-600 dark:text-green-400 underline">info@brightlifepharmacy.com</a>.</p>
        </div>

        <div class="rounded-3xl border border-gray-200 dark:border-gray-700 p-6 bg-gray-50 dark:bg-gray-800">
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">Do you accept prescriptions?</h2>
          <p class="mt-3 text-gray-600 dark:text-gray-300">Yes, we accept valid prescriptions for prescription medicines. Please attach your prescription with your order or contact our support team.</p>
        </div>

        <div class="rounded-3xl border border-gray-200 dark:border-gray-700 p-6 bg-gray-50 dark:bg-gray-800">
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">How can I track my order?</h2>
          <p class="mt-3 text-gray-600 dark:text-gray-300">Order tracking information is shared via email after your order is confirmed. For further updates, email <a href="mailto:info@brightlifepharmacy.com" class="text-green-600 dark:text-green-400 underline">info@brightlifepharmacy.com</a>.</p>
        </div>
      </section>

      <div class="mt-10 text-center">
        <a href="/" class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-green-600 text-white font-semibold hover:bg-green-700 transition-all">Back to Home</a>
      </div>
    </div>
  </div>
</div>
