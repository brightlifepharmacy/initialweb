<% layout("/layouts/boilerplate") -%>

<div class="min-h-screen py-10 bg-gradient-to-b from-green-100 to-white dark:from-gray-950 dark:to-gray-900">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto bg-white dark:bg-gray-900 shadow-xl rounded-3xl p-8 border border-green-100 dark:border-gray-800">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">Refund Policy</h1>
      <p class="text-gray-600 dark:text-gray-300 mb-8">We want you to feel confident with your purchase from BrightLife Pharmacy. Read our refund policy below.</p>

      <div class="space-y-6 text-gray-700 dark:text-gray-300 text-base">
        <div>
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">1. Eligibility</h2>
          <p class="mt-3">Refunds are available for items that are damaged, defective, or incorrectly shipped. Prescription medicines may be subject to additional verification and cannot be refunded if the seal is broken for safety reasons.</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">2. Request Window</h2>
          <p class="mt-3">Submit refund requests within 7 days of delivery. Please include your order number and a description of the issue.</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">3. How to Request</h2>
          <p class="mt-3">Email us at <a href="mailto:info@brightlifepharmacy.com" class="text-green-600 dark:text-green-400 underline">info@brightlifepharmacy.com</a> with your order details. Our support team will respond with next steps.</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">4. Approval Process</h2>
          <p class="mt-3">We review refund requests within 2 business days. Approved refunds will be issued via the original payment method.</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">5. Exceptions</h2>
          <p class="mt-3">Opened or used personal care products, custom orders, and medical devices that are not defective may not be eligible for refund.</p>
        </div>
      </div>

      <div class="mt-10 text-center">
        <a href="/" class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-green-600 text-white font-semibold hover:bg-green-700 transition-all">Back to Home</a>
      </div>
    </div>
  </div>
</div>
