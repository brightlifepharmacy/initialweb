<% layout("/layouts/boilerplate") -%>

<section class="py-16 bg-gradient-to-b from-white via-emerald-50 to-gray-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Preventive Care</p>
      <h1 class="mt-3 text-3xl font-bold text-gray-900 dark:text-white md:text-4xl">Health Checkups</h1>
      <p class="mt-4 text-base leading-8 text-gray-600 dark:text-gray-300">
        Comprehensive health checkup packages for individuals, families, and corporate employees. Early detection and routine monitoring to keep you healthy.
      </p>
    </div>

    <div class="grid max-w-5xl grid-cols-1 gap-6 mx-auto mt-12 md:grid-cols-3">
      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-300">
          <i class="text-xl fa-solid fa-heart-pulse"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Basic Health Package</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Includes general physician consultation, basic blood tests, and BMI check.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 text-teal-600 bg-teal-100 rounded-xl dark:bg-teal-900/30 dark:text-teal-300">
          <i class="text-xl fa-solid fa-microscope"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Advanced Screening</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Targeted tests including lipid profile, liver & kidney function, and diabetes screening.
        </p>
      </article>

      <article class="p-6 bg-white border border-gray-200 shadow-sm rounded-2xl dark:border-gray-700 dark:bg-gray-800">
        <div class="inline-flex items-center justify-center w-12 h-12 mb-4 rounded-xl bg-cyan-100 text-cyan-600 dark:bg-cyan-900/30 dark:text-cyan-300">
          <i class="text-xl fa-solid fa-briefcase-medical"></i>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Corporate Plans</h2>
        <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
          Customizable corporate packages with on-site camps and consolidated reporting.
        </p>
      </article>
    </div>

    <div class="max-w-5xl p-6 mx-auto mt-10 bg-white border shadow-sm rounded-2xl border-emerald-100 dark:border-gray-700 dark:bg-gray-800">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">How to Book</h2>
      <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">Call us or use the contact form to schedule a checkup. We will guide you on fasting instructions and sample collection timings if required.</p>

      <div class="flex flex-col gap-3 mt-6 sm:flex-row">
        <a href="/contact" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold text-white transition-colors rounded-lg bg-emerald-600 hover:bg-emerald-700">
          Schedule a Checkup
          <i class="ml-2 fa-solid fa-arrow-right"></i>
        </a>
        <a href="/products?category=devices" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold transition-colors border rounded-lg border-emerald-500 text-emerald-600 hover:bg-emerald-50 dark:text-emerald-400 dark:hover:bg-emerald-900/20">
          Browse Monitoring Devices
        </a>
      </div>
    </div>
  </div>
</section>
