  <!-- Smooth Theme Transition -->
  <style>
    html, body {
      transition: background-color 0.25s, color 0.25s;
    }
    
    /* Additional custom styles */
    :root {
      --primary-green: #2E7D32;
      --primary-gold: #C99A2E;
      --primary-dark: #111B15;
      --primary-light: #F7F8F5;
    }
    
    .dark {
      background-color: #0E1712;
      color: #E9F2E7;
    }
    
    /* Smooth scroll behavior */
    html {
      scroll-behavior: smooth;
    }
    
    /* Focus styles for accessibility */
    *:focus-visible {
      outline: 2px solid #2E7D32;
      outline-offset: 2px;
    }
    
    .dark *:focus-visible {
      outline-color: #66BB6A;
    }
    
    /* Selection color */
    ::selection {
      background: #2E7D32;
      color: white;
    }
    
    .dark ::selection {
      background: #66BB6A;
      color: #0E1712;
    }
    
    /* Scrollbar styling */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    
    ::-webkit-scrollbar-track {
      background: #F7F8F5;
    }
    
    .dark ::-webkit-scrollbar-track {
      background: #0E1712;
    }
    
    ::-webkit-scrollbar-thumb {
      background: #2E7D32;
      border-radius: 4px;
    }
    
    .dark ::-webkit-scrollbar-thumb {
      background: #3F9142;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: #1B5E20;
    }
    
    .dark ::-webkit-scrollbar-thumb:hover {
      background: #4CAF50;
    }
  </style>

  <!-- Dark mode detection -->
  <script>
    // Check for saved theme preference
    if (localStorage.theme === "dark") {
      document.documentElement.classList.add("dark");
    } else if (localStorage.theme === "light") {
      document.documentElement.classList.remove("dark");
    } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
      document.documentElement.classList.add("dark");
    }
    
    // Prevent flash of wrong theme
    document.addEventListener('DOMContentLoaded', function() {
      // Theme is already set
    });
  </script>
</head>

<body class="bg-[#F7F8F5] dark:bg-[#0E1712] text-[#12261A] dark:text-[#E9F2E7] transition-colors duration-300 min-h-screen font-body">
  
