<!-- signup.ejs -->
<% layout("/layouts/boilerplate") -%>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">

<style>
  .font-display { font-family: 'Fraunces', serif; }
  .font-body { font-family: 'Inter', sans-serif; }
  .font-mono { font-family: 'IBM Plex Mono', monospace; }

  /* Signup Card Styles */
  .signup-card {
    animation: slideUp 0.6s ease-out;
  }
  
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Input Focus Effects */
  .signup-input {
    transition: all 0.3s ease;
  }
  
  .signup-input:focus {
    box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.1);
  }
  
  /* Password Strength Bar */
  .strength-bar {
    height: 3px;
    border-radius: 2px;
    transition: all 0.3s ease;
    background: #E3E8E1;
  }
  
  .dark .strength-bar {
    background: #2A3A31;
  }
  
  .strength-bar.weak {
    background: #EF5350;
    width: 33%;
  }
  
  .strength-bar.medium {
    background: #FFA726;
    width: 66%;
  }
  
  .strength-bar.strong {
    background: #66BB6A;
    width: 100%;
  }
  
  /* Social Login Buttons */
  .social-btn {
    transition: all 0.3s ease;
  }
  
  .social-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.08);
  }
  
  /* Password Toggle */
  .password-toggle {
    cursor: pointer;
    transition: color 0.2s;
  }
  
  .password-toggle:hover {
    color: #2E7D32;
  }
  
  .dark .password-toggle:hover {
    color: #66BB6A;
  }
  
  /* Divider */
  .divider::before,
  .divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: #E3E8E1;
  }
  
  .dark .divider::before,
  .dark .divider::after {
    background: #22302A;
  }
  
  /* Password Requirements */
  .requirement {
    transition: all 0.3s ease;
  }
  
  .requirement.valid {
    color: #66BB6A;
  }
  
  .requirement.invalid {
    color: #EF5350;
  }
</style>

<main class="font-body min-h-screen bg-[#F7F8F5] dark:bg-[#0E1712] text-[#12261A] dark:text-[#E9F2E7] transition-colors duration-300 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  
  <!-- Decorative Background -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-[#2E7D32] via-[#C99A2E] to-[#2E7D32] dark:from-[#4CAF50] dark:via-[#E3C069] dark:to-[#4CAF50] opacity-60"></div>
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 dark:opacity-5 pointer-events-none">
    <div class="absolute top-20 right-20 w-64 h-64 rounded-full bg-[#2E7D32] blur-3xl"></div>
    <div class="absolute bottom-20 right-40 w-96 h-96 rounded-full bg-[#C99A2E] blur-3xl"></div>
  </div>
  
  <div class="w-full max-w-md relative">
    
    <!-- Logo -->
    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2.5">
        <div class="w-12 h-12 rounded-xl bg-[#E8F5E9] dark:bg-[#1D2E21] flex items-center justify-center p-1.5">
          <img src="images/logo2.png" alt="Bright-Life Pharmacy logo" class="w-full h-full object-contain" />
        </div>
        <div class="leading-tight">
          <p class="font-display font-semibold text-lg text-[#12261A] dark:text-[#F2F8F0]">Bright-Life</p>
          <p class="text-[11px] font-mono text-[#4B5C50] dark:text-[#8FA393] -mt-0.5">Pharmacy</p>
        </div>
      </a>
    </div>
    
    <!-- Signup Card -->
    <div class="signup-card bg-white dark:bg-[#111B15] rounded-2xl border border-[#E3E8E1] dark:border-[#22302A] shadow-lg p-6 sm:p-8">
      
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="font-display text-2xl font-bold text-[#12261A] dark:text-[#F2F8F0]">
          Create Account
        </h1>
        <p class="text-sm text-[#4B5C50] dark:text-[#8FA393] mt-2">
          Join Bright-Life Pharmacy for personalized healthcare
        </p>
      </div>
      
      <!-- Signup Form -->
      <form id="signup-form" class="space-y-4">
        
        <!-- Full Name -->
        <div>
          <label for="fullname" class="block text-sm font-medium text-[#12261A] dark:text-[#E9F2E7] mb-1.5">
            Full Name *
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fa-regular fa-user text-[#8A978C] dark:text-[#6E8175]"></i>
            </div>
            <input type="text" id="fullname" required
              class="signup-input w-full pl-10 pr-4 py-3 rounded-xl border border-[#E3E8E1] dark:border-[#2A3A31] bg-[#F7F8F5] dark:bg-[#16211A] text-sm text-[#12261A] dark:text-[#E9F2E7] placeholder-[#8A978C] dark:placeholder-[#6E8175] focus:outline-none focus:ring-2 focus:ring-[#2E7D32]/40 dark:focus:ring-[#4CAF50]/40 transition-all"
              placeholder="John Doe">
          </div>
        </div>
        
        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-[#12261A] dark:text-[#E9F2E7] mb-1.5">
            Email Address *
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fa-regular fa-envelope text-[#8A978C] dark:text-[#6E8175]"></i>
            </div>
            <input type="email" id="email" required
              class="signup-input w-full pl-10 pr-4 py-3 rounded-xl border border-[#E3E8E1] dark:border-[#2A3A31] bg-[#F7F8F5] dark:bg-[#16211A] text-sm text-[#12261A] dark:text-[#E9F2E7] placeholder-[#8A978C] dark:placeholder-[#6E8175] focus:outline-none focus:ring-2 focus:ring-[#2E7D32]/40 dark:focus:ring-[#4CAF50]/40 transition-all"
              placeholder="john@example.com">
          </div>
        </div>
        
        <!-- Password -->
        <div>
          <label for="password" class="block text-sm font-medium text-[#12261A] dark:text-[#E9F2E7] mb-1.5">
            Password *
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fa-solid fa-lock text-[#8A978C] dark:text-[#6E8175]"></i>
            </div>
            <input type="password" id="password" required
              class="signup-input w-full pl-10 pr-12 py-3 rounded-xl border border-[#E3E8E1] dark:border-[#2A3A31] bg-[#F7F8F5] dark:bg-[#16211A] text-sm text-[#12261A] dark:text-[#E9F2E7] placeholder-[#8A978C] dark:placeholder-[#6E8175] focus:outline-none focus:ring-2 focus:ring-[#2E7D32]/40 dark:focus:ring-[#4CAF50]/40 transition-all"
              placeholder="Create a strong password">
            <button type="button" id="password-toggle" class="password-toggle absolute inset-y-0 right-0 pr-3 flex items-center text-[#8A978C] dark:text-[#6E8175] hover:text-[#2E7D32] dark:hover:text-[#66BB6A] transition-colors">
              <i class="fa-regular fa-eye" id="password-icon"></i>
            </button>
          </div>
          
          <!-- Password Strength -->
          <div class="mt-2">
            <div class="strength-bar" id="strength-bar"></div>
            <div class="flex justify-between mt-1">
              <span class="text-xs text-[#4B5C50] dark:text-[#8FA393]" id="strength-text">Enter a password</span>
              <span class="text-xs text-[#4B5C50] dark:text-[#8FA393]" id="strength-label"></span>
            </div>
          </div>
          
          <!-- Password Requirements -->
          <div class="mt-3 space-y-1">
            <p class="text-xs font-medium text-[#4B5C50] dark:text-[#8FA393]">Password must have:</p>
            <div class="requirement text-xs text-[#4B5C50] dark:text-[#8FA393]" id="req-length">
              <i class="fa-regular fa-circle mr-1.5"></i> At least 8 characters
            </div>
            <div class="requirement text-xs text-[#4B5C50] dark:text-[#8FA393]" id="req-uppercase">
              <i class="fa-regular fa-circle mr-1.5"></i> At least 1 uppercase letter
            </div>
            <div class="requirement text-xs text-[#4B5C50] dark:text-[#8FA393]" id="req-number">
              <i class="fa-regular fa-circle mr-1.5"></i> At least 1 number
            </div>
          </div>
        </div>
        
        <!-- Confirm Password -->
        <div>
          <label for="confirm-password" class="block text-sm font-medium text-[#12261A] dark:text-[#E9F2E7] mb-1.5">
            Confirm Password *
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fa-solid fa-shield text-[#8A978C] dark:text-[#6E8175]"></i>
            </div>
            <input type="password" id="confirm-password" required
              class="signup-input w-full pl-10 pr-4 py-3 rounded-xl border border-[#E3E8E1] dark:border-[#2A3A31] bg-[#F7F8F5] dark:bg-[#16211A] text-sm text-[#12261A] dark:text-[#E9F2E7] placeholder-[#8A978C] dark:placeholder-[#6E8175] focus:outline-none focus:ring-2 focus:ring-[#2E7D32]/40 dark:focus:ring-[#4CAF50]/40 transition-all"
              placeholder="Confirm your password">
          </div>
          <div id="confirm-match" class="mt-1 text-xs hidden"></div>
        </div>
        
        <!-- Terms & Conditions -->
        <div class="flex items-start gap-2 pt-1">
          <input type="checkbox" id="terms" required
            class="mt-0.5 w-4 h-4 rounded border-[#E3E8E1] dark:border-[#22302A] text-[#2E7D32] focus:ring-[#2E7D32] dark:focus:ring-[#4CAF50] transition-colors">
          <label for="terms" class="text-xs text-[#4B5C50] dark:text-[#8FA393] leading-relaxed">
            I agree to the 
            <a href="#" class="text-[#2E7D32] dark:text-[#66BB6A] hover:underline transition-colors">Terms of Service</a>
            and 
            <a href="#" class="text-[#2E7D32] dark:text-[#66BB6A] hover:underline transition-colors">Privacy Policy</a>
          </label>
        </div>
        
        <!-- Submit Button -->
        <button type="submit" 
          class="w-full py-3.5 bg-[#2E7D32] hover:bg-[#276b2b] dark:bg-[#3F9142] dark:hover:bg-[#4CAF50] text-white font-medium rounded-xl transition-all duration-300 hover:shadow-lg hover:scale-[1.02]">
          <span id="signup-btn-text">Create Account</span>
          <i class="fa-solid fa-spinner fa-spin hidden" id="signup-spinner"></i>
        </button>
        
        <!-- Response Message -->
        <div id="signup-response" class="hidden text-center text-sm py-2 rounded-lg"></div>
      </form>
      
      <!-- Divider -->
      <div class="divider flex items-center gap-4 my-6">
        <span class="text-xs text-[#4B5C50] dark:text-[#8FA393] whitespace-nowrap">or sign up with</span>
      </div>
      
      <!-- Social Signup -->
      <div class="grid grid-cols-1">
        <button class="social-btn flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-[#E3E8E1] dark:border-[#22302A] bg-white dark:bg-[#16211A] text-sm font-medium text-[#12261A] dark:text-[#E9F2E7] hover:bg-[#F0F4EE] dark:hover:bg-[#1D2E21] transition-all">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Google
        </button>
        <!-- <button class="social-btn flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-[#E3E8E1] dark:border-[#22302A] bg-white dark:bg-[#16211A] text-sm font-medium text-[#12261A] dark:text-[#E9F2E7] hover:bg-[#F0F4EE] dark:hover:bg-[#1D2E21] transition-all">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989C18.343 21.129 22 16.99 22 12z" fill="#1877F2"/>
          </svg>
          Facebook
        </button> -->
      </div>
      
      <!-- Login Link -->
      <p class="text-center text-sm text-[#4B5C50] dark:text-[#8FA393] mt-6">
        Already have an account? 
        <a href="/login" class="font-medium text-[#2E7D32] dark:text-[#66BB6A] hover:underline transition-colors">
          Sign in
        </a>
      </p>
    </div>
    
    <!-- Footer Note -->
    <p class="text-center text-xs text-[#8A978C] dark:text-[#6E8175] mt-6">
      By creating an account, you agree to our Terms of Service and Privacy Policy
    </p>
  </div>
</main>

<script>
  // ===================== PASSWORD TOGGLE =====================
  const passwordToggle = document.getElementById('password-toggle');
  const passwordInput = document.getElementById('password');
  const passwordIcon = document.getElementById('password-icon');
  
  passwordToggle?.addEventListener('click', function() {
    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordInput.setAttribute('type', type);
    passwordIcon.className = type === 'password' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
  });

  // ===================== PASSWORD STRENGTH =====================
  const passwordField = document.getElementById('password');
  const strengthBar = document.getElementById('strength-bar');
  const strengthText = document.getElementById('strength-text');
  const strengthLabel = document.getElementById('strength-label');
  
  const reqLength = document.getElementById('req-length');
  const reqUppercase = document.getElementById('req-uppercase');
  const reqNumber = document.getElementById('req-number');
  
  function checkPasswordStrength(password) {
    let strength = 0;
    let checks = {
      length: password.length >= 8,
      uppercase: /[A-Z]/.test(password),
      number: /[0-9]/.test(password)
    };
    
    // Update requirements
    updateRequirement(reqLength, checks.length);
    updateRequirement(reqUppercase, checks.uppercase);
    updateRequirement(reqNumber, checks.number);
    
    // Calculate strength
    if (checks.length) strength++;
    if (checks.uppercase) strength++;
    if (checks.number) strength++;
    
    // Update UI
    strengthBar.className = 'strength-bar';
    if (password.length === 0) {
      strengthBar.className = 'strength-bar';
      strengthText.textContent = 'Enter a password';
      strengthLabel.textContent = '';
      return;
    }
    
    if (strength === 1) {
      strengthBar.classList.add('weak');
      strengthText.textContent = 'Weak password';
      strengthLabel.textContent = 'Weak';
      strengthLabel.style.color = '#EF5350';
    } else if (strength === 2) {
      strengthBar.classList.add('medium');
      strengthText.textContent = 'Medium password';
      strengthLabel.textContent = 'Medium';
      strengthLabel.style.color = '#FFA726';
    } else if (strength === 3) {
      strengthBar.classList.add('strong');
      strengthText.textContent = 'Strong password';
      strengthLabel.textContent = 'Strong';
      strengthLabel.style.color = '#66BB6A';
    }
  }
  
  function updateRequirement(element, isValid) {
    element.className = 'requirement text-xs';
    if (isValid) {
      element.classList.add('valid');
      element.innerHTML = '<i class="fa-regular fa-circle-check mr-1.5"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
    } else {
      element.classList.add('invalid');
      element.innerHTML = '<i class="fa-regular fa-circle mr-1.5"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
    }
  }
  
  passwordField?.addEventListener('input', function() {
    checkPasswordStrength(this.value);
    checkPasswordMatch();
  });

  // ===================== CONFIRM PASSWORD MATCH =====================
  const confirmPassword = document.getElementById('confirm-password');
  const confirmMatch = document.getElementById('confirm-match');
  
  function checkPasswordMatch() {
    const pass = passwordField.value;
    const confirm = confirmPassword.value;
    
    if (confirm.length === 0) {
      confirmMatch.className = 'mt-1 text-xs hidden';
      return;
    }
    
    if (pass === confirm) {
      confirmMatch.className = 'mt-1 text-xs text-[#66BB6A]';
      confirmMatch.innerHTML = '<i class="fa-regular fa-circle-check mr-1"></i> Passwords match';
    } else {
      confirmMatch.className = 'mt-1 text-xs text-[#EF5350]';
      confirmMatch.innerHTML = '<i class="fa-regular fa-circle-xmark mr-1"></i> Passwords do not match';
    }
  }
  
  confirmPassword?.addEventListener('input', checkPasswordMatch);

  // ===================== SIGNUP FORM =====================
  const signupForm = document.getElementById('signup-form');
  const signupResponse = document.getElementById('signup-response');
  const signupBtnText = document.getElementById('signup-btn-text');
  const signupSpinner = document.getElementById('signup-spinner');
  const termsCheck = document.getElementById('terms');
  
  signupForm?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const fullname = document.getElementById('fullname').value.trim();
    const email = document.getElementById('email').value.trim();
    const password = passwordField.value;
    const confirm = confirmPassword.value;
    
    // Validation
    if (!fullname || !email || !password || !confirm) {
      signupResponse.className = 'text-center text-sm py-2 rounded-lg bg-[#FFEBEE] dark:bg-[#2B1815] text-[#C62828] dark:text-[#E28880]';
      signupResponse.textContent = '⚠️ Please fill in all fields.';
      signupResponse.classList.remove('hidden');
      setTimeout(() => signupResponse.classList.add('hidden'), 3000);
      return;
    }
    
    // Email validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      signupResponse.className = 'text-center text-sm py-2 rounded-lg bg-[#FFEBEE] dark:bg-[#2B1815] text-[#C62828] dark:text-[#E28880]';
      signupResponse.textContent = '⚠️ Please enter a valid email address.';
      signupResponse.classList.remove('hidden');
      setTimeout(() => signupResponse.classList.add('hidden'), 3000);
      return;
    }
    
    // Password validation
    if (password.length < 8) {
      signupResponse.className = 'text-center text-sm py-2 rounded-lg bg-[#FFEBEE] dark:bg-[#2B1815] text-[#C62828] dark:text-[#E28880]';
      signupResponse.textContent = '⚠️ Password must be at least 8 characters.';
      signupResponse.classList.remove('hidden');
      setTimeout(() => signupResponse.classList.add('hidden'), 3000);
      return;
    }
    
    // Password match
    if (password !== confirm) {
      signupResponse.className = 'text-center text-sm py-2 rounded-lg bg-[#FFEBEE] dark:bg-[#2B1815] text-[#C62828] dark:text-[#E28880]';
      signupResponse.textContent = '⚠️ Passwords do not match.';
      signupResponse.classList.remove('hidden');
      setTimeout(() => signupResponse.classList.add('hidden'), 3000);
      return;
    }
    
    // Terms check
    if (!termsCheck.checked) {
      signupResponse.className = 'text-center text-sm py-2 rounded-lg bg-[#FFEBEE] dark:bg-[#2B1815] text-[#C62828] dark:text-[#E28880]';
      signupResponse.textContent = '⚠️ Please accept the Terms of Service and Privacy Policy.';
      signupResponse.classList.remove('hidden');
      setTimeout(() => signupResponse.classList.add('hidden'), 3000);
      return;
    }
    
    // Show loading state
    signupBtnText.textContent = 'Creating Account...';
    signupSpinner.classList.remove('hidden');
    signupResponse.classList.add('hidden');
    
    // Simulate API call
    setTimeout(() => {
      // Demo signup - always success
      const success = true;
      
      if (success) {
        signupResponse.className = 'text-center text-sm py-2 rounded-lg bg-[#E8F5E9] dark:bg-[#1D2E21] text-[#2E7D32] dark:text-[#66BB6A]';
        signupResponse.innerHTML = '✅ Account created successfully! Redirecting to login...';
        signupResponse.classList.remove('hidden');
        
        // Reset button
        signupBtnText.textContent = 'Create Account';
        signupSpinner.classList.add('hidden');
        
        // Redirect to login after delay
        setTimeout(() => {
          window.location.href = '/login';
        }, 2000);
      } else {
        signupResponse.className = 'text-center text-sm py-2 rounded-lg bg-[#FFEBEE] dark:bg-[#2B1815] text-[#C62828] dark:text-[#E28880]';
        signupResponse.textContent = '❌ Something went wrong. Please try again.';
        signupResponse.classList.remove('hidden');
        
        signupBtnText.textContent = 'Create Account';
        signupSpinner.classList.add('hidden');
      }
    }, 1500);
  });

  // ===================== ENTER KEY SUPPORT =====================
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      const activeElement = document.activeElement;
      if (activeElement && 
          (activeElement.id === 'fullname' || 
           activeElement.id === 'email' || 
           activeElement.id === 'password' || 
           activeElement.id === 'confirm-password')) {
        signupForm?.dispatchEvent(new Event('submit'));
      }
    }
  });

  // ===================== REAL-TIME VALIDATION =====================
  // Auto-trim spaces in name
  document.getElementById('fullname')?.addEventListener('blur', function() {
    this.value = this.value.trim();
  });
</script>