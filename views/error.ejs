<!-- error.ejs -->
<% layout("/layouts/boilerplate") -%>

<main class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 bg-[#F7F8F5] dark:bg-[#0E1712] transition-colors duration-300">
  
  <!-- Decorative Background Elements -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-[#2E7D32] via-[#C99A2E] to-[#2E7D32] dark:from-[#4CAF50] dark:via-[#E3C069] dark:to-[#4CAF50] opacity-60"></div>
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 dark:opacity-5 pointer-events-none">
    <div class="absolute top-20 right-20 w-64 h-64 rounded-full bg-[#2E7D32] blur-3xl"></div>
    <div class="absolute bottom-20 right-40 w-96 h-96 rounded-full bg-[#C99A2E] blur-3xl"></div>
  </div>
  <div class="absolute bottom-0 left-0 w-1/3 h-1/2 opacity-5 dark:opacity-5 pointer-events-none">
    <div class="absolute bottom-20 left-20 w-72 h-72 rounded-full bg-[#2E7D32] blur-3xl"></div>
  </div>

  <!-- Error Content -->
  <div class="text-center max-w-2xl mx-auto relative z-10 animate-slide-up">
    
    <!-- Logo -->
    <div class="flex justify-center mb-8">
      <a href="/" class="inline-flex items-center gap-2.5">
        <div class="w-14 h-14 rounded-xl bg-[#E8F5E9] dark:bg-[#1D2E21] flex items-center justify-center p-1.5">
          <img src="/images/logo2.png" alt="Bright-Life Pharmacy logo" class="w-full h-full object-contain" />
        </div>
        <div class="leading-tight text-left">
          <p class="font-display font-semibold text-lg text-[#12261A] dark:text-[#F2F8F0]">Bright-Life</p>
          <p class="text-[11px] font-mono text-[#4B5C50] dark:text-[#8FA393] -mt-0.5">Pharmacy</p>
        </div>
      </a>
    </div>

    <!-- Error Status Code -->
    <div class="relative inline-block mb-6">
      <div class="text-8xl md:text-9xl font-extrabold font-display 
                  bg-gradient-to-r from-[#2E7D32] via-[#C99A2E] to-[#2E7D32] 
                  dark:from-[#4CAF50] dark:via-[#E3C069] dark:to-[#4CAF50] 
                  bg-clip-text text-transparent 
                  animate-pulse">
        <%= statusCode || 404 %>
      </div>
      <!-- Subtle Glow -->
      <div class="absolute inset-0 blur-2xl opacity-20 bg-[#2E7D32] dark:bg-[#4CAF50] -z-10 rounded-full"></div>
    </div>

    <!-- Error Message -->
    <h2 class="text-2xl md:text-3xl font-bold text-[#12261A] dark:text-[#F2F8F0] mb-3">
      <%= message || 'Something went wrong' %>
    </h2>
    
    <p class="text-[#4B5C50] dark:text-[#8FA393] text-base md:text-lg max-w-md mx-auto leading-relaxed">
      <%= 
        statusCode === 404 ? 'The page you\'re looking for seems to have wandered off.' :
        statusCode === 500 ? 'Our pharmacy team is working on fixing this issue.' :
        statusCode === 403 ? 'You need special access to view this page.' :
        'We apologize for the inconvenience.'
      %>
    </p>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center mt-8">
      <a href="/" 
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 
               bg-[#2E7D32] hover:bg-[#276b2b] 
               dark:bg-[#3F9142] dark:hover:bg-[#4CAF50] 
               text-white font-medium rounded-xl 
               transition-all duration-300 hover:scale-105 hover:shadow-lg">
        <i class="fa-solid fa-house"></i>
        Return Home
      </a>
      <a href="/contact" 
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 
               border-2 border-[#2E7D32] dark:border-[#4CAF50] 
               text-[#2E7D32] dark:text-[#66BB6A] 
               hover:bg-[#2E7D32] hover:text-white 
               dark:hover:bg-[#3F9142] dark:hover:text-white 
               font-medium rounded-xl 
               transition-all duration-300 hover:scale-105 hover:shadow-lg">
        <i class="fa-solid fa-headset"></i>
        Get Help
      </a>
    </div>

    <!-- Status Specific Badge -->
    <div class="mt-6">
      <span class="inline-flex items-center gap-2 px-4 py-2 
                   bg-[#E8F5E9] dark:bg-[#1D2E21] 
                   border border-[#A5D6A7] dark:border-[#2E7D32] 
                   rounded-full text-xs font-medium 
                   text-[#2E7D32] dark:text-[#66BB6A]">
        <span class="w-2 h-2 rounded-full bg-[#2E7D32] dark:bg-[#66BB6A] animate-pulse"></span>
        <% if(statusCode === 404) { %>
          Page Not Found
        <% } else if(statusCode === 500) { %>
          Server Error
        <% } else if(statusCode === 403) { %>
          Access Denied
        <% } else { %>
          Error <%= statusCode || 'Unknown' %>
        <% } %>
      </span>
    </div>

    <!-- Error Code Reference (only visible in dev) -->
    <p class="text-xs text-[#8A978C] dark:text-[#6E8175] mt-8 opacity-50">
      Error Reference: BL-<%= statusCode || '000' %>-<%= Date.now().toString().slice(-6) %>
    </p>
  </div>
</main>

<style>
  /* Animations */
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-slide-up {
    animation: slideUp 0.6s ease-out;
  }
  
  /* Pulse Animation for Status Code */
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.8;
    }
  }
  
  /* Responsive adjustments */
  @media (max-width: 640px) {
    .text-8xl {
      font-size: 5rem;
    }
  }
</style>

<!-- Additional Script for Error Logging -->
<script>
  // Log error for debugging
  (function() {
    const statusCode = `<%= statusCode || '404' %>`;
    const message = '<%= message || "Unknown error" %>';
    const url = window.location.href;
    
    console.log('🔴 Error Page Loaded:');
    console.log('📄 Status:', statusCode);
    console.log('💬 Message:', message);
    console.log('🔗 URL:', url);
    
    // You can send this to your error tracking service
    // Example: sendToErrorTracking({ statusCode, message, url });
  })();
</script>