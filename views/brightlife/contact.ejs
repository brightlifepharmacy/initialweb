<% layout('layouts/boilerplate') %> 

<div class="container mt-5">
    <h2>Contact Us</h2>
    <form action="/contact" method="POST">
        <div class="mb-3">
            <label for="name" class="form-label">Name</label>
            <input type="text" class="form-control" id="name" name="contact[name]" required>
        </div>
        <div class="mb-3">
            <label for="email" class="form-label">Email Address</label>
            <input type="email" class="form-control" id="email" name="contact[email]" required>
        </div>
        <div class="mb-3">
            <label for="message" class="form-label">Your Query/Message</label>
            <textarea class="form-control" id="message" name="contact[message]" rows="4" required></textarea>
        </div>
        <button type="submit" class="btn btn-success">Submit</button>
    </form>
</div>