<% layout('layouts/boilerplate') %>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2 class="mb-3"><%= blog.title %></h2>
            <img src="<%= blog.image %>" class="img-fluid rounded mb-4 shadow-sm" alt="<%= blog.title %>" style="width: 100%;">
            <div class="content mb-5">
                <p style="font-size: 1.1rem; line-height: 1.8;"><%= blog.content %></p>
            </div>
            
            <hr class="mb-4">
            
            <h4 class="mb-4">Discussion</h4>
            
            <% if (currUser) { %>
                <form action="/blogs/<%= blog._id %>/comments" method="POST" class="mb-4 p-3 bg-light rounded border">
                    <div class="mb-3">
                        <label for="body" class="form-label fw-bold">Leave a Comment</label>
                        <textarea name="comment[body]" id="body" cols="30" rows="3" class="form-control" placeholder="Share your thoughts..." required></textarea>
                    </div>
                    <button class="btn btn-success">Post Comment</button>
                </form>
            <% } else { %>
                <div class="alert alert-info shadow-sm" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    Please <a href="/login" class="alert-link">log in</a> to join the conversation and post a comment.
                </div>
            <% } %>

            <div class="comments-list mt-4">
                <% if (blog.comments.length === 0) { %>
                    <p class="text-muted">No comments yet. Be the first to share your thoughts!</p>
                <% } else { %>
                    <% for (let comment of blog.comments) { %>
                        <div class="card mb-3 border-0 shadow-sm">
                            <div class="card-body bg-light rounded">
                                <h6 class="card-subtitle mb-2 text-primary fw-bold">@<%= comment.author.name %></h6>
                                <p class="card-text mb-0"><%= comment.body %></p>
                            </div>
                        </div>
                    <% } %>
                <% } %>
            </div>
            
        </div>
    </div>
</div>