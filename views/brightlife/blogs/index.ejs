<% layout('layouts/boilerplate') %>

<section class="py-12 bg-white dark:bg-gray-800 transition-all min-h-screen">
  <div class="container mx-auto px-4 mt-4">
    
    <!-- Page Header -->
    <div class="text-center mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-green-600 dark:text-green-400">Health & Wellness Insights</h2>
      <p class="text-gray-600 dark:text-gray-300 mt-3 text-lg max-w-2xl mx-auto">Empowering you with expert medical advice, nutrition tips, and daily wellness strategies from our certified healthcare professionals.</p>
    </div>

    <!-- Topics We Cover (Static Professional UI) -->
    <div class="flex flex-wrap justify-center gap-3 mb-12">
        <span class="px-4 py-2 bg-green-50 text-green-700 rounded-full text-sm font-semibold border border-green-200 shadow-sm"><i class="bi bi-apple me-1"></i> Nutrition</span>
        <span class="px-4 py-2 bg-blue-50 text-blue-700 rounded-full text-sm font-semibold border border-blue-200 shadow-sm"><i class="bi bi-activity me-1"></i> Fitness</span>
        <span class="px-4 py-2 bg-purple-50 text-purple-700 rounded-full text-sm font-semibold border border-purple-200 shadow-sm"><i class="bi bi-brain me-1"></i> Mental Health</span>
        <span class="px-4 py-2 bg-red-50 text-red-700 rounded-full text-sm font-semibold border border-red-200 shadow-sm"><i class="bi bi-capsule me-1"></i> Medicines</span>
        <span class="px-4 py-2 bg-yellow-50 text-yellow-700 rounded-full text-sm font-semibold border border-yellow-200 shadow-sm"><i class="bi bi-heart-pulse me-1"></i> Wellness</span>
    </div>

    <!-- Blogs Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <% if (typeof blogs !== 'undefined' && blogs.length > 0) { %>
        <% for(let blog of blogs) { %>
          <div class="bg-gray-50 dark:bg-gray-700 rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all flex flex-col border border-gray-100 dark:border-gray-600">
            <img src="<%= blog.image %>" class="w-full h-56 object-cover" alt="<%= blog.title %>">
            <div class="p-6 flex-grow flex flex-col justify-between">
              <div>
                <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3"><%= blog.title %></h3>
                <p class="text-gray-600 dark:text-gray-300 mb-5"><%= blog.content.substring(0, 100) %>...</p>
              </div>
              <div>
                <a href="/blogs/<%= blog._id %>" class="inline-block w-full text-center bg-green-600 text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-green-700 transition shadow-sm">
                  Read Article
                </a>
              </div>
            </div>
          </div>
        <% } %>
      <% } else { %>
        <!-- Professional Empty State -->
        <div class="col-span-1 md:col-span-3 text-center py-16 bg-gray-50 dark:bg-gray-700 rounded-xl border border-dashed border-green-300 dark:border-gray-500 shadow-sm">
          <i class="bi bi-journal-medical text-5xl text-green-500 mb-4 inline-block"></i>
          <h3 class="text-2xl font-semibold text-gray-700 dark:text-gray-200 mb-2">Our Medical Authors Are Writing!</h3>
          <p class="text-gray-500 dark:text-gray-400 text-lg max-w-lg mx-auto">Our team of doctors and pharmacists are currently preparing high-quality, verified health articles for you. Please check back soon for our publication!</p>
        </div>
      <% } %>
    </div>

    <!-- Newsletter Subscription (The ultimate professional touch) -->
    <div class="bg-gradient-to-r from-green-600 to-green-500 rounded-2xl p-8 md:p-12 text-center text-white shadow-lg">
        <h3 class="text-2xl md:text-3xl font-bold mb-4">Never Miss a Health Update</h3>
        <p class="text-green-50 mb-6 max-w-xl mx-auto">Subscribe to our weekly newsletter to get the latest health tips, medicine alerts, and wellness guides delivered directly to your inbox.</p>
        <form class="flex flex-col sm:flex-row justify-center gap-3 max-w-lg mx-auto" onsubmit="event.preventDefault(); alert('Subscribed successfully!');">
            <input type="email" placeholder="Enter your email address" class="px-5 py-3 rounded-lg text-gray-800 w-full focus:outline-none focus:ring-2 focus:ring-green-300" required>
            <button type="submit" class="bg-gray-900 hover:bg-gray-800 text-white px-6 py-3 rounded-lg font-semibold transition-colors whitespace-nowrap shadow-md">Subscribe Now</button>
        </form>
        <p class="text-xs text-green-100 mt-4"><i class="bi bi-shield-check me-1"></i> We respect your privacy. No spam, ever.</p>
    </div>

  </div>
</section>