<% layout("/layouts/boilerplate") -%>

<!-- Hero Section with Medical Theme -->
<section class="relative bg-gradient-to-b from-green-50 to-white dark:from-gray-900 dark:to-gray-800 overflow-hidden">
  <!-- Medical Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="medical-pattern" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M0 0h80v80H0z" fill="none"/>
          <path d="M40 20L60 40 40 60 20 40z" stroke="rgb(59 130 246)" stroke-width="1" fill="none"/>
          <path d="M20 20h40v40H20z" stroke="rgb(45 212 191)" stroke-width="1" fill="none"/>
          <circle cx="40" cy="40" r="10" stroke="rgb(59 130 246)" stroke-width="1" fill="none"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#medical-pattern)"/>
    </svg>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      
      <!-- Left Content -->
      <div class="space-y-6">
        <!-- Trust Badge -->
        <div class="inline-flex items-center space-x-2 bg-white dark:bg-gray-800 px-4 py-2 rounded-full shadow-sm border border-green-100 dark:border-gray-700">
          <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">24/7 Emergency Service Available</span>
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
          <span class="text-gray-800 dark:text-white">Your Trusted</span>
          <span class="block bg-gradient-to-r from-green-600 to-teal-500 bg-clip-text text-transparent">Medical Partner</span>
        </h1>

        <!-- Subheading -->
        <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl">
          BrightLife Pharmacy provides genuine allopathic medicines and surgical supplies with expert guidance. 
          Licensed pharmacy serving the community since 2010.
        </p>

        <!-- Key Features -->
        <div class="grid grid-cols-2 gap-4 pt-4">
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
              <i class="fa-solid fa-shield-check text-green-600 dark:text-green-400"></i>
            </div>
            <div>
              <p class="font-semibold text-gray-800 dark:text-white">100% Genuine</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Medicines</p>
            </div>
          </div>
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-teal-100 dark:bg-teal-900/30 rounded-full flex items-center justify-center">
              <i class="fa-solid fa-user-doctor text-teal-600 dark:text-teal-400"></i>
            </div>
            <div>
              <p class="font-semibold text-gray-800 dark:text-white">Expert</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Consultation</p>
            </div>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-6">
          <a href="/products" 
             class="px-8 py-3 bg-gradient-to-r from-green-600 to-teal-500 text-white rounded-lg hover:shadow-xl transition-all duration-300 font-semibold text-center hover:scale-105 flex items-center justify-center">
            <i class="fa-solid fa-capsules mr-2"></i>
            View Available Products
          </a>
          <a href="/contact" 
             class="px-8 py-3 border border-green-500 text-green-600 dark:text-green-400 rounded-lg hover:bg-green-50 dark:hover:bg-green-900/20 transition-all duration-300 font-semibold text-center flex items-center justify-center">
            <i class="fa-solid fa-phone mr-2"></i>
            Contact Pharmacy
          </a>
        </div>
      </div>

      <!-- Right Image -->
      <div class="relative">
        <div class="relative z-10 rounded-2xl overflow-hidden shadow-2xl">
          <div class="aspect-w-4 aspect-h-3 bg-gradient-to-br from-green-400 to-teal-300">
            <!-- Pharmacy Image Placeholder -->
            <div class="w-full h-full flex items-center justify-center p-8">
              <div class="text-center">
                <div class="w-24 h-24 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-6">
                  <i class="fa-solid fa-heart-pulse text-white text-4xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-white mb-2">BrightLife Pharmacy</h3>
                <p class="text-white/90">Allopathic & Surgical Supplies</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Floating Info Cards -->
        <div class="absolute -bottom-4 -left-4 bg-white dark:bg-gray-800 p-4 rounded-xl shadow-xl z-20 max-w-xs border border-gray-100 dark:border-gray-700">
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
              <i class="fa-solid fa-clock text-green-600 dark:text-green-400"></i>
            </div>
            <div>
              <h3 class="font-bold text-gray-800 dark:text-white">Open 24/7</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">Emergency Services</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Available Products Section -->
<section class="py-16 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4 ">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Available Products</h2>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Browse our range of genuine allopathic medicines and surgical supplies
      </p>
    </div>

    <% const activeCategory = typeof selectedCategory !== "undefined" ? selectedCategory : "all"; %>
    <% const activePrice = typeof selectedPrice !== "undefined" ? selectedPrice : "all"; %>

    <!-- Product Filters -->
    <div class="mb-8 space-y-4">
      <div class="flex flex-wrap justify-center gap-2">
        <a href="/?category=all&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'all' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">All Products</a>
        <a href="/?category=allopathic&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'allopathic' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Allopathic Medicines</a>
        <a href="/?category=surgical&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'surgical' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Surgical Items</a>
        <a href="/?category=first-aid&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'first-aid' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">First Aid</a>
        <a href="/?category=devices&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'devices' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Medical Devices</a>
      </div>

      <div class="flex flex-wrap justify-center gap-2">
        <a href="/?category=<%= activeCategory %>&price=all" class="px-4 py-2 <%= activePrice === 'all' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Any Price</a>
        <a href="/?category=<%= activeCategory %>&price=under-100" class="px-4 py-2 <%= activePrice === 'under-100' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Under Rs.100</a>
        <a href="/?category=<%= activeCategory %>&price=100-500" class="px-4 py-2 <%= activePrice === '100-500' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Rs.100 - Rs.500</a>
        <a href="/?category=<%= activeCategory %>&price=above-500" class="px-4 py-2 <%= activePrice === 'above-500' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Above Rs.500</a>
      </div>
    </div>

    <%
      const fallbackProducts = [
        {
          id: 1,
          name: "Paracetamol 500mg",
          description: "Fever and mild pain relief tablets for everyday care.",
          image: "/images/brightlife.png",
          slug: "paracetamol-500mg",
        },
        {
          id: 5,
          name: "Surgical Gloves",
          description: "Sterile disposable gloves for safe medical procedures.",
          image: "/images/logo2.png",
          slug: "surgical-gloves",
        },
        {
          id: 10,
          name: "Digital BP Monitor",
          description: "Automatic blood pressure monitor for home checks.",
          image: "/images/logo1.png",
          slug: "digital-bp-monitor",
        },
        {
          id: 4,
          name: "First Aid Kit",
          description: "Essential wound care supplies for quick response.",
          image: "/images/logo.png",
          slug: "first-aid-kit",
        },
      ];
      const homeProducts =
        typeof products !== "undefined" && Array.isArray(products) && products.length
          ? products
          : fallbackProducts;
    %>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% homeProducts.forEach(product => { %>
        <article class="flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-gray-50 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800">
          <div class="h-44 bg-white p-4 dark:bg-gray-900">
            <img
              src="<%= product.image %>"
              alt="<%= product.name %>"
              class="h-full w-full rounded-lg object-contain"
            >
          </div>

          <div class="flex flex-1 flex-col p-5">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">
              <%= product.name %>
            </h3>

            <p class="mt-2 flex-1 text-sm leading-6 text-gray-600 dark:text-gray-300">
              <%= product.description %>
            </p>

            <p class="mt-3 text-sm font-semibold text-green-600 dark:text-green-400">
              Rs.<%= product.price %>
            </p>

            <div class="mt-5 flex items-center gap-3">
              <a
                href="/product/<%= product.id %>"
                class="flex-1 rounded-lg bg-green-600 px-4 py-2 text-center text-sm font-semibold text-white transition-colors duration-300 hover:bg-green-700"
              >
                View Details
              </a>

              <a
                href="/contact"
                aria-label="Call for <%= product.name %>"
                class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-green-500 text-green-600 transition-colors duration-300 hover:bg-green-50 dark:text-green-400 dark:hover:bg-green-900/20"
              >
                <i class="fa-solid fa-phone"></i>
              </a>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <% if (homeProducts.length === 0) { %>
      <div class="rounded-xl border border-gray-200 bg-gray-50 p-8 text-center dark:border-gray-700 dark:bg-gray-800">
        <p class="font-semibold text-gray-900 dark:text-white">No products found</p>
        <a href="/" class="mt-3 inline-flex text-sm font-semibold text-green-600 dark:text-green-400">Clear filters</a>
      </div>
    <% } %>

    <!-- View All Products Button -->
    <div class="text-center mt-10">
      <a href="/products" 
         class="inline-flex items-center px-6 py-3 border-2 border-green-500 text-green-600 dark:text-green-400 rounded-lg hover:bg-green-50 dark:hover:bg-green-900/20 transition-all duration-300 font-semibold">
        View All Available Products
        <i class="fa-solid fa-arrow-right ml-2"></i>
      </a>
    </div>
  </div>
</section>

<!-- Health & Wellness Blogs -->
<section class="py-16 bg-gray-50 dark:bg-gray-800/50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Health & Wellness Articles</h2>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Educational articles about medicines, surgical care, and health maintenance
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% const blogs = [
        {
          title: 'Understanding Allopathic Medicines',
          excerpt: 'Learn about prescription drugs, their proper usage, and safety guidelines.',
          category: 'Medication Guide',
          readTime: '4 min read',
          date: 'Mar 15, 2024'
        },
        {
          title: 'Surgical Item Sterilization',
          excerpt: 'Importance of proper sterilization techniques for surgical instruments.',
          category: 'Surgical Care',
          readTime: '6 min read',
          date: 'Mar 10, 2024'
        },
        {
          title: 'First Aid Kit Essentials',
          excerpt: 'Must-have items for your home and car first aid kits.',
          category: 'First Aid',
          readTime: '5 min read',
          date: 'Mar 5, 2024'
        }
      ] %>
      
      <% blogs.forEach(blog => { %>
        <div class="bg-white dark:bg-gray-800 rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-200 dark:border-gray-700">
          <!-- Blog Header -->
          <div class="h-48 bg-gradient-to-r from-green-500 to-teal-400 relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <i class="fa-solid fa-file-medical text-white/20 text-8xl"></i>
            </div>
            <div class="absolute top-4 left-4">
              <span class="bg-white/90 text-green-600 px-3 py-1 rounded-full text-xs font-bold">
                <%= blog.category %>
              </span>
            </div>
          </div>

          <!-- Blog Content -->
          <div class="p-6">
            <div class="flex items-center text-sm text-gray-500 dark:text-gray-400 mb-3">
              <i class="fa-solid fa-clock mr-1"></i>
              <span><%= blog.readTime %></span>
              <span class="mx-2">•</span>
              <span><%= blog.date %></span>
            </div>

            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
              <%= blog.title %>
            </h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
              <%= blog.excerpt %>
            </p>

            <a href="/blogs/<%= blog.title.toLowerCase().replace(/ /g, '-') %>" 
               class="text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 font-medium text-sm inline-flex items-center">
              Read Full Article
              <i class="fa-solid fa-arrow-right ml-2"></i>
            </a>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="text-center mt-10">
      <a href="/blogs" 
         class="inline-flex items-center px-6 py-3 bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-300 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-all duration-300 font-semibold">
        View All Articles
        <i class="fa-solid fa-newspaper ml-2"></i>
      </a>
    </div>
  </div>
</section>

<!-- Customer Reviews Section -->
<section class="py-16 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">What Our Customers Say</h2>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Feedback from our valued customers about our products and services
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% const reviews = [
        {
          name: 'Rajesh Kumar',
          role: 'Regular Customer (3 years)',
          review: 'Genuine medicines and excellent service. The 24/7 availability helped during emergencies.',
          rating: 5,
          date: '2 weeks ago'
        },
        {
          name: 'Dr. Priya Sharma',
          role: 'General Physician',
          review: 'I recommend BrightLife to my patients. Their surgical supplies are always sterile and reliable.',
          rating: 5,
          date: '1 month ago'
        },
        {
          name: 'Amit Patel',
          role: 'Hospital Administrator',
          review: 'Bulk orders for surgical items are always delivered on time with proper documentation.',
          rating: 4,
          date: '3 weeks ago'
        }
      ] %>
      
      <% reviews.forEach(review => { %>
        <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-all duration-300">
          <!-- Rating Stars -->
          <div class="flex mb-4">
            <% for(let i = 0; i < 5; i++) { %>
              <i class="fa-solid fa-star <%= i < review.rating ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600' %>"></i>
            <% } %>
          </div>

          <!-- Review Text -->
          <p class="text-gray-700 dark:text-gray-300 italic mb-6">
            "<%= review.review %>"
          </p>

          <!-- Reviewer Info -->
          <div class="flex items-center justify-between">
            <div>
              <h4 class="font-bold text-gray-900 dark:text-white"><%= review.name %></h4>
              <p class="text-sm text-gray-600 dark:text-gray-400"><%= review.role %></p>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-500"><%= review.date %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

