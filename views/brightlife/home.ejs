<% layout("/layouts/boilerplate") -%>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">

<style>
  .font-display { font-family: 'Fraunces', serif; }
  .font-body { font-family: 'Inter', sans-serif; }
  .font-mono { font-family: 'IBM Plex Mono', monospace; }

  .rx-label {
    transform: rotate(-2deg);
    font-family: 'IBM Plex Mono', monospace;
  }
  .rx-label::before {
    content: "";
    position: absolute;
    top: -5px;
    left: 14px;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: inherit;
  }

  /* 3D Scene Perspective Core */
  .scene-3d {
    perspective: 1500px; /* Perspective enhanced for better depth */
    transform-style: preserve-3d;
  }
  .object-3d {
    transform-style: preserve-3d;
    transition: transform 0.15s cubic-bezier(0.25, 0.8, 0.25, 1);
    will-change: transform;
  }
  
  /* Precision Z-axis depths */
  .layer-depth-back { transform: translateZ(-50px) scale(0.9); }
  .layer-depth-sm { transform: translateZ(30px); }
  .layer-depth-md { transform: translateZ(70px); }
  .layer-depth-lg { transform: translateZ(120px); }

  /* Smooth Levitation Keyframes (Retained existing animations) */
  @keyframes float-y {
    0%, 100% { transform: translateY(0px) rotate(6deg); }
    50% { transform: translateY(-12px) rotate(4deg); }
  }
  @keyframes float-reverse {
    0%, 100% { transform: translateY(0px) rotate(-3deg); }
    50% { transform: translateY(10px) rotate(-1deg); }
  }
  .animate-float { animation: float-y 6s ease-in-out infinite; }
  .animate-float-reverse { animation: float-reverse 7s ease-in-out infinite; }

  /* Extra subtle rotation for 3D sub-elements */
  @keyframes spin-slow {
    0% { transform: translateZ(40px) rotate(0deg); }
    100% { transform: translateZ(40px) rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }

  /* Dynamic 3D interactive aura/glow follow */
  .glow-follow {
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(102,187,106,0.15) 0%, rgba(102,187,106,0) 70%);
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%, -50%);
    transition: opacity 0.5s ease;
    opacity: 0;
    z-index: 1;
  }
  #hero-interactive-zone:hover .glow-follow {
    opacity: 1;
  }
</style>

<div class="font-body bg-[#F7F8F5] dark:bg-[#0E1712] text-[#12261A] dark:text-[#E9F2E7] transition-colors duration-300">

  <!-- ============ IMPROVED HERO WITH INTERACTIVE 3D ANIMATION ============ -->
  <section id="hero-section" class="relative overflow-hidden border-b border-[#E3E8E1] dark:border-[#22302A] scene-3d">
    <!-- Ambient Backdrop elements -->
    <div class="absolute -top-24 -right-24 w-[420px] h-[420px] rounded-[40%] bg-[#E8F5E9] dark:bg-[#16261C] opacity-70 dark:opacity-40 rotate-12 pointer-events-none"></div>
    <div class="absolute top-40 -right-10 w-[220px] h-[220px] rounded-full border-[10px] border-[#D4A63A]/30 dark:border-[#D4A63A]/20 pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-6 md:px-10 py-16 md:py-28 grid md:grid-cols-2 gap-12 items-center">
      
      <!-- Left Column: Content + Smart Search & Upload -->
      <div class="z-10">
        <span class="relative inline-block bg-white dark:bg-[#16211A] border border-[#2E7D32]/30 dark:border-[#4CAF50]/40 text-[#2E7D32] dark:text-[#66BB6A] text-xs font-mono tracking-wide px-4 py-1.5 rounded-full rx-label shadow-sm">
          Rx &middot; licensed pharmacy
        </span>

        <h1 class="font-display text-4xl md:text-5xl lg:text-[3.6rem] leading-[1.1] font-semibold mt-6 text-[#12261A] dark:text-[#F2F8F0]">
          Genuine allopathic medicines,
          <span class="text-[#2E7D32] dark:text-[#66BB6A] italic block mt-1">delivered with care.</span>
        </h1>

        <p class="mt-5 text-base md:text-lg text-[#4B5C50] dark:text-[#A9BDAE] max-w-xl leading-relaxed">
          Bright-Life Pharmacy connects you to verified allopathic medicines, trained home-care support, and pharmacist-reviewed guidance &mdash; from one dependable counter.
        </p>

        <!-- Improved Unified Search / Upload Container -->
        <div class="mt-8 bg-white dark:bg-[#16211A] p-2 rounded-2xl border border-[#E3E8E1] dark:border-[#2A3A31] shadow-md max-w-xl transition-all hover:shadow-lg focus-within:ring-2 focus-within:ring-[#2E7D32]/30 dark:focus-within:ring-[#4CAF50]/30">
          <form class="flex flex-col sm:flex-row items-center gap-2">
            <div class="relative flex-1 w-full">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[#4B5C50] dark:text-[#7C9482]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 10a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input type="text" placeholder="Search medicines (e.g., Paracetamol 500mg)..."
                class="w-full pl-11 pr-24 py-3 bg-transparent text-sm text-[#12261A] dark:text-[#E9F2E7] placeholder-[#8A978C] dark:placeholder-[#6E8175] focus:outline-none" />
              
              <!-- Inline Quick Prescription Upload alternative -->
              <label class="absolute right-3 top-1/2 -translate-y-1/2 flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-[#E3E8E1] dark:border-[#2A3A31] bg-[#F7F8F5] dark:bg-[#22302A] text-[11px] font-medium text-[#4B5C50] dark:text-[#A9BDAE] cursor-pointer hover:bg-[#E8F5E9] dark:hover:bg-[#1D2E21] hover:text-[#2E7D32] dark:hover:text-[#66BB6A] transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                <span>Upload Rx</span>
                <input type="file" class="hidden" accept="image/*,.pdf" />
              </label>
            </div>
            
            <button type="submit" class="w-full sm:w-auto px-6 py-3 rounded-xl bg-[#2E7D32] hover:bg-[#276b2b] dark:bg-[#3F9142] dark:hover:bg-[#4CAF50] text-white text-sm font-semibold transition-colors shadow-sm shrink-0">
              Search
            </button>
          </form>
        </div>

        <div class="mt-4 flex flex-wrap gap-2 text-xs text-[#4B5C50] dark:text-[#A9BDAE] pl-1">
          <span class="opacity-75">Popular searches:</span>
          <a href="#" class="hover:text-[#2E7D32] dark:hover:text-[#66BB6A] underline underline-offset-2 decoration-[#2E7D32]/30">Paracetamol</a>
          <a href="#" class="hover:text-[#2E7D32] dark:hover:text-[#66BB6A] underline underline-offset-2 decoration-[#2E7D32]/30">Cetirizine</a>
          <a href="#" class="hover:text-[#2E7D32] dark:hover:text-[#66BB6A] underline underline-offset-2 decoration-[#2E7D32]/30">Metformin</a>
        </div>

        <!-- Metrics Row -->
        <div class="mt-12 grid grid-cols-3 gap-6 max-w-md border-t border-[#E3E8E1] dark:border-[#22302A] pt-6">
          <div class="transform transition-transform hover:-translate-y-1">
            <p class="font-display text-2xl md:text-3xl font-semibold text-[#12261A] dark:text-[#F2F8F0]">1,200+</p>
            <p class="text-xs text-[#4B5C50] dark:text-[#8FA393] mt-1 font-medium">Medicines listed</p>
          </div>
          <div class="transform transition-transform hover:-translate-y-1">
            <p class="font-display text-2xl md:text-3xl font-semibold text-[#12261A] dark:text-[#F2F8F0]">45 min</p>
            <p class="text-xs text-[#4B5C50] dark:text-[#8FA393] mt-1 font-medium">Avg. delivery time</p>
          </div>
          <div class="transform transition-transform hover:-translate-y-1">
            <p class="font-display text-2xl md:text-3xl font-semibold text-[#12261A] dark:text-[#F2F8F0]">4.7 / 5</p>
            <p class="text-xs text-[#4B5C50] dark:text-[#8FA393] mt-1 font-medium">App rating</p>
          </div>
        </div>
      </div>

      <!-- Right Column: Interactive Parallax 3D Animation Graphic -->
      <div class="relative flex justify-center items-center py-8 min-h-[420px] select-none" id="hero-interactive-zone">
        
        <!-- Live Light Follower (Glow Aura) -->
        <div class="glow-follow" id="glow-light"></div>

        <div class="object-3d relative w-80 h-80 md:w-[26rem] md:h-[26rem] flex items-center justify-center">
          
          <!-- Layer 1: Base 3D Shifting Backdrop Blob -->
          <div class="animate-float absolute w-72 h-72 md:w-96 md:h-96 rounded-[38%] bg-gradient-to-br from-[#66BB6A] to-[#2E7D32] dark:from-[#3F9142] dark:to-[#1B5E20] shadow-2xl opacity-95 transition-transform duration-300 layer-depth-back"></div>
          
          <!-- Layer 2: Concentric 3D Geometric Border Frame -->
          <div class="animate-float-reverse absolute w-76 h-76 md:w-[25rem] md:h-[25rem] rounded-[42%] border-2 border-white/40 dark:border-white/10 transition-transform duration-300"></div>

          <!-- EXTRA 3D ELEMENT: Floating Tiny Pills in background layer -->
          <div class="absolute w-full h-full pointer-events-none layer-depth-sm">
            <!-- Green Pill top-left -->
            <div class="absolute top-10 left-6 w-8 h-4 rounded-full bg-[#E8F5E9]/80 border border-emerald-500/20 rotate-[35deg] shadow-md animate-float"></div>
            <!-- Gold Pill bottom-right -->
            <div class="absolute bottom-16 right-4 w-10 h-5 rounded-full bg-[#FDF6E3]/90 border border-amber-500/20 -rotate-12 shadow-md animate-float-reverse"></div>
          </div>

          <!-- Layer 3: Central Floating Medical Icon (Deep Depth Z-Axis) -->
          <div class="layer-depth-md absolute transition-transform duration-300 drop-shadow-[0_20px_50px_rgba(46,125,50,0.4)]">
            <svg class="w-48 h-48 md:w-60 md:h-60 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 20c0-4.5 3-7.5 6-9s6 4.5 6 9" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 20h16" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 11c-1-3 0-6 3-8 3 2 4 5 3 8" fill="none"/>
              <circle cx="16.5" cy="7.5" r="0.9" fill="currentColor" stroke="none"/>
            </svg>
          </div>

          <!-- EXTRA 3D ELEMENT: Rotating cross medical icon floating on the front -->
          <div class="absolute top-12 right-12 text-[#D4A63A] w-6 h-6 animate-spin-slow pointer-events-none">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 10.5h-5.5V5c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v5.5H5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5h5.5V19c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-5.5H19c.83 0 1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5z"/></svg>
          </div>

          <!-- Layer 4: Interactive Floating Microcard (Frontmost Layer with distinct depth) -->
          <div class="layer-depth-lg absolute -bottom-4 -left-4 md:-left-8 bg-white/90 dark:bg-[#16211A]/95 backdrop-blur-md border border-[#E3E8E1] dark:border-[#2A3A31] rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.15)] px-5 py-4 flex items-center gap-3.5 transform transition-transform duration-300 hover:scale-105 cursor-pointer">
            <div class="w-10 h-10 rounded-full bg-[#E8F5E9] dark:bg-[#1D2E21] flex items-center justify-center shadow-inner shrink-0">
              <svg class="w-5 h-5 text-[#2E7D32] dark:text-[#66BB6A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-[#12261A] dark:text-[#F2F8F0] tracking-wide uppercase">Pharmacist Verified</p>
              <p class="text-[11px] text-[#4B5C50] dark:text-[#8FA393] font-medium mt-0.5">Every order checked twice</p>
            </div>
          </div>

          <!-- Layer 5: Secondary Floating Microcard (Right Top Layer) -->
          <div class="layer-depth-md absolute -top-4 -right-4 md:-right-8 bg-white/90 dark:bg-[#16211A]/95 backdrop-blur-md border border-[#E3E8E1] dark:border-[#2A3A31] rounded-2xl shadow-[0_15px_30px_rgba(0,0,0,0.12)] px-4 py-3 flex items-center gap-3 transform transition-all duration-300 hover:scale-105 cursor-pointer">
            <span class="flex h-3 w-3 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
            </span>
            <p class="text-xs font-semibold text-[#12261A] dark:text-[#F2F8F0]">100% Genuine Stock</p>
          </div>

        </div>
      </div>

    </div>
  </section>



  <!-- ============ TRUST STRIP ============ -->
  <section class="border-b border-[#E3E8E1] dark:border-[#22302A] bg-white dark:bg-[#111B15]">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-6 grid grid-cols-2 md:grid-cols-4 gap-6">
          <% [
            { icon: "M9 12l2 2 4-4m5-2a9 9 0 11-18 0 9 9 0 0118 0z", text: "Licensed pharmacists" },
            { icon: "M13 10V3L4 14h7v7l9-11h-7z", text: "Fast, tracked delivery" },
            { icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v2", text: "Secure checkout" },
            { icon: "M5 13l4 4L19 7", text: "Genuine allopathic stock" }
          ].forEach(item => { %>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0 text-[#2E7D32] dark:text-[#66BB6A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= item.icon %>" />
            </svg>
            <span class="text-sm text-[#4B5C50] dark:text-[#A9BDAE]"><%= item.text %></span>
          </div>
      <% }) %>
    </div>
  </section>

  <!-- ============ CATEGORIES ============ -->
  <section class="max-w-7xl mx-auto px-6 md:px-10 py-16 md:py-20">
    <div class="flex items-end justify-between mb-8">
      <div>
        <span class="text-xs font-mono tracking-wide text-[#C99A2E]">shop by category</span>
        <h2 class="font-display text-2xl md:text-3xl font-semibold mt-1">Find what you need, quickly</h2>
      </div>
      <a href="#" class="hidden md:inline-flex items-center gap-1 text-sm text-[#2E7D32] dark:text-[#66BB6A] font-medium hover:underline underline-offset-2">
        View all categories
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      <% [
        { name: "Tablets", icon: "M8.5 15.5l7-7a3.5 3.5 0 10-5-5l-7 7a3.5 3.5 0 105 5z M9 9l6 6" },
        { name: "Syrups", icon: "M9 3h6M10 3v4l-4 8v4a2 2 0 002 2h8a2 2 0 002-2v-4l-4-8V3" },
        { name: "Injectables", icon: "M18.5 5.5l-11 11M15 3l6 6-2 2-6-6zM4 20l3-1 8-8-2-2-8 8-1 3z" },
        { name: "Diabetic care", icon: "M12 3v3m0 12v3M4.2 4.2l2.1 2.1m11.4 11.4l2.1 2.1M3 12h3m12 0h3M4.2 19.8l2.1-2.1m11.4-11.4l2.1-2.1" },
        { name: "Baby & mom", icon: "M12 21c4-2 7-5.5 7-9a7 7 0 10-14 0c0 3.5 3 7 7 9z" },
        { name: "First aid", icon: "M12 4v16m-8-8h16" }
      ].forEach(cat => { %>
        <a href="#" class="group flex flex-col items-center text-center gap-3 p-5 rounded-2xl border border-[#E3E8E1] dark:border-[#22302A] bg-white dark:bg-[#16211A] hover:border-[#2E7D32] dark:hover:border-[#4CAF50] hover:shadow-md transition-all">
          <div class="w-12 h-12 rounded-xl bg-[#E8F5E9] dark:bg-[#1D2E21] flex items-center justify-center group-hover:bg-[#2E7D32] dark:group-hover:bg-[#4CAF50] transition-colors">
            <svg class="w-6 h-6 text-[#2E7D32] dark:text-[#66BB6A] group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= cat.icon %>" />
            </svg>
          </div>
          <span class="text-sm font-medium text-[#12261A] dark:text-[#E9F2E7]"><%= cat.name %></span>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- ============ FEATURED MEDICINES ============ -->
  <section class="bg-white dark:bg-[#111B15] border-y border-[#E3E8E1] dark:border-[#22302A]">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-16 md:py-20">
      <div class="flex items-end justify-between mb-8">
        <div>
          <span class="text-xs font-mono tracking-wide text-[#C99A2E]">featured stock</span>
          <h2 class="font-display text-2xl md:text-3xl font-semibold mt-1">Frequently requested medicines</h2>
        </div>
        <a href="#" class="hidden md:inline-flex items-center gap-1 text-sm text-[#2E7D32] dark:text-[#66BB6A] font-medium hover:underline underline-offset-2">
          Browse full shop
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        <% [
          { name: "Paracip 650", cat: "Fever & pain relief", price: 32, mrp: 40, rating: 4.6, reviews: 128, rx: false },
          { name: "Azithral 500", cat: "Antibiotic", price: 118, mrp: 140, rating: 4.5, reviews: 76, rx: true },
          { name: "Cetzine", cat: "Allergy relief", price: 24, mrp: 30, rating: 4.4, reviews: 95, rx: false },
          { name: "Glycomet 500 SR", cat: "Diabetic care", price: 88, mrp: 102, rating: 4.7, reviews: 210, rx: true },
          { name: "Pantocid 40", cat: "Acidity & gas", price: 96, mrp: 115, rating: 4.6, reviews: 154, rx: true },
          { name: "Volini Gel", cat: "Pain relief", price: 145, mrp: 165, rating: 4.5, reviews: 88, rx: false },
          { name: "Shelcal 500", cat: "Calcium supplement", price: 132, mrp: 150, rating: 4.8, reviews: 302, rx: false },
          { name: "Betadine Ointment", cat: "Wound care", price: 68, mrp: 80, rating: 4.3, reviews: 61, rx: false }
        ].forEach(med => { %>
          <div class="group relative rounded-2xl border border-[#E3E8E1] dark:border-[#22302A] bg-[#FBFAF7] dark:bg-[#16211A] overflow-hidden hover:border-[#2E7D32] dark:hover:border-[#4CAF50] hover:shadow-md transition-all">

            <% if (med.rx) { %>
              <span class="absolute top-3 left-3 z-10 bg-white dark:bg-[#16211A] border border-[#D4A63A]/50 text-[#8a6a1f] dark:text-[#E3C069] text-[10px] font-mono px-2.5 py-1 rounded-full rx-label shadow-sm">
                Rx required
              </span>
            <% } %>

            <div class="h-32 flex items-center justify-center bg-gradient-to-br from-[#E8F5E9] to-[#D2E9D5] dark:from-[#1D2E21] dark:to-[#16241A]">
              <svg class="w-12 h-12 text-[#2E7D32] dark:text-[#66BB6A] opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.5 15.5l7-7a3.5 3.5 0 10-5-5l-7 7a3.5 3.5 0 105 5z M9 9l6 6" />
              </svg>
            </div>

            <div class="p-4">
              <p class="text-[11px] text-[#4B5C50] dark:text-[#8FA393] font-mono"><%= med.cat %></p>
              <h3 class="font-semibold text-sm mt-1 text-[#12261A] dark:text-[#F2F8F0]"><%= med.name %></h3>

              <div class="flex items-center gap-1 mt-2">
                <svg class="w-3.5 h-3.5 text-[#C99A2E]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.05 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.958a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.363 1.118l1.287 3.957c.3.922-.755 1.688-1.538 1.118l-3.37-2.447a1 1 0 00-1.175 0l-3.37 2.447c-.783.57-1.838-.196-1.539-1.118l1.287-3.957a1 1 0 00-.363-1.118L2.062 9.386c-.784-.57-.38-1.81.588-1.81h4.163a1 1 0 00.95-.69l1.286-3.958z"/></svg>
                <span class="text-xs font-medium text-[#12261A] dark:text-[#E9F2E7]"><%= med.rating %></span>
                <span class="text-[11px] text-[#4B5C50] dark:text-[#8FA393]">(<%= med.reviews %>)</span>
