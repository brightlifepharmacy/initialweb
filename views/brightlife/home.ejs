<% layout("/layouts/boilerplate") -%>

<!-- Hero Section with Medical Theme -->
<section class="relative overflow-hidden bg-gradient-to-b from-green-50 to-white dark:from-gray-900 dark:to-gray-800">
  <!-- Medical Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="medical-pattern" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M0 0h80v80H0z" fill="none"/>
          <path d="M40 20L60 40 40 60 20 40z" stroke="rgb(59 130 246)" stroke-width="1" fill="none"/>
          <path d="M20 20h40v40H20z" stroke="rgb(45 212 191)" stroke-width="1" fill="none"/>
          <circle cx="40" cy="40" r="10" stroke="rgb(59 130 246)" stroke-width="1" fill="none"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#medical-pattern)"/>
    </svg>
  </div>

  <div class="container relative px-4 py-12 mx-auto sm:px-6 lg:px-8 md:py-20">
    <div class="grid items-center grid-cols-1 gap-12 lg:grid-cols-2">
      
      <!-- Left Content -->
      <div class="space-y-6">
        <!-- Trust Badge -->
        <div class="inline-flex items-center px-4 py-2 space-x-2 bg-white border border-green-100 rounded-full shadow-sm dark:bg-gray-800 dark:border-gray-700">
          <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">24/7 Emergency Service Available</span>
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl font-bold leading-tight md:text-5xl lg:text-6xl">
          <span class="text-gray-800 dark:text-white">Your Trusted</span>
          <span class="block text-transparent bg-gradient-to-r from-green-600 to-teal-500 bg-clip-text">Medical Partner</span>
        </h1>

        <!-- Subheading -->
        <p class="max-w-xl text-lg text-gray-600 dark:text-gray-400">
          BrightLife Pharmacy provides genuine allopathic medicines and surgical supplies with expert guidance. 
          Licensed pharmacy serving the community since 2010.
        </p>

        <!-- Key Features -->
        <div class="grid grid-cols-1 gap-4 pt-4 sm:grid-cols-2">
          <div class="flex flex-col items-center p-4 space-y-3 transition-shadow duration-300 bg-white border border-gray-100 shadow-sm sm:flex-row sm:items-start sm:space-y-0 sm:space-x-4 dark:bg-gray-800 rounded-xl dark:border-gray-700 hover:shadow-md">
            <div class="flex items-center justify-center flex-shrink-0 w-12 h-12 bg-green-100 rounded-full md:w-14 md:h-14 dark:bg-green-900/30">
              <!-- Inline shield-check SVG to ensure the icon is visible regardless of external font loading -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-600 md:w-8 md:h-8 dark:text-green-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 2.04c-.7 0-1.39.14-2.02.41C6.82 2.9 6 3.45 5.2 3.95c-.8.5-1.61.9-2.56 1.29-.7.28-1.2.96-1.2 1.7v1.2c0 4.23 2.12 8.11 5.58 9.72.24.1.51.1.76 0C13.48 16.25 15.6 12.37 15.6 8.14V6.94c0-.74-.5-1.42-1.2-1.7-.95-.39-1.76-.79-2.56-1.29-.8-.5-1.62-1.05-2.78-1.35-.13-.03-.26-.05-.39-.05zM8.3 9.1a1 1 0 011.4-.1l1.9 1.9 3.2-3.2a1 1 0 011.4 1.42l-4 4a1 1 0 01-1.4 0L8.7 10.5a1 1 0 01-.4-.4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="text-center sm:text-left">
              <p class="font-bold text-gray-900 dark:text-white">100% Genuine Medicines</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">FDA approved products</p>
            </div>
          </div>
          <div class="flex flex-col items-center p-4 space-y-3 transition-shadow duration-300 bg-white border border-gray-100 shadow-sm sm:flex-row sm:items-start sm:space-y-0 sm:space-x-4 dark:bg-gray-800 rounded-xl dark:border-gray-700 hover:shadow-md">
            <div class="flex items-center justify-center flex-shrink-0 w-12 h-12 bg-teal-100 rounded-full md:w-14 md:h-14 dark:bg-teal-900/30">
              <i class="text-2xl text-teal-600 fa-solid fa-user-doctor dark:text-teal-400 md:text-3xl" aria-hidden="true"></i>
            </div>
            <div class="text-center sm:text-left">
              <p class="font-bold text-gray-900 dark:text-white">Expert Consultation</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">Free pharmacist guidance</p>
            </div>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col gap-4 pt-6 sm:flex-row">
          <a href="/products" 
             class="flex items-center justify-center px-8 py-3 font-semibold text-center text-white transition-all duration-300 rounded-lg bg-gradient-to-r from-green-600 to-teal-500 hover:shadow-xl hover:scale-105">
            <i class="mr-2 fa-solid fa-capsules"></i>
            View Available Products
          </a>
          <a href="/contact" 
             class="flex items-center justify-center px-8 py-3 font-semibold text-center text-green-600 transition-all duration-300 border border-green-500 rounded-lg dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20">
            <i class="mr-2 fa-solid fa-phone"></i>
            Contact Pharmacy
          </a>
        </div>
      </div>

      <!-- Right Image -->
      <div class="relative">
        <div class="relative z-10 overflow-hidden shadow-2xl rounded-2xl">
          <div class="aspect-w-4 aspect-h-3 bg-gradient-to-br from-green-400 to-teal-300">
            <!-- Pharmacy Image Placeholder -->
            <div class="flex items-center justify-center w-full h-full p-8">
              <div class="text-center">
                <div class="flex items-center justify-center w-24 h-24 mx-auto mb-6 rounded-full bg-white/20">
                  <i class="text-4xl text-white fa-solid fa-heart-pulse"></i>
                </div>
                <h3 class="mb-2 text-2xl font-bold text-white">BrightLife Pharmacy</h3>
                <p class="text-white/90">Allopathic & Surgical Supplies</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Floating Info Cards -->
        <div class="absolute z-20 max-w-xs p-4 bg-white border border-gray-100 shadow-xl -bottom-4 -left-4 dark:bg-gray-800 rounded-xl dark:border-gray-700">
          <div class="flex items-center space-x-3">
            <div class="flex items-center justify-center w-12 h-12 bg-green-100 rounded-full dark:bg-green-900/30">
              <i class="text-green-600 fa-solid fa-clock dark:text-green-400"></i>
            </div>
            <div>
              <h3 class="font-bold text-gray-800 dark:text-white">Open 24/7</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">Emergency Services</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Available Products Section -->
<section class="py-16 bg-white dark:bg-gray-900">
  <div class="container px-4 mx-auto ">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-gray-900 dark:text-white">Available Products</h2>
      <p class="max-w-2xl mx-auto text-gray-600 dark:text-gray-400">
        Browse our range of genuine allopathic medicines and surgical supplies
      </p>
    </div>

    <% const activeCategory = typeof selectedCategory !== "undefined" ? selectedCategory : "all"; %>
    <% const activePrice = typeof selectedPrice !== "undefined" ? selectedPrice : "all"; %>

    <!-- Product Filters -->
    <div class="mb-8 space-y-4">
      <div class="flex flex-wrap justify-center gap-2">
        <a href="/?category=all&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'all' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">All Products</a>
        <a href="/?category=allopathic&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'allopathic' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Allopathic Medicines</a>
        <a href="/?category=surgical&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'surgical' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Surgical Items</a>
        <a href="/?category=first-aid&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'first-aid' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">First Aid</a>
        <a href="/?category=devices&price=<%= activePrice %>" class="px-4 py-2 <%= activeCategory === 'devices' ? 'bg-green-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Medical Devices</a>
      </div>

      <div class="flex flex-wrap justify-center gap-2">
        <a href="/?category=<%= activeCategory %>&price=all" class="px-4 py-2 <%= activePrice === 'all' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Any Price</a>
        <a href="/?category=<%= activeCategory %>&price=under-100" class="px-4 py-2 <%= activePrice === 'under-100' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Under Rs.100</a>
        <a href="/?category=<%= activeCategory %>&price=100-500" class="px-4 py-2 <%= activePrice === '100-500' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Rs.100 - Rs.500</a>
        <a href="/?category=<%= activeCategory %>&price=above-500" class="px-4 py-2 <%= activePrice === 'above-500' ? 'bg-teal-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' %> rounded-full text-sm font-medium">Above Rs.500</a>
      </div>
    </div>

    <%
      const fallbackProducts = [
        {
          id: 1,
          name: "Paracetamol 500mg",
          description: "Fever and mild pain relief tablets for everyday care.",
          image: "/images/brightlife.png",
          slug: "paracetamol-500mg",
        },
        {
          id: 5,
          name: "Surgical Gloves",
          description: "Sterile disposable gloves for safe medical procedures.",
          image: "/images/logo2.png",
          slug: "surgical-gloves",
        },
        {
          id: 10,
          name: "Digital BP Monitor",
          description: "Automatic blood pressure monitor for home checks.",
          image: "/images/logo1.png",
          slug: "digital-bp-monitor",
        },
        {
          id: 4,
          name: "First Aid Kit",
          description: "Essential wound care supplies for quick response.",
          image: "/images/logo.png",
          slug: "first-aid-kit",
        },
      ];
      const homeProducts =
        typeof products !== "undefined" && Array.isArray(products) && products.length
          ? products
          : fallbackProducts;
    %>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% homeProducts.forEach(product => { %>
        <article class="flex flex-col h-full overflow-hidden transition-all duration-300 border border-gray-200 shadow-sm rounded-xl bg-gray-50 hover:-translate-y-1 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800">
          <div class="p-4 bg-white h-44 dark:bg-gray-900">
            <img
              src="<%= product.image %>"
              alt="<%= product.name %>"
              class="object-contain w-full h-full rounded-lg"
            >
          </div>

          <div class="flex flex-col flex-1 p-5">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">
              <%= product.name %>
            </h3>

            <p class="flex-1 mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">
              <%= product.description %>
            </p>

            <p class="mt-3 text-sm font-semibold text-green-600 dark:text-green-400">
              Rs.<%= product.price %>
            </p>

            <div class="flex items-center gap-3 mt-5">
              <a
                href="/products/<%= encodeURIComponent(product.slug || product._id || product.id) %>"
                class="flex-1 px-4 py-2 text-sm font-semibold text-center text-white transition-colors duration-300 bg-green-600 rounded-lg hover:bg-green-700"
              >
                View Details
              </a>

              <button type="button" aria-label="Leave a comment for <%= product.name %>" class="inline-flex items-center justify-center w-10 h-10 text-lg font-bold text-green-600 transition-colors duration-300 border border-green-500 rounded-lg inquiry-btn hover:bg-green-50 dark:text-green-400 dark:hover:bg-green-900/20" data-product="<%= product.name %>">
                ?
              </button>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <% if (homeProducts.length === 0) { %>
      <div class="p-8 text-center border border-gray-200 rounded-xl bg-gray-50 dark:border-gray-700 dark:bg-gray-800">
        <p class="font-semibold text-gray-900 dark:text-white">No products found</p>
        <a href="/" class="inline-flex mt-3 text-sm font-semibold text-green-600 dark:text-green-400">Clear filters</a>
      </div>
    <% } %>

    <!-- View All Products Button -->
    <div class="mt-10 text-center">
      <a href="/products" 
         class="inline-flex items-center px-6 py-3 font-semibold text-green-600 transition-all duration-300 border-2 border-green-500 rounded-lg dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20">
        View All Available Products
        <i class="ml-2 fa-solid fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>

<!-- Health & Wellness Blogs -->
<section class="py-16 bg-gray-50 dark:bg-gray-800/50">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-gray-900 dark:text-white">Health & Wellness Articles</h2>
      <p class="max-w-2xl mx-auto text-gray-600 dark:text-gray-400">
        Educational articles about medicines, surgical care, and health maintenance
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      <% const fallbackArticles = [
        {
          id: 1,
          title: 'Understanding Allopathic Medicines',
          description: 'Learn about prescription drugs, their proper usage, and safety guidelines.',
          image: '/images/article-allopathic.svg',
          slug: 'understanding-allopathic-medicines',
          category: 'Medication Guide',
          readTime: '4 min read',
          date: 'Mar 15, 2024'
        },
        {
          id: 3,
          title: 'Surgical Item Sterilization',
          description: 'Importance of proper sterilization techniques for surgical instruments.',
          image: '/images/article-surgical.svg',
          slug: 'surgical-item-sterilization',
          category: 'Surgical Care',
          readTime: '6 min read',
          date: 'Mar 10, 2024'
        },
        {
          id: 2,
          title: 'First Aid Kit Essentials',
          description: 'Must-have items for your home and car first aid kits.',
          image: '/images/article-first-aid.svg',
          slug: 'first-aid-kit-essentials',
          category: 'First Aid',
          readTime: '5 min read',
          date: 'Mar 5, 2024'
        }
      ];
      const homeArticles =
        typeof articles !== "undefined" && Array.isArray(articles) && articles.length
          ? articles.slice(0, 3)
          : fallbackArticles;
      %>
      
      <% homeArticles.forEach(article => { %>
        <div class="flex flex-col h-full overflow-hidden transition-all duration-300 bg-white border border-gray-200 shadow-sm rounded-2xl hover:-translate-y-1 hover:shadow-2xl dark:border-gray-700 dark:bg-gray-800">
          <!-- Article Image -->
          <div class="relative aspect-[16/10] overflow-hidden bg-gradient-to-br from-green-50 via-white to-teal-50 p-5 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
            <img
              src="<%= article.image %>"
              alt="<%= article.title %>"
              class="object-contain w-full h-full rounded-xl"
            >
            <div class="absolute left-4 top-4">
              <span class="px-3 py-1 text-xs font-bold text-green-600 rounded-full shadow-sm bg-white/90 backdrop-blur dark:bg-gray-900/80 dark:text-green-300">
                <%= article.category || 'Health Guide' %>
              </span>
            </div>
          </div>

          <!-- Article Content -->
          <div class="flex flex-col flex-1 p-6">
            <div class="flex items-center mb-3 text-sm text-gray-500 dark:text-gray-400">
              <i class="mr-1 fa-solid fa-clock"></i>
              <span><%= article.readTime || '4 min read' %></span>
              <span class="mx-2">•</span>
              <span><%= article.date || 'Health Article' %></span>
            </div>

            <h3 class="text-xl font-bold leading-tight text-gray-900 dark:text-white">
              <%= article.title %>
            </h3>

            <p class="flex-1 mt-3 leading-7 text-gray-600 dark:text-gray-400">
              <%= article.description %>
            </p>

            <a href="/blog/<%= article.slug || article._id || article.id %>" 
               class="inline-flex items-center mt-6 text-sm font-medium text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300">
              Read Full Article
              <i class="ml-2 fa-solid fa-arrow-right"></i>
            </a>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="mt-10 text-center">
      <a href="/blogs" 
         class="inline-flex items-center px-6 py-3 font-semibold text-gray-800 transition-all duration-300 bg-gray-200 rounded-lg dark:bg-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600">
        View All Articles
        <i class="ml-2 fa-solid fa-newspaper"></i>
      </a>
    </div>
  </div>
</section>

<!-- Customer Reviews Section -->
<section class="py-16 bg-white dark:bg-gray-900">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-gray-900 dark:text-white">What Our Customers Say</h2>
      <p class="max-w-2xl mx-auto text-gray-600 dark:text-gray-400">
        Feedback from our valued customers about our products and services
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <% const reviews = [
        {
          name: 'Rajesh Kumar',
          role: 'Regular Customer (3 years)',
          review: 'Genuine medicines and excellent service. The 24/7 availability helped during emergencies.',
          rating: 5,
          date: '2 weeks ago'
        },
        {
          name: 'Dr. Priya Sharma',
          role: 'General Physician',
          review: 'I recommend BrightLife to my patients. Their surgical supplies are always sterile and reliable.',
          rating: 5,
          date: '1 month ago'
        },
        {
          name: 'Amit Patel',
          role: 'Hospital Administrator',
          review: 'Bulk orders for surgical items are always delivered on time with proper documentation.',
          rating: 4,
          date: '3 weeks ago'
        }
      ] %>
      
      <% reviews.forEach(review => { %>
        <div class="p-6 transition-all duration-300 border border-gray-200 bg-gray-50 dark:bg-gray-800 rounded-xl dark:border-gray-700 hover:shadow-lg">
          <!-- Rating Stars -->
          <div class="flex mb-4">
            <% for(let i = 0; i < 5; i++) { %>
              <i class="fa-solid fa-star <%= i < review.rating ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600' %>"></i>
            <% } %>
          </div>

          <!-- Review Text -->
          <p class="mb-6 italic text-gray-700 dark:text-gray-300">
            "<%= review.review %>"
          </p>

          <!-- Reviewer Info -->
          <div class="flex items-center justify-between">
            <div>
              <h4 class="font-bold text-gray-900 dark:text-white"><%= review.name %></h4>
              <p class="text-sm text-gray-600 dark:text-gray-400"><%= review.role %></p>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-500"><%= review.date %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Services Overview -->
<section class="py-16 bg-gradient-to-r from-green-600 to-teal-500">
  <div class="container px-4 mx-auto sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center text-white">
      <h2 class="mb-6 text-3xl font-bold md:text-4xl">Our Pharmacy Services</h2>
      
      <div class="grid grid-cols-1 gap-8 mt-10 md:grid-cols-2">
        <div class="p-6 bg-white/10 backdrop-blur-sm rounded-xl">
          <div class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-full bg-white/20">
            <i class="text-2xl fa-solid fa-prescription"></i>
          </div>
          <h3 class="mb-2 text-xl font-bold">Prescription Medicines</h3>
          <p class="text-white/90">Allopathic drugs with proper prescription guidance</p>
        </div>
        
        <div class="p-6 bg-white/10 backdrop-blur-sm rounded-xl">
          <div class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-full bg-white/20">
            <i class="text-2xl fa-solid fa-syringe"></i>
          </div>
          <h3 class="mb-2 text-xl font-bold">Surgical Supplies</h3>
          <p class="text-white/90">Sterile surgical instruments and disposables</p>
        </div>
        
        <div class="p-6 bg-white/10 backdrop-blur-sm rounded-xl">
          <div class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-full bg-white/20">
            <i class="text-2xl fa-solid fa-user-doctor"></i>
          </div>
          <h3 class="mb-2 text-xl font-bold">Medical Consultation</h3>
          <p class="text-white/90">Free guidance from certified pharmacists</p>
        </div>
        
        <div class="p-6 bg-white/10 backdrop-blur-sm rounded-xl">
          <div class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-full bg-white/20">
            <i class="text-2xl fa-solid fa-truck-medical"></i>
          </div>
          <h3 class="mb-2 text-xl font-bold">Home Delivery</h3>
          <p class="text-white/90">Medicines delivered to your doorstep</p>
        </div>
      </div>
      
      <!-- Contact Info -->
      <div class="pt-8 mt-12 border-t border-white/20">
        <h3 class="mb-6 text-2xl font-bold">Need Assistance?</h3>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <a href="tel:+911234567890" 
             class="flex items-center justify-center px-6 py-3 text-lg font-semibold text-green-600 transition-all duration-300 bg-white rounded-lg hover:bg-gray-100">
            <i class="mr-2 fa-solid fa-phone"></i>
            Call: +91 12345 67890
          </a>
          <a href="/contact" 
             class="flex items-center justify-center px-6 py-3 text-lg font-semibold text-white transition-all duration-300 bg-transparent border-2 border-white rounded-lg hover:bg-white/10">
            <i class="mr-2 fa-solid fa-map-marker-alt"></i>
            Visit Pharmacy
          </a>
