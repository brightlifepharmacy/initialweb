<!-- Interactive Mouse Tracking Script -->
<!-- Interactive Mouse Tracking & Real 3D Parallax Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const interactiveZone = document.getElementById('hero-interactive-zone');
    const target3DObject = interactiveZone?.querySelector('.object-3d');
    const glowLight = document.getElementById('glow-light');

    if (!interactiveZone || !target3DObject) return;

    // Smooth transition control parameters
    let animationFrameId = null;

    interactiveZone.addEventListener('mousemove', (e) => {
      const rect = interactiveZone.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      // Update light source tracker dynamically
      if (glowLight) {
        glowLight.style.left = `${x}px`;
        glowLight.style.top = `${y}px`;
      }

      // Calculate tilt angles based on cursor offset from center
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = -((e.clientY - rect.top - centerY) / centerY) * 20; // max 20 degrees
      const rotateY = ((e.clientX - rect.left - centerX) / centerX) * 20;

      // Cancel previous frame to avoid lag
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
      }

      // Render 3D transform with higher performance utilizing requestAnimationFrame
      animationFrameId = requestAnimationFrame(() => {
        target3DObject.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });
    });

    // Reset layout elements smoothly when cursor leaves
    interactiveZone.addEventListener('mouseleave', () => {
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
      }
      target3DObject.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  });
</script>